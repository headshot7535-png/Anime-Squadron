-- Summary helper
local function printSummary()
    log("SUMMARY", "=== top remote hits ===")
    local sorted = {}
    for path, n in pairs(remoteHits) do sorted[#sorted + 1] = { path = path, n = n } end
    table.sort(sorted, function(a, b) return a.n > b.n end)
    for i = 1, math.min(15, #sorted) do
        log("SUMMARY", sorted[i].n .. "x " .. sorted[i].path)
    end
    flushLog(true)
end

addThread(function()
    task.wait(120)
    while alive() do
        printSummary()
        task.wait(120)
    end
end)

