            local ok2, d = pcall(function() return HS:JSONDecode(r) end)
            if ok2 and d and d.job == game.JobId and os.time() - (tonumber(d.ts) or 0) < 20 then
                return
            end
        end
    end
    _G.AB_TP_BOOT = tick()
    local src
    if readfile and isfile and isfile("AutoBounty.lua") then
        local ok, loc = pcall(readfile, "AutoBounty.lua")
        if ok and loc and #loc > 1000 then src = loc end
    end
    if not src then src = abGet(_u) end
    if src then pcall(function() loadstring(src)() end) end
end)
]]):format(gid, url)
end

local function installReconnectLoader()
    if not shouldInstallReconnect() then return false end
    local url = CONFIG.scriptUrl
    if type(url) ~= "string" or url == "" then return false end
    if type(writefile) ~= "function" then return false end
    local loader = buildReconnectLoader(url)
    local targets = {
        "autoexec/AutoBounty.lua",
        "autoexec/autobounty.lua",
        "../autoexec/AutoBounty.lua",
        "../autoexec/autobounty.lua",
        "auto_exec/AutoBounty.lua",
        "Autoexec/AutoBounty.lua",
    }
    local wrote = false
    for _, path in ipairs(targets) do
        local ok = pcall(function()
            if type(makefolder) == "function" then
                local dir = path:match("^(.*)/")
                if dir and type(isfolder) == "function" and not isfolder(dir) then
                    pcall(makefolder, dir)
                end
            end
            writefile(path, loader)
        end)
        if ok then wrote = true end
    end
    AB._autoexecPaths = targets
    return wrote
end

local function uninstallReconnectLoader()
    if type(delfile) ~= "function" then return false end
    local any = false
    for _, path in ipairs(AB._autoexecPaths or {
        "autoexec/AutoBounty.lua", "autoexec/autobounty.lua",
        "../autoexec/AutoBounty.lua", "../autoexec/autobounty.lua",
        "auto_exec/AutoBounty.lua", "Autoexec/AutoBounty.lua",
    }) do
        pcall(function()
            if type(isfile) == "function" and isfile(path) then
                delfile(path)
                any = true
            end
        end)
    end
    return any
end

armReexec = function()
    if not CONFIG.autoExecute then return false end
    local url = CONFIG.scriptUrl
    if type(url) ~= "string" or url == "" then return false end
    local q = getQueueFn()
    if not q then
        if not AB._queueWarned then
            AB._queueWarned = true
            warn("[Auto Bounty] queue_on_teleport missing — enable reconnect loader or use Misc > Re-arm")
        end
        return false
    end
    local now = tick()
    if AB._lastQueue and (now - AB._lastQueue) < 1.5 then return true end
    AB._lastQueue = now
    markQueueArmed()
    pcall(q, buildQueuePayload(url))
    return true
end

-- Re-arm on teleport (lobby <-> raid, server hop, reconnect-via-teleport)
addConn(LP.OnTeleport:Connect(function(_)
    if CONFIG.autoExecute then pcall(armReexec) end
end))

-- Arm before Roblox closes the client (disconnect / reconnect flow)
pcall(function()
    game:BindToClose(function()
        if CONFIG.autoExecute then pcall(armReexec) end
        if shouldInstallReconnect() then pcall(installReconnectLoader) end
    end)
end)

pcall(armReexec)
if shouldInstallReconnect() then pcall(installReconnectLoader) end

addThread(function()
    local lastInstall = 0
    while alive() do
        task.wait(3)
        if CONFIG.autoExecute then pcall(armReexec) end
        if shouldInstallReconnect() and tick() - lastInstall > 60 then
            lastInstall = tick()
            pcall(installReconnectLoader)
        end
    end
end)

