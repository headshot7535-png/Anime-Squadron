-- ============================================================
local function findTraitMapEntry(world, mode, act)
    for _, m in ipairs(TRAIT_DAILY_MAPS) do
        if m.world == world and m.mode == mode and tonumber(m.act) == tonumber(act) then
            return m
        end
    end
    return nil
end

local function getCurrentPlayMap()
    local ok, play = pcall(function() return require(LP.PlayerScripts.Client.Play) end)
    if ok and play and type(play.current) == "table" then
        local c = play.current
        if c.world and c.mode and c.act then
            return findTraitMapEntry(c.world, c.mode, c.act) or {
                world = c.world, mode = c.mode, act = c.act, cap = 100,
            }
        end
    end
    return nil
end

local function resolveDailyMap()
    local df = Session.dailyFarm
    if df and df.world and df.mode and df.act then
        return findTraitMapEntry(df.world, df.mode, df.act) or {
            world = df.world, mode = df.mode, act = df.act, cap = df.cap or 100,
        }
    end
    return getCurrentPlayMap()
end

local _lastCapLeaveNotify = 0
local function leaveStageIfCapped(map, reason, fromIdx)
    refreshPlayerData()
    if not map then return false end
    if not isTraitCapMaxed(map) and not shouldSkipMapAfterCapLeave(map) then return false end
    setStatus(reason or ("Daily cap full on " .. map.world .. " - leaving stage..."))
    if tick() - _lastCapLeaveNotify > 10 then
        _lastCapLeaveNotify = tick()
        notify("Daily Traits", map.world .. " cap reached (" .. getTraitCapCount(map) .. "/" .. map.cap .. ") — next map.", "success")
    end
    leaveStage(true)
    AB._dailyLeftCap = true
    advanceDailyMapIdx(fromIdx or (Session.dailyFarm and Session.dailyFarm.idx), map)
    return true
end

local function waitForLobbyReturn(timeout)
    local t0 = tick()
    while alive() and (not inLobby() or inBattle()) and (tick() - t0) < (timeout or 60) do
        leaveStage()
        task.wait(2)
    end
    if inLobby() then
        task.wait(2)
        setStatus("Returned to lobby.")
        return true
    end
    return false
end

-- block until stage ends; leave early the moment this map's daily cap is full
local function waitForDailyRun(map)
    local t0 = tick()
    while alive() and CONFIG.enabled and inLobby() and (tick() - t0) < 12 do
        task.wait(0.5)
    end
    if not alive() or not CONFIG.enabled then return false end

    if inLobby() then
        setStatus("Daily traits - waiting for stage to start...")
        local t1 = tick()
        while alive() and CONFIG.enabled and inLobby() and (tick() - t1) < CONFIG.farmTimeout do
            task.wait(2)
        end
        if inLobby() then return false end
    end

    setStatus(("Daily traits - fighting %s %s Act %d, watching cap..."):format(map.mode, map.world, map.act))
    local t2 = tick()
    while alive() and CONFIG.enabled and (not inLobby() or inBattle()) and (tick() - t2) < CONFIG.farmTimeout do
        if leaveStageIfCapped(map, nil, Session.dailyFarm and Session.dailyFarm.idx) then
            waitForLobbyReturn(60)
            return true
        end
        task.wait(1)
    end

    if inLobby() and not inBattle() then return true end
    waitForLobbyReturn(30)
    return true
end

-- block until we leave lobby (battle started) then return to lobby
local function waitForStageReturn()
    local t0 = tick()
    while alive() and CONFIG.enabled and inLobby() and (tick() - t0) < 12 do
        task.wait(0.5)
    end
    if not inLobby() then
        setStatus("Daily traits - in battle, waiting to return...")
        while alive() and not inLobby() do task.wait(1) end
        task.wait(2)
        setStatus("Returned to lobby.")
        return true
    end
    -- same-place fallback: wait until we leave the lobby UI or timeout
    setStatus("Daily traits - waiting for stage to start...")
    local t1 = tick()
    while alive() and CONFIG.enabled and inLobby() and (tick() - t1) < CONFIG.farmTimeout do
        task.wait(2)
    end
    return not inLobby()
end

-- ============================================================
-- Core loop logic
-- ============================================================
-- after launching a stage, block here until we leave the lobby (teleport) or,
-- if it's a same-place arena, until the bounty progress changes.
local function waitForRun(bountyId, startProg)
    local t0 = tick()
    while alive() and CONFIG.enabled and inLobby() and (tick() - t0) < 12 do
        task.wait(0.5)
    end
    if not inLobby() then
        setStatus("In battle - auto-fighting, waiting to return...")
        while alive() and not inLobby() do task.wait(1) end
        task.wait(2) -- let lobby GUI repopulate
        setStatus("Returned to lobby.")
        return
    end
    -- same-place fallback: wait for progress to move
    setStatus("Farming - waiting for bounty progress...")
    local t1 = tick()
    while alive() and CONFIG.enabled and inLobby() and (tick() - t1) < CONFIG.farmTimeout do
        for _, b in ipairs(readBounties()) do
            if b.id == bountyId and (b.progress ~= startProg or b.complete) then return end
        end
        task.wait(2)
    end
end

-- one decision step for daily trait caps; returns "done" when all maps are maxed
local function dailyTraitStep()
    if not CONFIG.dailyTraitFarm then return end

    refreshPlayerData()

    if not inLobby() then
        local map = resolveDailyMap()
        if map then
            local curIdx = Session.dailyFarm and Session.dailyFarm.idx
            if leaveStageIfCapped(map, nil, curIdx) then
                waitForLobbyReturn(45)
                return
            end
            setStatus(("Daily traits - in %s %s Act %d  %d/%d"):format(
                map.mode, map.world, map.act, getTraitCapCount(map), map.cap))
        else
            setStatus("Daily traits - in stage, watching cap...")
        end
        return
    end

    local open = countOpenTraitMaps()
    if open == 0 then
        setStatus("All daily trait caps filled!")
        if CONFIG.dailyStopWhenDone then
            notify("Daily Traits", "Every map's daily Trait Shard cap is full.", "success")
            return "done"
        end
        task.wait(3)
        return
    end

    local startIdx = 1
    if Session.dailyFarm and Session.dailyFarm.idx then
        startIdx = Session.dailyFarm.idx
    end
    local map, idx = nextTraitMap(startIdx)
    if not map then
        setStatus("All daily trait caps filled!")
        return "done"
    end

    local beforeCap = getTraitCapCount(map)
    if isTraitCapMaxed(map) or shouldSkipMapAfterCapLeave(map) then
        advanceDailyMapIdx(idx, map)
        setStatus(map.world .. " capped — rotating to next map")
        return
    end

    rememberDailyMap(map, idx)
    local df = Session.dailyFarm
    df.runs = (df.runs or 0) + 1

    setStatus(("Daily traits: %s %s Act %d  %d/%d  (run #%d, %d maps left)")
        :format(map.mode, map.world, map.act, beforeCap, map.cap, df.runs, open))

    local ok, err = startMap(map.world, map.act, map.mode, CONFIG.dailyDifficulty)
    if not ok then
        setStatus("Daily launch failed: " .. tostring(err))
        advanceDailyMapIdx(idx, nil)
        df.stall = (df.stall or 0) + 1
        saveSession()
        local qn = #getDailyMapQueue()
        if qn > 0 and df.stall >= qn then
            notify("Daily Traits", "Couldn't enter any daily-trait map. Stopped.", "error")
            return "done"
        end
        task.wait(2)
        return
    end

    waitForDailyRun(map)

    refreshPlayerData()
    local afterCap = getTraitCapCount(map)
    if afterCap > beforeCap then
        df.stall = 0
        df.lastCap = afterCap
    else
        df.stall = (df.stall or 0) + 1
    end
    saveSession()

    if isTraitCapMaxed(map) or shouldSkipMapAfterCapLeave(map) then
        if not AB._dailyLeftCap then
            notify("Daily Traits", map.world .. " cap reached (" .. map.cap .. ") — next map.", "success")
        end
        AB._dailyLeftCap = nil
        advanceDailyMapIdx(idx, map)
        return
    end
    if df.stall >= CONFIG.dailyStallRuns then
        setStatus(map.world .. " cap stalled - moving to next map")
        notify("Daily Traits", map.world .. " cap not increasing - skipping.", "info")
        advanceDailyMapIdx(idx, map)
        df.stall = 0
        saveSession()
    end
end

-- one decision step; returns "done" when there is nothing left to do
local function step()
    if not CONFIG.bountyFarm then return end
    if not inLobby() then
        setStatus("Not in lobby (battle/loading) - waiting...")
        return
    end

    local list = readBounties()
    if #list == 0 then
        -- board not populated yet (just joined / still loading) - wait, don't stop
        setStatus("Waiting for bounty board to load...")
        return
    end

    -- SAFETY: figure out if ANY bounty on the board is a trait/reroll one. If not,
    -- we refuse to decline (unless explicitly forced) so we never wipe the whole
    -- board because of a reward-name mismatch. This is what caused "all bounties
    -- disappear on execute".
    local anyTrait = false
    for _, b in ipairs(list) do if b.trait then anyTrait = true break end end
    local mayDecline = CONFIG.declineNonTrait and (anyTrait or CONFIG.declineEvenIfNoTrait)

    -- 1) handle the active bounty first (one active at a time)
    local active
    for _, b in ipairs(list) do if b.active then active = b break end end
    if active then
        if active.complete then
            setStatus(("Claiming completed bounty (%s)"):format(active.world or "?"))
            if bClaim(active.id) then
                notify("Bounty", "Claimed reward from " .. (active.world or "bounty"), "success")
                forgetBounty()
            end
            return
        end
        if active.trait then
            -- remember this target on disk so it survives the Story-mode teleport.
            -- We can't read the enemy in Story mode, so we MATCH the enemy to the
            -- right act by trial: if the last run added 0 progress, that act has no
            -- such enemy -> cycle to the next act. When progress moves, lock the act.
            local prev = Session.bounty
            local madeProgress = true
            if prev and prev.id == active.id and prev.lastLaunchProgress ~= nil then
                madeProgress = active.progress > prev.lastLaunchProgress
            end
            -- self-correct: if we left early last run but the server didn't credit
            -- the kills, stop early-leaving and just finish stages fully instead.
            if AB._earlyLeft then
                AB._earlyLeft = false
                if not madeProgress then
                    AB._noEarlyLeave = true
                    madeProgress = true -- banking issue, not a wrong-act issue
                    setStatus("Early-leave didn't bank progress - switching to full runs.")
                    notify("Auto Bounty", "Leaving early didn't credit kills; finishing stages fully now.", "info")
                end
            end
            rememberBounty(active) -- preserves act / actsTried / foundAct for the same id
            local s = Session.bounty

            if madeProgress then
                s.foundAct = true   -- this act spawns the enemy; lock it in
                s.actsTried = 0
                s.failRuns = 0
            elseif prev and prev.lastLaunchProgress ~= nil then
                if s.foundAct then
                    -- right act, but the run didn't clear (lost / unlucky) - retry,
                    -- but don't loop forever if the loadout simply can't do it
                    s.failRuns = (s.failRuns or 0) + 1
                    if s.failRuns >= CONFIG.maxActs then
                        setStatus(("Runs on %s Act %d aren't clearing - stopping (loadout?)")
                            :format(active.world or "?", s.act or CONFIG.act))
                        notify("Auto Bounty", "Can't clear the stage for " ..
                            (active.enemy or "the target") .. ". Stopped.", "error")
                        setEnabled(false)
                        return "done"
                    end
                else
                    -- enemy not in this act yet -> cycle to the next act
                    s.actsTried = (s.actsTried or 0) + 1
                    if s.actsTried >= CONFIG.maxActs then
                        setStatus(("Tried every act in %s, %s never appeared - stopping")
                            :format(active.world or "?", active.enemy or "target"))
                        notify("Auto Bounty", "Couldn't find " ..
                            (active.enemy or "the target") .. " in any act of " ..
                            (active.world or "that world") .. ".", "error")
                        setEnabled(false)
                        return "done"
                    end
                    s.act = ((s.act or CONFIG.act) % CONFIG.maxActs) + 1
                    setStatus(("%s not found - trying %s Act %d")
                        :format(active.enemy or "target", active.world or "?", s.act))
                end
            end

            local act = s.act or CONFIG.act
            setStatus(("Farming %s Act %d: eliminate %s  %d/%d  (run #%d)")
                :format(active.world or "?", act, active.enemy or "target",
                    active.progress, active.required, (s.runs or 0) + 1))
            s.runs = (s.runs or 0) + 1
            s.lastLaunchProgress = active.progress
            Session.runKills = 0 -- reset live counter for this new run
            AB._leftRun = false  -- allow one early-leave for this new run
            saveSession()

            local ok, err = startMap(active.world, act)
            if ok then
                waitForRun(active.id, active.progress)
            else
                setStatus("Launch failed: " .. tostring(err))
                task.wait(2)
            end
            return
        end
        -- active bounty does NOT reward trait shards
        if mayDecline then
            setStatus("Active bounty has no trait reward - declining it")
            bDecline(active.id)
        elseif CONFIG.declineNonTrait then
            setStatus("No trait bounty on board - NOT declining (safety). See console.")
            task.wait(3)
        else
            setStatus("Active bounty has no trait reward (decline disabled) - idle")
            task.wait(2)
        end
        return
    end

    -- no active bounty -> drop any stale memory of one
    if Session.bounty then forgetBounty() end

    -- 2) no active bounty -> clear out a non-trait bounty (one per step)
    if mayDecline then
        for _, b in ipairs(list) do
            if (not b.trait) and (not b.active) then
                setStatus(("Declining non-trait bounty (%s)"):format(b.world or "?"))
                bDecline(b.id)
                return
            end
        end
    end

    -- 3) accept a trait-reroll bounty
    for _, b in ipairs(list) do
        if b.trait and (not b.active) then
            setStatus(("Accepting trait bounty (%s)"):format(b.world or "?"))
            if bAccept(b.id) then
                notify("Bounty", "Accepted: " .. (b.world or "bounty"), "info")
            end
            return
        end
    end

    -- 4) nothing acceptable left
    if not anyTrait then
        if CONFIG.useRefreshTicket and getTickets() > 0 then
            setStatus("No trait bounties - using a ticket to roll a new one")
            bUseTicket()
            return
        end
        -- don't claim "done" and stop; without declining we just idle and keep
        -- watching in case the board changes (and we never wipe it)
        setStatus("No trait/reroll bounty available - waiting (board left intact).")
        task.wait(3)
        return
    end
end

local _looping = false
local _inSetEnabled = false
function mainLoop()
    if _looping then return end
    _looping = true
    setStatus("Auto Bounty started.")
    while alive() and CONFIG.enabled do
        local bountyDone, dailyDone = false, false

        if CONFIG.bountyFarm then
            local ok, res = pcall(step)
            if not ok then
                setStatus("Error: " .. tostring(res))
            elseif res == "done" then
                bountyDone = true
                if CONFIG.stopWhenDone and not CONFIG.dailyTraitFarm then
                    setStatus("No trait-reroll bounties left - stopped.")
                    notify("Auto Bounty", "No trait bounties left. Done.", "success")
                    setEnabled(false)
                    break
                end
            end
        end

        if CONFIG.dailyTraitFarm and alive() and CONFIG.enabled then
            local ok2, res2 = pcall(dailyTraitStep)
            if not ok2 then
                setStatus("Daily error: " .. tostring(res2))
            elseif res2 == "done" then
                dailyDone = true
                if CONFIG.dailyStopWhenDone and (not CONFIG.bountyFarm or bountyDone) then
                    setEnabled(false)
                    break
                end
            end
        end

        if CONFIG.bountyFarm and CONFIG.dailyTraitFarm and bountyDone and dailyDone then
            setStatus("Bounty + daily trait caps all done - stopped.")
            notify("Auto Bounty", "Nothing left to farm. Done.", "success")
            setEnabled(false)
            break
        end

        task.wait(CONFIG.loopDelay)
    end
    _looping = false
    setStatus("Stopped.")
end

function setEnabled(on)
    on = on and true or false
    if _inSetEnabled then return end
    if CONFIG.enabled == on then
        Session.running = on
        AB.enabled = on
        return
    end
    _inSetEnabled = true
    CONFIG.enabled = on
    AB.enabled = CONFIG.enabled
    Session.running = CONFIG.enabled
    pcall(saveSettings)
    if canFile and canFile() then
        pcall(function() writefile("AutoBounty_session.json", HttpService:JSONEncode(Session)) end)
    end
    if CONFIG.enabled then addThread(mainLoop) end
    _inSetEnabled = false
end

-- remember/forget the bounty we are currently farming (persists across teleport)
function rememberBounty(b)
    if not b then return end
    local s = Session.bounty
    if not s or s.id ~= b.id then
        -- new target: start at the configured act, will auto-cycle if no enemy
        s = { id = b.id, runs = 0, act = CONFIG.act, actsTried = 0,
              foundAct = false, failRuns = 0, lastLaunchProgress = nil }
    end
    s.world    = b.world
    s.enemy    = b.enemy
    s.required = b.required
    s.progress = b.progress
    Session.bounty = s
    if saveSession then saveSession() end
end
function forgetBounty()
    Session.bounty = nil
    if saveSession then saveSession() end
end

