local function clickBackToLobby()
    local btn = findBackToLobbyTeleportBtn()
    if not btn then
        openGameSettingsGameplay()
        btn = findBackToLobbyTeleportBtn()
    end
    if not btn then return false end
    if not invokeGui(btn) then return false end
    task.wait(1.2)
