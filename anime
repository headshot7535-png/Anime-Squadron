                if ok and type(data) == "table"
                    and type(data.awakening) == "table"
                    and type(data.awakening.cost) == "table" then
                    map[child.Name] = true
                end
            end
        end
    end
    AWAKENABLE_NAMES = map
    return map
end

local function isAwakenableUnitName(unitName)
    if type(unitName) ~= "string" or unitName == "" then return false, nil end
    local awakenable = scanAwakenableCharacterNames()
    if awakenable[unitName] then return true, unitName end
    local folder = ReplicatedStorage.Characters:FindFirstChild(unitName)
    if folder then
        local data = getCharacterData(unitName)
        if data and type(data.awakening) == "table" and type(data.awakening.cost) == "table" then
            return true, unitName
        end
    end
    return false, nil
end

local function discoverUnitsFromCharactersGui(seen)
    local list = {}
    seen = seen or {}
    local menus = getMenus()
    local charsFrame = menus and menus:FindFirstChild("Characters")
    local scroll = charsFrame and charsFrame:FindFirstChild("ScrollingFrame")
    local awakenable = scanAwakenableCharacterNames()
    if not scroll then return list end

    for _, child in ipairs(scroll:GetChildren()) do
        if child:IsA("GuiButton") then
            local modelName = nil
            local vp = child:FindFirstChild("ViewportFrame")
            local wm = vp and vp:FindFirstChildOfClass("WorldModel")
            if wm then modelName = wm.Name end
            if not modelName and child:FindFirstChild("UnitName") then
                modelName = child.UnitName.Text
            end
            if modelName and awakenable[modelName] and not seen[modelName] then
                seen[modelName] = true
                list[#list + 1] = {
                    id = child.Name,
                    name = modelName,
                    index = tonumber(child.Name),
                    level = nil,
                }
            end
        end
    end
    return list
end

local function countAwakenUnitCache()
    local n = 0
    if AS.awakenUnitByName then
        for _ in pairs(AS.awakenUnitByName) do n = n + 1 end
    end
    return n
end

local function mergeAwakenUnitEntry(list, seen, entry)
    if type(entry) ~= "table" or type(entry.name) ~= "string" or entry.name == "" then return end
    if seen[entry.name] then return end
    seen[entry.name] = true
    list[#list + 1] = entry
end

local function updateAwakenUnitsCache(units)
    if type(units) ~= "table" or #units == 0 then return end
    AS.awakenUnitByName = AS.awakenUnitByName or {}
    Session.awakenUnitCache = Session.awakenUnitCache or { byName = {} }
    local byName = Session.awakenUnitCache.byName or {}
    local before = countAwakenUnitCache()
    for _, u in ipairs(units) do
        if u.name then
            local prev = byName[u.name] or AS.awakenUnitByName[u.name]
            local merged = {
                id    = u.id or (prev and prev.id),
                name  = u.name,
                index = u.index or (prev and prev.index),
                level = u.level or (prev and prev.level),
            }
            byName[u.name] = merged
            AS.awakenUnitByName[u.name] = merged
        end
    end
    local after = countAwakenUnitCache()
    if after > before or (inLobby() and after > 0) then
        Session.awakenUnitCache.byName = byName
        saveSession()
    end
end

local function getOwnedAwakenableUnits()
    restoreAwakenUnitCache()
    local list, seen = {}, {}

    if AS.awakenUnitByName then
        local cached = {}
        for _, u in pairs(AS.awakenUnitByName) do cached[#cached + 1] = u end
        table.sort(cached, function(a, b) return tostring(a.name) < tostring(b.name) end)
        for _, u in ipairs(cached) do
            mergeAwakenUnitEntry(list, seen, u)
        end
    end

    if inLobby() then
        refreshPlayerData()
    end
    local data = getPlayerData()
    if data and type(data.characters) == "table" then
        for id, ch in pairs(data.characters) do
            if type(ch) == "table" and type(ch.name) == "string" and ch.name ~= "" then
                local ok, folderName = isAwakenableUnitName(ch.name)
                if ok and folderName then
                    mergeAwakenUnitEntry(list, seen, {
                        id = ch.id or id,
                        name = folderName,
                        index = ch.index,
                        level = ch.level,
                    })
                end
            end
        end
    end

    if inLobby() then
        for _, u in ipairs(discoverUnitsFromCharactersGui(seen)) do
            mergeAwakenUnitEntry(list, seen, u)
        end
    end

    table.sort(list, function(a, b) return tostring(a.name) < tostring(b.name) end)
    if #list > 0 then
        updateAwakenUnitsCache(list)
    end
    return list
end

local function findOwnedUnitByName(unitName)
    if type(unitName) ~= "string" or unitName == "" then return nil end
    restoreAwakenUnitCache()
    if AS.awakenUnitByName and AS.awakenUnitByName[unitName] then
        return AS.awakenUnitByName[unitName]
    end
    if not inLobby() then
        return nil
    end
    refreshPlayerData()
    local data = getPlayerData()
    if data and type(data.characters) == "table" then
        for id, ch in pairs(data.characters) do
            if type(ch) == "table" and ch.name then
                local ok, folderName = isAwakenableUnitName(ch.name)
                if ok and folderName == unitName then
                    local unit = {
                        id = ch.id or id,
                        name = folderName,
                        index = ch.index,
                        level = ch.level,
                    }
                    updateAwakenUnitsCache({ unit })
                    return unit
                end
            end
        end
    end
    for _, u in ipairs(getOwnedAwakenableUnits()) do
        if u.name == unitName then return u end
    end
    return nil
end

