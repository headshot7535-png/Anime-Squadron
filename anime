    return t:find(want, 1, true) ~= nil
end

local function gameExactItemCount(data, itemName)
    if type(data) ~= "table" or type(itemName) ~= "string" or itemName == "" then return nil end
    local items = type(data.items) == "table" and data.items or nil
    local stats = type(data.stats) == "table" and data.stats or nil
    local keys = { itemName, string.lower(itemName) }
    for _, key in ipairs(keys) do
        local raw = items and items[key]
        if raw == nil and stats then raw = stats[key] end
        if raw ~= nil then
            local n = coerceItemValue(raw)
            return n ~= nil and n or 0
