-- Stage leave (Settings > Gameplay > Back To Lobby > Teleport during raids)
local function guiText(node)
    if not node then return "" end
    if node:IsA("TextLabel") or node:IsA("TextButton") then return node.Text or "" end
    return ""
end

local function guiTextDeep(node)
    if not node then return "" end
    local direct = guiText(node)
    if direct ~= "" then return direct end
    for _, d in ipairs(node:GetDescendants()) do
        if d:IsA("TextLabel") or d:IsA("TextButton") then
            local t = d.Text
            if t and t ~= "" then return t end
        end
    end
    return ""
end

local function invokeGui(btn)
    if not btn or not btn.Parent then return false end
    local targets = { btn }
    local rb = btn:FindFirstChild("RealButton")
    if rb then targets[#targets + 1] = rb end
    local fired = false
    if getconnections then
        for _, t in ipairs(targets) do
            for _, sig in ipairs({ "Activated", "MouseButton1Click" }) do
                local ev = t[sig]
                if ev then
                    for _, conn in ipairs(getconnections(ev)) do
                        if conn.Function then
                            fired = pcall(conn.Function) or fired
                        end
                    end
                end
            end
        end
    end
    if not fired and firesignal then
        for _, t in ipairs(targets) do
            fired = pcall(firesignal, t.Activated) or fired
            fired = pcall(firesignal, t.MouseButton1Click) or fired
        end
    end
    return fired
end

local function clickGui(btn)
    return invokeGui(btn)
end

local function openGameSettingsGameplay()
    local menus = getMenus()
    if not menus then return nil end
    local settings = menus:FindFirstChild("Settings")
    if not settings then return nil end

    if not settings.Visible then
        local openBtn = menus:FindFirstChild("Buttons")
            and menus.Buttons:FindFirstChild("Buttons2")
            and menus.Buttons.Buttons2:FindFirstChild("Settings")
        if openBtn then
            local rb = openBtn:FindFirstChild("RealButton")
            invokeGui(rb or openBtn)
        end
        task.wait(0.35)
        if not settings.Visible then settings.Visible = true end
    end

    local filters = settings:FindFirstChild("Filters")
    local gameplayTab = filters and filters:FindFirstChild("Gameplay")
    if gameplayTab then
        local rb = gameplayTab:FindFirstChild("RealButton")
        invokeGui(rb or gameplayTab)
    end

    local sf = settings:FindFirstChild("ScrollingFrame")
    local gameplay = sf and sf:FindFirstChild("Gameplay")
    if gameplay then gameplay.Visible = true end
    task.wait(0.15)
    return gameplay
end

local function findBackToLobbyTeleportBtn()
    local menus = getMenus()
    local settings = menus and menus:FindFirstChild("Settings")
    if not settings then return nil end
    local searchRoots = {}
    local sf = settings:FindFirstChild("ScrollingFrame")
    if sf then
        local gameplay = sf:FindFirstChild("Gameplay")
        if gameplay then searchRoots[#searchRoots + 1] = gameplay end
        searchRoots[#searchRoots + 1] = sf
    end
    searchRoots[#searchRoots + 1] = settings

    for _, root in ipairs(searchRoots) do
        for _, key in ipairs({ "back_to_lobby", "return_to_lobby", "to_lobby", "back_to_lobby_button" }) do
            local row = root:FindFirstChild(key, true)
            if row then
                local action = row:FindFirstChild("button") or row:FindFirstChild("action")
                if action and not action:FindFirstChild("slider") then return action end
            end
        end
    end

    for _, root in ipairs(searchRoots) do
        for _, row in ipairs(root:GetDescendants()) do
            if row:IsA("GuiButton") then
                local nameLbl = row:FindFirstChild("name")
                if nameLbl and nameLbl:IsA("TextLabel") then
                    local txt = nameLbl.Text:lower()
                    if txt:find("back", 1, true) and txt:find("lobby", 1, true) then
                        for _, ch in ipairs(row:GetDescendants()) do
                            if (ch:IsA("GuiButton") or ch:IsA("TextButton")) and ch ~= row then
                                if guiTextDeep(ch):lower():find("teleport", 1, true) then
                                    return ch
                                end
                            end
                        end
                        local action = row:FindFirstChild("button")
                        if action and not action:FindFirstChild("slider") then return action end
                    end
                end
            end
        end
        for _, d in ipairs(root:GetDescendants()) do
            if d:IsA("TextLabel") and guiText(d):lower() == "teleport" then
                local parent = d.Parent
                while parent and parent ~= root do
                    if parent:IsA("GuiButton") or parent:IsA("TextButton") or parent:IsA("ImageButton") then
                        return parent
                    end
                    parent = parent.Parent
                end
            end
        end
    end
    return nil
end

local function clientForceLeave()
    pcall(function()
        local gui = require(LP.PlayerScripts.Client.Gui)
        local play = require(LP.PlayerScripts.Client.Play)
        if gui and type(gui.transition) == "function" then
            task.spawn(gui.transition)
