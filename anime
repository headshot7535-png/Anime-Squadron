-- ============================================================
-- 2) workspace.Characters model probe
-- ============================================================
local modelSnap = {}
local function modelKey(m)
    return m:GetFullName()
end

local function dumpModel(m)
    local attrs = {}
    pcall(function()
        for name, val in pairs(m:GetAttributes()) do
            attrs[#attrs + 1] = name .. "=" .. tostring(val)
        end
    end)
    table.sort(attrs)
    local parts = {}
    for _, d in ipairs(m:GetDescendants()) do
        if d:IsA("ValueBase") then
            parts[#parts + 1] = d.Name .. "=" .. tostring(d.Value)
        elseif d:IsA("TextLabel") and d.Visible and d.Text ~= "" then
            parts[#parts + 1] = "TL:" .. d.Name .. "=" .. d.Text:sub(1, 40)
        end
    end
    return {
        name = m.Name,
        class = m.ClassName,
        attrs = table.concat(attrs, ", "),
        values = table.concat(parts, ", "),
    }
end

local function scanCharactersFolder(folder)
    if not folder then return end
    for _, m in ipairs(folder:GetChildren()) do
        if m:IsA("Model") then
            local key = modelKey(m)
            local snap = dumpModel(m)
            local sig = snap.attrs .. "|" .. snap.values
            local prev = modelSnap[key]
            if not prev then
                modelSnap[key] = sig
                log("MODEL+ ", ("%s type-attrs=[%s] vals=[%s]"):format(key, snap.attrs, snap.values))
            elseif prev ~= sig then
                modelSnap[key] = sig
                log("MODELΔ ", ("%s now attrs=[%s] vals=[%s]"):format(key, snap.attrs, snap.values))
            end
        end
    end
end

local function bindCharacters(container)
    scanCharactersFolder(container)
    addConn(container.ChildAdded:Connect(function(m)
        if m:IsA("Model") then
            task.defer(function()
                local snap = dumpModel(m)
                log("MODEL+ ", ("ADD %s [%s] vals=[%s]"):format(m:GetFullName(), snap.attrs, snap.values))
                modelSnap[modelKey(m)] = snap.attrs .. "|" .. snap.values
            end)
        end
    end))
    addConn(container.ChildRemoved:Connect(function(m)
        if m:IsA("Model") then
            local t = "?"
            pcall(function() t = tostring(m:GetAttribute("type") or "?") end)
            log("MODEL-", "REMOVED " .. m.Name .. " type=" .. t)
            modelSnap[modelKey(m)] = nil
        end
    end))
end

local chars = workspace:FindFirstChild("Characters")
if chars then bindCharacters(chars) end
addConn(workspace.ChildAdded:Connect(function(c)
    if c.Name == "Characters" then
        log("WORLD", "workspace.Characters appeared")
        bindCharacters(c)
    end
end))

-- ============================================================
-- 3) leaderstats / player combat stats
-- ============================================================
local lastDamage = {}

local function scanLeaderstats(plr)
    local ls = plr:FindFirstChild("leaderstats")
    if not ls then return end
    for _, v in ipairs(ls:GetChildren()) do
        if v:IsA("IntValue") or v:IsA("NumberValue") then
            local key = plr.Name .. "/" .. v.Name
            local cur = v.Value
            local prev = lastDamage[key]
            if prev == nil then
                lastDamage[key] = cur
                log("STAT+", ("%s = %s"):format(key, tostring(cur)))
            elseif cur ~= prev then
                local delta = cur - prev
                lastDamage[key] = cur
                log("STATΔ", ("%s %s -> %s (+%s)"):format(key, tostring(prev), tostring(cur), tostring(delta)))
            end
            if not v:GetAttribute("_cp_hook") then
                v:SetAttribute("_cp_hook", true)
                addConn(v:GetPropertyChangedSignal("Value"):Connect(function()
                    local p = lastDamage[key] or 0
                    local n = v.Value
                    if n ~= p then
                        lastDamage[key] = n
                        log("STATΔ", ("%s LIVE %s -> %s (+%s)"):format(key, tostring(p), tostring(n), tostring(n - p)))
                    end
                end))
            end
        end
    end
end

for _, p in ipairs(Players:GetPlayers()) do scanLeaderstats(p) end
addConn(Players.PlayerAdded:Connect(scanLeaderstats))
addConn(LP.ChildAdded:Connect(function(c)
    if c.Name == "leaderstats" then task.defer(function() scanLeaderstats(LP) end) end
end))

-- ============================================================
-- 4) Module / getgc scan for Characters.all and combat tables
-- ============================================================
local function probeModuleTable(tbl, label)
    if type(tbl) ~= "table" then return false end
    local found = false
    if type(tbl.all) == "table" then
        found = true
        local n = 0
        for id, ent in pairs(tbl.all) do
            n = n + 1
            if n <= 8 and type(ent) == "table" then
                log("GC", label .. ".all[" .. tostring(id) .. "] name=" .. tostring(ent.name)
                    .. " type=" .. tostring(ent.type) .. " owner=" .. tostring(ent.owner)
                    .. " hp=" .. tostring(ent.health) .. "/" .. tostring(ent.max_health)
                    .. " dmg=" .. tostring(ent.damage))
            end
        end
        log("GC", label .. ".all has " .. n .. " entries")
    end
    for k, v in pairs(tbl) do
        if type(k) == "string" and (k:lower():find("damage") or k:lower():find("combat") or k:lower():find("dps")) then
            log("GC", label .. "." .. k .. " = " .. ser(v, 1))
            found = true
        end
    end
    return found
end

local function scanRequiredModules()
    local ps = LP:FindFirstChild("PlayerScripts")
    if not ps then return end
    local targets = {
        "Client.Utility",
        "Client.Play",
        "Client.Characters",
        "Client.Gui",
    }
    for _, path in ipairs(targets) do
        local ok, mod = pcall(function()
            local cur = ps
            for part in string.gmatch(path, "[^%.]+") do
                cur = cur:WaitForChild(part, 2)
            end
            return require(cur)
        end)
        if ok and type(mod) == "table" then
            log("MODULE", "Required " .. path)
            if mod.data then
                log("MODULE", path .. ".data keys sample: " .. ser(mod.data, 0):sub(1, 400))
            end
            probeModuleTable(mod, path)
        end
    end
    pcall(function()
        local Helper = require(RS:WaitForChild("Shared"):WaitForChild("Helper"))
        if type(Helper.calculate_stat) == "function" then
            log("MODULE", "Shared.Helper.calculate_stat available (theoretical DPS only)")
        end
    end)
end

local function scanGetGC()
    if not getgc then
        log("GC", "getgc() not available on this executor — skip memory scan")
        return
    end
    local ok, objs = pcall(getgc, true)
    if not ok or type(objs) ~= "table" then
        log("GC", "getgc failed")
        return
    end
    local found = 0
    for _, obj in ipairs(objs) do
        if type(obj) == "table" then
            if rawget(obj, "all") and type(rawget(obj, "all")) == "table" then
                local sample = rawget(obj, "all")
                local hasCombat = false
                for _, ent in pairs(sample) do
                    if type(ent) == "table" and (ent.health or ent.damage or ent.owner) then
                        hasCombat = true
                        break
                    end
                end
                if hasCombat then
                    found = found + 1
                    probeModuleTable(obj, "getgc#"..found)
                end
            end
        end
    end
    log("GC", "getgc scan done, combat tables found: " .. found)
end

-- ============================================================
-- 5) Billboard / floating damage text in workspace
-- ============================================================
local function scanFloatingText()
    local n = 0
    for _, d in ipairs(workspace:GetDescendants()) do
        if d:IsA("TextLabel") or d:IsA("TextButton") then
            local t = d.Text or ""
            if t ~= "" and t:match("^%-?%d") and #t <= 12 then
                n = n + 1
                if n <= 15 then
                    log("FLOAT", d:GetFullName() .. " = " .. t)
                end
            end
        end
    end
    if n > 0 then log("FLOAT", "numeric text labels this sweep: " .. n) end
end

