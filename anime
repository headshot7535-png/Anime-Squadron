-- Teleport persistence (re-exec after returning to lobby)
-- ============================================================
local function getQueueFn()
    return (syn and syn.queue_on_teleport)
        or (fluxus and fluxus.queue_on_teleport)
        or queue_on_teleport
        or queueonteleport
        or (getgenv and getgenv().queue_on_teleport)
end
armReexec = function()
    if not CONFIG.autoExecute then return end
    local url = CONFIG.scriptUrl
    if type(url) ~= "string" or url == "" then return end
    local q = getQueueFn()
    if not q then return false end
    -- guard against double-queue within the same place
    local now = tick()
    if AB._lastQueue and (now - AB._lastQueue) < 3 then return true end
    AB._lastQueue = now
    pcall(q, ([[loadstring(game:HttpGet("%s"))()]]):format(url))
    return true
end
-- OnTeleport: compare by NAME string so a missing Enum member can't crash us
addConn(LP.OnTeleport:Connect(function(state)
    local name = (typeof(state) == "EnumItem") and state.Name or tostring(state)
    if name == "Started" or name == "RequestedByServer" or name == "InProgress" then
        pcall(armReexec)
    end
end))
armReexec()
-- keep the queue armed at all times so ANY upcoming teleport (manual or server)
-- re-runs us - some executors consume/clear the queue, so we keep re-arming.
addThread(function()
    while alive() do
        task.wait(5)
        if CONFIG.autoExecute then pcall(armReexec) end
    end
end)

-- ============================================================
-- Auto-exec install (covers MANUAL rejoins / manual return to lobby)
-- queue_on_teleport only fires for in-experience TeleportService teleports. If
-- the player leaves and rejoins (or the executor drops the queue), that won't
-- fire. So we also drop a tiny loader into the executor's autoexec folder that
-- runs on EVERY join - but guarded to this game's id so it never runs elsewhere.
-- ============================================================
local function installAutoexec()
    if not CONFIG.autoexecInstall then return end
    local url = CONFIG.scriptUrl
    if type(url) ~= "string" or url == "" then return end
    if type(writefile) ~= "function" then return false end
    -- guarded loader: only fetch+run when we're actually in this game
    local gid = tostring(game.GameId)
    local loader = ([[
-- Auto Bounty auto-loader (auto-generated). Delete this file to stop auto-run.
if tostring(game.GameId) == "%s" then
    task.spawn(function()
        local ok, src = pcall(function() return game:HttpGet("%s") end)
        if ok and src then pcall(function() loadstring(src)() end) end
    end)
end
]]):format(gid, url)
    -- try common autoexec folder layouts across executors
    local targets = {
        "autoexec/AutoBounty.lua",
        "autoexec/autobounty.lua",
        "auto_exec/AutoBounty.lua",
        "Autoexec/AutoBounty.lua",
    }
    local wrote = false
    for _, path in ipairs(targets) do
        local ok = pcall(function()
            if type(makefolder) == "function" then
                local dir = path:match("^(.*)/")
                if dir and type(isfolder) == "function" and not isfolder(dir) then
                    pcall(makefolder, dir)
                end
            end
            writefile(path, loader)
        end)
        if ok then wrote = true end
    end
    AB._autoexecPaths = targets
    return wrote
end
local function uninstallAutoexec()
    if type(delfile) ~= "function" then return false end
    local any = false
    for _, path in ipairs(AB._autoexecPaths or {
        "autoexec/AutoBounty.lua", "autoexec/autobounty.lua",
        "auto_exec/AutoBounty.lua", "Autoexec/AutoBounty.lua" }) do
        if pcall(function() if type(isfile) == "function" and isfile(path) then delfile(path) end end) then
            any = true
        end
    end
    return any
end
pcall(installAutoexec)

