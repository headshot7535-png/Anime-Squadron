local g = getgenv and getgenv() or {}
local CONFIG = {
    traitReward      = "Trait Shards",                 -- reward keyword that marks a "trait reroll" bounty
    act              = tonumber(g.AutoBountyAct) or 1,  -- Story act to farm
    difficulty       = g.AutoBountyDifficulty or "Normal", -- "Normal" | "Hard"
    soloOnly         = (g.AutoBountySolo ~= false),     -- create a friends-only (solo) room
    declineNonTrait  = (g.AutoBountyDeclineNonTrait ~= false),
    useRefreshTicket = (g.AutoBountyUseTicket == true), -- spend bounty tickets to roll new bounties when none left
    stopWhenDone     = (g.AutoBountyStopWhenDone ~= false),
    loopDelay        = 1.0,
    actionCooldown   = 0.45,                            -- min gap between remote calls (rate-limit safety)
    farmTimeout      = 600,                             -- max seconds to wait for a same-place run to progress
    -- auto-execute: re-run this script automatically after each teleport (lobby <-> battle)
    autoExecute      = (g.AutoBountyAutoExecute ~= false),
    scriptUrl        = g.AutoBountyScriptURL or SCRIPT_URL, -- for queue_on_teleport persistence
    -- anti-afk: prevent the 20-minute idle kick
    antiAfk          = (g.AutoBountyAntiAFK ~= false),
    antiAfkInterval  = 8,                               -- seconds between keep-alive nudges
}
CONFIG.enabled = AB.enabled == true                    -- resume running after a teleport

-- ============================================================
-- Cleanup system
-- ============================================================
local _conns, _threads = {}, {}
local function addConn(c) table.insert(_conns, c); return c end
local function addThread(fn)
    local t = task.spawn(fn)
    table.insert(_threads, t)
    return t
end
local function cleanupAll()
    for _, c in ipairs(_conns) do pcall(function() c:Disconnect() end) end
    for _, t in ipairs(_threads) do pcall(function() task.cancel(t) end) end
    _conns, _threads = {}, {}
end
-- kill the previous instance's connections/threads/GUI
if AB.cleanup then pcall(AB.cleanup) end

-- ============================================================
-- Wait for PlayerGui
-- ============================================================
do
    local ok = false
    for _ = 1, 60 do
        if LP and LP:FindFirstChildOfClass("PlayerGui") then ok = true break end
        task.wait(0.3)
    end
    if not ok then return end
end

-- ============================================================
-- Remote caching + safe calling
-- ============================================================
local _remotes = {}
local function getRemote(folder, name)
    local key = folder .. "/" .. name
    local cached = _remotes[key]
    if cached and cached.Parent then return cached end
    local f = ReplicatedStorage:FindFirstChild("Remotes")
    f = f and f:FindFirstChild(folder)
    local r = f and f:FindFirstChild(name)
    if r then _remotes[key] = r end
    return r
end

local _lastCall = 0
local function throttle()
    local dt = tick() - _lastCall
    if dt < CONFIG.actionCooldown then task.wait(CONFIG.actionCooldown - dt) end
    _lastCall = tick()
end

-- InvokeServer wrapper that preserves multi-returns: ok, serverSuccess, a, b
local function invokeR(folder, name, ...)
    local r = getRemote(folder, name)
    if not r then return false, "remote_missing" end
    throttle()
    local res = table.pack(pcall(function(...) return r:InvokeServer(...) end, ...))
    if not res[1] then return false, res[2] end
    return true, res[2], res[3], res[4]
end
local function fireR(folder, name, ...)
    local r = getRemote(folder, name)
    if not r then return false end
    throttle()
    return pcall(function(...) r:FireServer(...) end, ...)
end

-- ============================================================
-- GUI helpers / place detection
-- ============================================================
local function getMenus()
    local pg = LP:FindFirstChildOfClass("PlayerGui")
    return pg and pg:FindFirstChild("Menus")
end
local function getBountyGui()
    local m = getMenus()
    return m and m:FindFirstChild("Bounty")
end
-- We're "in the lobby" if the Bounty menu exists (battle place won't have it)
local function inLobby()
    return getBountyGui() ~= nil
end

-- the game's own bounty client module (calls remotes AND refreshes the GUI)
local _bModule
local function ensureModule()
    if _bModule then return _bModule end
    local ok, m = pcall(function()
        return require(LP.PlayerScripts.Client.Bounties)
    end)
    if ok and type(m) == "table" then _bModule = m end
    return _bModule
end
-- best-effort refresh of the game's own bounty GUI after a direct remote call
local function refreshGUI(bounties, tickets)
    if not bounties then return end
    local m = ensureModule()
    if m and m.setup then pcall(m.setup, bounties, tickets) end
end

-- ============================================================
-- Bounty reading (parse the live GUI)
-- ============================================================
local function parseProgress(text)
    if type(text) ~= "string" then return 0, 0 end
    local p, r = text:match(">%s*(%d+)%s*</font>%s*/%s*(%d+)")
    if not p then
        local clean = text:gsub("<[^>]->", "")
        p, r = clean:match("(%d+)%s*/%s*(%d+)")
    end
    return tonumber(p) or 0, tonumber(r) or 0
end

-- returns a list: { {id, world, progress, required, active, complete, trait}, ... }
local function readBounties()
    local out = {}
    local gui = getBountyGui()
    if not gui then return out end
    local sf = gui:FindFirstChild("ScrollingFrame")
    if not sf then return out end
    for _, f in ipairs(sf:GetChildren()) do
        local id = tonumber(f.Name)
        if id and f:IsA("GuiObject") then
            local entry = { id = id, progress = 0, required = 0, active = false, trait = false }

            local worldL = f:FindFirstChild("World")
            entry.world = worldL and worldL.Text or nil

            local progL = f:FindFirstChild("Progress")
            if progL then entry.progress, entry.required = parseProgress(progL.Text) end

            local isAct = f:FindFirstChild("Is_Active")
            if isAct and isAct.Visible then entry.active = true end
            local accept = f:FindFirstChild("Accept")
            local acceptLbl = accept and accept:FindFirstChild("TextLabel")
            if acceptLbl then
                local t = acceptLbl.Text
                if t == "Pending" or t == "Claim" then entry.active = true end
            end

            local rew = f:FindFirstChild("Rewards")
            if rew then
                for _, r in ipairs(rew:GetChildren()) do
                    if r:IsA("GuiObject") and r.Name == CONFIG.traitReward then
                        entry.trait = true
                    end
                end
            end

            entry.complete = (entry.required > 0) and (entry.progress >= entry.required)
            out[#out + 1] = entry
        end
    end
    return out
end

local function getTickets()
    local gui = getBountyGui()
    local tl = gui and gui:FindFirstChild("Tickets Left")
    local amt = tl and tl:FindFirstChild("Amount")
    if amt then
        local n = tostring(amt.Text):gsub("%D", "")
        return tonumber(n) or 0
    end
    return 0
end

-- ============================================================
-- Bounty actions (direct remotes + GUI refresh)
-- ============================================================
-- Prefer the game's module fn (it InvokeServers + rebuilds the GUI in one go),
-- fall back to a direct remote call + manual GUI refresh.
local function doAction(method, remoteName, id)
    local m = ensureModule()
    if m and m[method] then
        throttle()
        local ok = pcall(m[method], id)
        if ok then return true end
    end
    local ok, suc, bounties, tickets = invokeR("Bounties", remoteName, id)
    if ok and suc then refreshGUI(bounties, tickets); return true end
    return false, suc
end
local function bAccept(id)    return doAction("accept",      "accept",      id) end
local function bDecline(id)   return doAction("decline",     "decline",     id) end
local function bClaim(id)     return doAction("claim",       "claim",       id) end
local function bUseTicket()   return doAction("use_ticket",  "use_ticket",  nil) end

-- ============================================================
-- Matchmaking (start the bounty's world)
-- ============================================================
local function startMap(world)
    local current = {
        world        = world,
        act          = CONFIG.act,
        mode         = "Story",
        difficulty   = CONFIG.difficulty,
        only_friends = CONFIG.soloOnly and true or false,
    }
    local okC, sucC, room = invokeR("Play", "create_room", current)
    if not (okC and sucC) then
        return false, tostring(room or "create_room failed")
    end
    task.wait(0.3)
    local okS, sucS = invokeR("Play", "start")
    if okS and sucS then return true end
    -- couldn't start; clean up the room so we don't get stuck
    pcall(function() fireR("Play", "leave") end)
    return false, "start failed"
end

