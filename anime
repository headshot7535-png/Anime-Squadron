-- ============================================================
-- Core loop logic
-- ============================================================
-- after launching a stage, block here until we leave the lobby (teleport) or,
-- if it's a same-place arena, until the bounty progress changes.
local function waitForRun(bountyId, startProg)
    local t0 = tick()
    while alive() and CONFIG.enabled and inLobby() and (tick() - t0) < 12 do
        task.wait(0.5)
    end
    if not inLobby() then
        setStatus("In battle - auto-fighting, waiting to return...")
        while alive() and not inLobby() do task.wait(1) end
        task.wait(2) -- let lobby GUI repopulate
        setStatus("Returned to lobby.")
        return
    end
    -- same-place fallback: wait for progress to move
    setStatus("Farming - waiting for bounty progress...")
    local t1 = tick()
    while alive() and CONFIG.enabled and inLobby() and (tick() - t1) < CONFIG.farmTimeout do
        for _, b in ipairs(readBounties()) do
            if b.id == bountyId and (b.progress ~= startProg or b.complete) then return end
        end
        task.wait(2)
    end
end

-- one decision step; returns "done" when there is nothing left to do
local function step()
    if not inLobby() then
        setStatus("Not in lobby (battle/loading) - waiting...")
        return
    end

    local list = readBounties()
    if #list == 0 then
        -- board not populated yet (just joined / still loading) - wait, don't stop
        setStatus("Waiting for bounty board to load...")
        return
    end

    -- 1) handle the active bounty first (one active at a time)
    local active
    for _, b in ipairs(list) do if b.active then active = b break end end
    if active then
        if active.complete then
            setStatus(("Claiming completed bounty (%s)"):format(active.world or "?"))
            if bClaim(active.id) then
                notify("Bounty", "Claimed reward from " .. (active.world or "bounty"), "success")
                forgetBounty()
            end
            return
        end
        if active.trait then
            -- remember this target on disk so it survives the Story-mode teleport.
            -- We can't read the enemy in Story mode, so we MATCH the enemy to the
            -- right act by trial: if the last run added 0 progress, that act has no
            -- such enemy -> cycle to the next act. When progress moves, lock the act.
            local prev = Session.bounty
            local madeProgress = true
            if prev and prev.id == active.id and prev.lastLaunchProgress ~= nil then
                madeProgress = active.progress > prev.lastLaunchProgress
            end
            rememberBounty(active) -- preserves act / actsTried / foundAct for the same id
            local s = Session.bounty

            if madeProgress then
                s.foundAct = true   -- this act spawns the enemy; lock it in
                s.actsTried = 0
                s.failRuns = 0
            elseif prev and prev.lastLaunchProgress ~= nil then
                if s.foundAct then
                    -- right act, but the run didn't clear (lost / unlucky) - retry,
                    -- but don't loop forever if the loadout simply can't do it
                    s.failRuns = (s.failRuns or 0) + 1
                    if s.failRuns >= CONFIG.maxActs then
                        setStatus(("Runs on %s Act %d aren't clearing - stopping (loadout?)")
                            :format(active.world or "?", s.act or CONFIG.act))
                        notify("Auto Bounty", "Can't clear the stage for " ..
                            (active.enemy or "the target") .. ". Stopped.", "error")
                        setEnabled(false)
                        return "done"
                    end
                else
                    -- enemy not in this act yet -> cycle to the next act
                    s.actsTried = (s.actsTried or 0) + 1
                    if s.actsTried >= CONFIG.maxActs then
                        setStatus(("Tried every act in %s, %s never appeared - stopping")
                            :format(active.world or "?", active.enemy or "target"))
                        notify("Auto Bounty", "Couldn't find " ..
                            (active.enemy or "the target") .. " in any act of " ..
                            (active.world or "that world") .. ".", "error")
                        setEnabled(false)
                        return "done"
                    end
                    s.act = ((s.act or CONFIG.act) % CONFIG.maxActs) + 1
                    setStatus(("%s not found - trying %s Act %d")
                        :format(active.enemy or "target", active.world or "?", s.act))
                end
            end

            local act = s.act or CONFIG.act
            setStatus(("Farming %s Act %d: eliminate %s  %d/%d  (run #%d)")
                :format(active.world or "?", act, active.enemy or "target",
                    active.progress, active.required, (s.runs or 0) + 1))
            s.runs = (s.runs or 0) + 1
            s.lastLaunchProgress = active.progress
            saveSession()

            local ok, err = startMap(active.world, act)
            if ok then
                waitForRun(active.id, active.progress)
            else
                setStatus("Launch failed: " .. tostring(err))
                task.wait(2)
            end
            return
        end
        -- active bounty does NOT reward trait shards
        if CONFIG.declineNonTrait then
            setStatus("Active bounty has no trait reward - declining it")
            bDecline(active.id)
        else
            setStatus("Active bounty has no trait reward (decline disabled) - idle")
            task.wait(2)
        end
        return
    end

    -- no active bounty -> drop any stale memory of one
    if Session.bounty then forgetBounty() end

    -- 2) no active bounty -> clear out a non-trait bounty (one per step)
    if CONFIG.declineNonTrait then
        for _, b in ipairs(list) do
            if (not b.trait) and (not b.active) then
                setStatus(("Declining non-trait bounty (%s)"):format(b.world or "?"))
                bDecline(b.id)
                return
            end
        end
    end

    -- 3) accept a trait-reroll bounty
    for _, b in ipairs(list) do
        if b.trait and (not b.active) then
            setStatus(("Accepting trait bounty (%s)"):format(b.world or "?"))
            if bAccept(b.id) then
                notify("Bounty", "Accepted: " .. (b.world or "bounty"), "info")
            end
            return
        end
    end

    -- 4) nothing acceptable left
    local anyTrait = false
    for _, b in ipairs(list) do if b.trait then anyTrait = true break end end
    if not anyTrait then
        if CONFIG.useRefreshTicket and getTickets() > 0 then
            setStatus("No trait bounties - using a ticket to roll a new one")
            bUseTicket()
            return
        end
        return "done"
    end
end

local _looping = false
function mainLoop()
    if _looping then return end
    _looping = true
    setStatus("Auto Bounty started.")
    while alive() and CONFIG.enabled do
        local ok, res = pcall(step)
        if not ok then
            setStatus("Error: " .. tostring(res))
        elseif res == "done" then
            if CONFIG.stopWhenDone then
                setStatus("No trait-reroll bounties left - stopped.")
                notify("Auto Bounty", "No trait bounties left. Done.", "success")
                setEnabled(false)
                break
            end
        end
        task.wait(CONFIG.loopDelay)
    end
    _looping = false
    setStatus("Stopped.")
end

function setEnabled(on)
    CONFIG.enabled = on and true or false
    AB.enabled = CONFIG.enabled
    Session.running = CONFIG.enabled
    if saveSession then saveSession() end
    if CONFIG.enabled then addThread(mainLoop) end
end

-- remember/forget the bounty we are currently farming (persists across teleport)
function rememberBounty(b)
    if not b then return end
    local s = Session.bounty
    if not s or s.id ~= b.id then
        -- new target: start at the configured act, will auto-cycle if no enemy
        s = { id = b.id, runs = 0, act = CONFIG.act, actsTried = 0,
              foundAct = false, failRuns = 0, lastLaunchProgress = nil }
    end
    s.world    = b.world
    s.enemy    = b.enemy
    s.required = b.required
    s.progress = b.progress
    Session.bounty = s
    if saveSession then saveSession() end
end
function forgetBounty()
    Session.bounty = nil
    if saveSession then saveSession() end
end

-- ============================================================
-- Settings persistence (JSON, debounced)
-- ============================================================
local SETTINGS_FILE = "AutoBounty_settings.json"
local function canFile()
    return (writefile and readfile and isfile) and true or false
end
local _saveQueued = false
local function saveSettings()
    if not canFile() then return end
    if _saveQueued then return end
    _saveQueued = true
    addThread(function()
        task.wait(0.6)
        _saveQueued = false
        local data = {
            act              = CONFIG.act,
            difficulty       = CONFIG.difficulty,
            soloOnly         = CONFIG.soloOnly,
            declineNonTrait  = CONFIG.declineNonTrait,
            useRefreshTicket = CONFIG.useRefreshTicket,
            stopWhenDone     = CONFIG.stopWhenDone,
            scriptUrl        = CONFIG.scriptUrl,
            autoExecute      = CONFIG.autoExecute,
            antiAfk          = CONFIG.antiAfk,
            liveKills        = CONFIG.liveKills,
            leaveWhenDone    = CONFIG.leaveWhenDone,
        }
        pcall(function() writefile(SETTINGS_FILE, HttpService:JSONEncode(data)) end)
    end)
end
local function loadSettings()
    if not canFile() then return end
    if not isfile(SETTINGS_FILE) then return end
    local ok, raw = pcall(readfile, SETTINGS_FILE)
    if not ok or not raw then return end
    local ok2, data = pcall(function() return HttpService:JSONDecode(raw) end)
    if not ok2 or type(data) ~= "table" then return end
    CONFIG.act              = math.clamp(tonumber(data.act) or CONFIG.act, 1, 7)
    if data.difficulty == "Normal" or data.difficulty == "Hard" then CONFIG.difficulty = data.difficulty end
    CONFIG.soloOnly         = data.soloOnly == true
    CONFIG.declineNonTrait  = data.declineNonTrait == true
    CONFIG.useRefreshTicket = data.useRefreshTicket == true
    CONFIG.stopWhenDone     = data.stopWhenDone == true
    -- default these to true when missing from an older settings file
    if data.autoExecute ~= nil then CONFIG.autoExecute = data.autoExecute == true end
    if data.antiAfk ~= nil then CONFIG.antiAfk = data.antiAfk == true end
    if data.liveKills ~= nil then CONFIG.liveKills = data.liveKills == true end
    if data.leaveWhenDone ~= nil then CONFIG.leaveWhenDone = data.leaveWhenDone == true end
    if type(data.scriptUrl) == "string" and data.scriptUrl ~= "" then CONFIG.scriptUrl = data.scriptUrl end
end
loadSettings()

