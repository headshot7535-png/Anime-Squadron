-- Daily trait farm helpers
-- ============================================================
local function findTraitMapEntry(world, mode, act)
    for _, m in ipairs(TRAIT_DAILY_MAPS) do
        if m.world == world and m.mode == mode and tonumber(m.act) == tonumber(act) then
            return m
        end
    end
    return nil
end

local function getCurrentPlayMap()
    local ok, play = pcall(function() return require(LP.PlayerScripts.Client.Play) end)
    if ok and play and type(play.current) == "table" then
        local c = play.current
        if c.world and c.mode and c.act then
            return findTraitMapEntry(c.world, c.mode, c.act) or {
                world = c.world, mode = c.mode, act = c.act, cap = 100,
            }
        end
    end
    return nil
end

local function resolveDailyMap()
    local df = Session.dailyFarm
    if df and df.world and df.mode and df.act then
        return findTraitMapEntry(df.world, df.mode, df.act) or {
            world = df.world, mode = df.mode, act = df.act, cap = df.cap or 100,
        }
    end
    return getCurrentPlayMap()
end

local _lastCapLeaveNotify = 0
local function leaveStageIfCapped(map, reason, fromIdx)
    refreshPlayerData()
    if not map then return false end
    if not isTraitCapMaxed(map) and not shouldSkipMapAfterCapLeave(map) then return false end
    setStatus(reason or ("Daily cap full on " .. map.world .. " - leaving stage..."))
    if tick() - _lastCapLeaveNotify > 10 then
        _lastCapLeaveNotify = tick()
        notify("Daily Traits", map.world .. " cap reached (" .. getTraitCapCount(map) .. "/" .. map.cap .. ") — next map.", "success")
    end
    leaveStage(true)
    AS._dailyLeftCap = true
    advanceDailyMapIdx(fromIdx or (Session.dailyFarm and Session.dailyFarm.idx), map)
    return true
end

local function waitForLobbyReturn(timeout)
    local t0 = tick()
    while alive() and (not inLobby() or inBattle()) and (tick() - t0) < (timeout or 60) do
        leaveStage()
        task.wait(2)
    end
    if inLobby() then
        task.wait(2)
        setStatus("Returned to lobby.")
        return true
    end
    return false
end

-- block until stage ends; leave early the moment this map's daily cap is full
local function waitForDailyRun(map)
    local t0 = tick()
    while alive() and CONFIG.enabled and inLobby() and (tick() - t0) < 12 do
        task.wait(0.5)
    end
    if not alive() or not CONFIG.enabled then return false end

    if inLobby() then
        setStatus("Daily traits - waiting for stage to start...")
        local t1 = tick()
        while alive() and CONFIG.enabled and inLobby() and (tick() - t1) < CONFIG.farmTimeout do
            task.wait(2)
        end
        if inLobby() then return false end
    end

    setStatus(("Daily traits - fighting %s %s Act %d, watching cap..."):format(map.mode, map.world, map.act))
    local t2 = tick()
    while alive() and CONFIG.enabled and (not inLobby() or inBattle()) and (tick() - t2) < CONFIG.farmTimeout do
        if leaveStageIfCapped(map, nil, Session.dailyFarm and Session.dailyFarm.idx) then
            waitForLobbyReturn(60)
            return true
        end
        task.wait(1)
    end

    if inLobby() and not inBattle() then return true end
    waitForLobbyReturn(30)
    return true
end

-- ============================================================
-- Rotating challenges (Daily [1d] + Regular [30m], once per reset)
-- ============================================================
local CHALLENGE_ORDER = { "1d", "30m" }
local CHALLENGE_NAMES = { ["1d"] = "Daily Challenge", ["30m"] = "Regular Challenge" }

local function getChallengeTimers()
    local ok, util = pcall(function() return require(LP.PlayerScripts.Client.Utility) end)
    if ok and util and type(util.timers) == "table" then
        return tonumber(util.timers.day) or 0, tonumber(util.timers.half_hour) or 0
    end
    return 0, 0
end

local function fmtChallengeTimer(sec)
    sec = math.max(0, math.floor(tonumber(sec) or 0))
    local h = math.floor(sec / 3600)
    local m = math.floor((sec % 3600) / 60)
    local s = sec % 60
    if h > 0 then return string.format("%d:%02d:%02d", h, m, s) end
    return string.format("%02d:%02d", m, s)
end

local function getRotatingChallenges()
    local ok, data = invokeR("Play", "get_challenges")
    if ok and type(data) == "table" then
        AS.challengeCache = data
        return data
    end
    return AS.challengeCache or {}
end

local function syncChallengeDoneFlags(chs)
    if type(CONFIG.challengeDone) ~= "table" then CONFIG.challengeDone = {} end
    AS.challengeDoneSession = AS.challengeDoneSession or {}
    AS._challengeAvail = AS._challengeAvail or {}
    for _, key in ipairs(CHALLENGE_ORDER) do
        local nowAvail = chs[key] ~= nil
        -- Only clear "done" when a challenge reappears after being unavailable (new reset)
        if nowAvail and AS._challengeAvail[key] == false then
            CONFIG.challengeDone[key] = nil
            AS.challengeDoneSession[key] = nil
        end
        AS._challengeAvail[key] = nowAvail
    end
end

local function isChallengeEnabled(key)
    if key == "1d" then return CONFIG.autoDailyChallenge end
    if key == "30m" then return CONFIG.autoRegularChallenge end
    return false
end

local CHALLENGE_DONE_PATTERNS = {
    "already completed",
    "already cleared",
    "already done",
    "completed!",
}

local function textIndicatesChallengeDone(txt)
    if type(txt) ~= "string" or txt == "" then return false end
    local lower = txt:lower()
    for _, pat in ipairs(CHALLENGE_DONE_PATTERNS) do
        if lower:find(pat, 1, true) then return true end
    end
    return lower:find("completed", 1, true) ~= nil and lower:find("already", 1, true) ~= nil
end

local function challengeCapKey(world, act, itemName)
    local s = ("Challenge %s %s %s"):format(tostring(world), tostring(act), tostring(itemName))
    return string.lower(s):gsub(" ", "_")
end

local function getChallengeCapCount(world, act, itemName)
    local data = getPlayerData()
    if not data or type(data.caps) ~= "table" then return 0 end
    local key = challengeCapKey(world, act, itemName)
    local count = tonumber(data.caps[key]) or 0
    if count == 0 then
        local want = key:gsub("_", "")
        for k, v in pairs(data.caps) do
            if type(k) == "string" and k:gsub("_", "") == want then
                count = tonumber(v) or 0
                break
            end
        end
    end
    return count
end

local function areChallengeRewardsCapped(ch)
    if type(ch) ~= "table" or type(ch.rewards) ~= "table" then return false end
    local hasCap = false
    for itemName, itemData in pairs(ch.rewards) do
        if type(itemData) == "table" and itemData.cap then
            hasCap = true
            local cap = tonumber(itemData.cap) or 0
            if getChallengeCapCount(ch.world, ch.act, itemName) < cap then
                return false
            end
        end
    end
    return hasCap
end

local function scanChallengeGuiCompleted(key)
    local menus = getMenus()
    if not menus then return false end
    local roots = {
        menus:FindFirstChild("Play"),
        menus:FindFirstChild("StageInfo"),
    }
    for _, root in ipairs(roots) do
        if root and (root:IsA("GuiObject") and root.Visible) then
            for _, d in ipairs(root:GetDescendants()) do
                if d:IsA("TextLabel") or d:IsA("TextButton") then
                    local t = d.Text
                    if textIndicatesChallengeDone(t) then return true end
                end
            end
        end
    end
    -- Daily/regular challenge world buttons live under Play.Worlds
    local play = menus:FindFirstChild("Play")
    local worlds = play and play:FindFirstChild("Worlds")
    local btn = worlds and worlds:FindFirstChild(key)
    if btn then
        for _, d in ipairs(btn:GetDescendants()) do
            if d:IsA("TextLabel") then
                if textIndicatesChallengeDone(d.Text) then return true end
            end
        end
    end
    return false
end

local function leaveChallengeRoomQuiet()
    pcall(function() fireR("Play", "leave") end)
    pcall(function() invokeR("Matchmaking", "leave") end)
    pcall(function() invokeR("Player", "physical_teleport", "play") end)
end

local function probeChallengeBlocked(key, ch)
    if type(ch) ~= "table" or not ch.world or not ch.act then return false end
    AS.challengeProbeCache = AS.challengeProbeCache or {}
    local cacheKey = ("%s|%s|%s"):format(key, ch.world, ch.act)
    if AS.challengeProbeCache[cacheKey] ~= nil then
        return AS.challengeProbeCache[cacheKey]
    end

    local current = {
        world        = ch.world,
        act          = ch.act,
        mode         = "Challenge",
        difficulty   = key,
        only_friends = CONFIG.soloOnly and true or false,
    }
    if type(ch.rewards) == "table" then
        current.rewards = ch.rewards
    end

    local okC, sucC, res = invokeR("Play", "create_room", current)
    if okC and sucC then
        leaveChallengeRoomQuiet()
        task.wait(0.4)
        AS.challengeProbeCache[cacheKey] = false
        return false
    end

    local blocked = textIndicatesChallengeDone(tostring(res or sucC or ""))
    AS.challengeProbeCache[cacheKey] = blocked
    return blocked
end

local function isChallengeAlreadyCompleted(key, ch)
    if AS.challengeDoneSession and AS.challengeDoneSession[key] then return true, "session" end
    refreshPlayerData()
    if areChallengeRewardsCapped(ch) then return true, "caps" end
    if scanChallengeGuiCompleted(key) then return true, "gui" end
    if probeChallengeBlocked(key, ch) then return true, "probe" end
    return false
end

local function shouldRunChallenge(key, ch)
    if not isChallengeEnabled(key) then return false end
    if type(ch) ~= "table" or not ch.world or not ch.act then return false end
    if AS.challengeDoneSession and AS.challengeDoneSession[key] then return false end
    return true
end

local function countPendingChallenges()
    if not CONFIG.autoDailyChallenge and not CONFIG.autoRegularChallenge then return 0 end
    local chs = getRotatingChallenges()
    syncChallengeDoneFlags(chs)
    local n = 0
    for _, key in ipairs(CHALLENGE_ORDER) do
        local ch = chs[key]
        if isChallengeEnabled(key) and type(ch) == "table" and ch.world then
            if not isChallengeAlreadyCompleted(key, ch) then
                n = n + 1
            end
        end
    end
    return n
end

local function challengesTakePriority()
    if Session.challengeFarm then return true end
    return countPendingChallenges() > 0
end

local function rememberChallenge(key, ch)
    Session.challengeFarm = {
        key   = key,
        world = ch.world,
        act   = ch.act,
    }
    saveSession()
end

local function forgetChallenge()
    Session.challengeFarm = nil
    saveSession()
end

local function markChallengeDone(key)
    AS.challengeDoneSession = AS.challengeDoneSession or {}
    AS.challengeDoneSession[key] = true
    if type(CONFIG.challengeDone) ~= "table" then CONFIG.challengeDone = {} end
    CONFIG.challengeDone[key] = os.time()
    if AS.challengeProbeCache then
        for ck in pairs(AS.challengeProbeCache) do
            if ck:sub(1, #key + 1) == (key .. "|") then
                AS.challengeProbeCache[ck] = true
            end
        end
    end
    saveSettings()
    saveSession()
end

local function waitForChallengeRun(key, ch)
    local label = CHALLENGE_NAMES[key] or key
    local t0 = tick()
    while alive() and CONFIG.enabled and inLobby() and (tick() - t0) < 12 do
        task.wait(0.5)
    end
    if not alive() or not CONFIG.enabled then return false end

    if inLobby() then
        setStatus(label .. " - waiting for stage to start...")
        local t1 = tick()
        while alive() and CONFIG.enabled and inLobby() and (tick() - t1) < CONFIG.farmTimeout do
            task.wait(2)
        end
        if inLobby() then return false end
    end

    setStatus(("%s - fighting %s Act %d..."):format(label, ch.world, ch.act))
    local t2 = tick()
    local idleSince = nil
    while alive() and CONFIG.enabled and (tick() - t2) < CONFIG.farmTimeout do
        if inLobby() and not inBattle() then break end
        if not inBattle() then
            idleSince = idleSince or tick()
            if tick() - idleSince >= 3 then
                setStatus(label .. " - challenge done, leaving stage...")
                leaveStage(true)
                waitForLobbyReturn(45)
                return true
            end
        else
            idleSince = nil
        end
        task.wait(1)
    end

    if inLobby() and not inBattle() then return true end
    leaveStage(true)
    waitForLobbyReturn(45)
    return true
end

local function challengeStep()
    if not CONFIG.autoDailyChallenge and not CONFIG.autoRegularChallenge then return end

    if not inLobby() then
        local cf = Session.challengeFarm
        if cf then
            if not inBattle() then
                AS._challengeIdleAt = AS._challengeIdleAt or tick()
                if tick() - AS._challengeIdleAt >= 3 then
                    setStatus("Challenge complete — leaving stage...")
                    leaveStage(true)
                    waitForLobbyReturn(45)
                    AS._challengeIdleAt = nil
                    return
                end
            else
                AS._challengeIdleAt = nil
            end
            setStatus(("%s - in %s Act %d, fighting..."):format(
                CHALLENGE_NAMES[cf.key] or cf.key or "Challenge",
                cf.world or "?", cf.act or "?"))
        else
            if not inBattle() then
                AS._challengeIdleAt = AS._challengeIdleAt or tick()
                if tick() - AS._challengeIdleAt >= 4 then
                    setStatus("Challenge - leaving finished stage...")
                    leaveStage(true)
                    waitForLobbyReturn(45)
                    AS._challengeIdleAt = nil
                end
            end
            setStatus("Challenge - in stage, waiting to return...")
        end
        return
    end
    AS._challengeIdleAt = nil

    local chs = getRotatingChallenges()
    syncChallengeDoneFlags(chs)

    for _, key in ipairs(CHALLENGE_ORDER) do
        local ch = chs[key]
        if not isChallengeEnabled(key) or type(ch) ~= "table" or not ch.world then
            continue
        end

        local already, reason = isChallengeAlreadyCompleted(key, ch)
        if already then
            if not (AS.challengeDoneSession and AS.challengeDoneSession[key]) then
                markChallengeDone(key)
                notify("Challenges", (CHALLENGE_NAMES[key] or key) .. " already completed — skipping.", "info")
            end
        else
            local label = CHALLENGE_NAMES[key] or key
            rememberChallenge(key, ch)
            setStatus(("%s: %s Act %d — starting..."):format(label, ch.world, ch.act))

            local ok, err = startMap(ch.world, ch.act, "Challenge", key, ch.rewards)
            if not ok then
                forgetChallenge()
                if textIndicatesChallengeDone(tostring(err)) then
                    markChallengeDone(key)
                    notify("Challenges", label .. " already completed.", "info")
                else
                    setStatus("Challenge launch failed: " .. tostring(err))
                    task.wait(2)
                    return
                end
            else
                waitForChallengeRun(key, ch)
                forgetChallenge()
                markChallengeDone(key)
                notify("Challenges", label .. " cleared — " .. ch.world, "success")
                return
            end
        end
    end
end

-- ============================================================
-- Auto awakening (farm materials + special quests, then awaken)
-- Priority: challenges > awakening > daily traits
-- ============================================================
local ITEM_LOC_CACHE = {}
local SPECIAL_QUEST_ITEM = {
    ["Beast Core"] = "Furious Beast",
    ["Fusion Core"] = "Strongest Fusion",
    ["Primal Core"] = "Primal Fusion",
}

local function stripHtml(s)
    if type(s) ~= "string" then return "" end
    s = s:gsub("<[^>]+>", ""):gsub("&nbsp;", " "):gsub("%s+", " ")
    return (s:match("^%s*(.-)%s*$") or s)
end

local function getItemCount(itemName)
    local data = getPlayerData()
    if not data then return 0 end
    if data.stats and data.stats[itemName] ~= nil then
        return tonumber(data.stats[itemName]) or 0
    end
    if data.items and data.items[itemName] ~= nil then
        return tonumber(data.items[itemName]) or 0
    end
    return 0
end

local function getCharacterData(unitName)
    local folder = ReplicatedStorage.Characters:FindFirstChild(unitName)
    if not folder then return nil end
    local dataMod = folder:FindFirstChild("data")
    if not dataMod then return nil end
    local ok, data = pcall(function() return require(dataMod) end)
    if ok and type(data) == "table" then return data end
    return nil
end

local AWAKENABLE_NAMES = nil
local function scanAwakenableCharacterNames()
    if AWAKENABLE_NAMES then return AWAKENABLE_NAMES end
    local map = {}
    local chars = ReplicatedStorage:FindFirstChild("Characters")
    if chars then
        for _, child in ipairs(chars:GetChildren()) do
            local dataMod = child:FindFirstChild("data")
            if dataMod then
                local ok, data = pcall(function() return require(dataMod) end)
                if ok and type(data) == "table"
                    and type(data.awakening) == "table"
                    and type(data.awakening.cost) == "table" then
                    map[child.Name] = true
                end
            end
        end
    end
    AWAKENABLE_NAMES = map
    return map
end

local function isAwakenableUnitName(unitName)
    if type(unitName) ~= "string" or unitName == "" then return false, nil end
    local awakenable = scanAwakenableCharacterNames()
    if awakenable[unitName] then return true, unitName end
    local folder = ReplicatedStorage.Characters:FindFirstChild(unitName)
    if folder then
        local data = getCharacterData(unitName)
        if data and type(data.awakening) == "table" and type(data.awakening.cost) == "table" then
            return true, unitName
        end
    end
    return false, nil
end

local function getAwakeningCost(unitName)
    local data = getCharacterData(unitName)
    if data and type(data.awakening) == "table" and type(data.awakening.cost) == "table" then
        return data.awakening.cost, data.awakening.object
    end
    return nil
end

local function discoverUnitsFromCharactersGui(seen)
    local list = {}
    seen = seen or {}
    local menus = getMenus()
    local charsFrame = menus and menus:FindFirstChild("Characters")
    local scroll = charsFrame and charsFrame:FindFirstChild("ScrollingFrame")
    local awakenable = scanAwakenableCharacterNames()
    if not scroll then return list end

    for _, child in ipairs(scroll:GetChildren()) do
        if child:IsA("GuiButton") then
            local modelName = nil
            local vp = child:FindFirstChild("ViewportFrame")
            local wm = vp and vp:FindFirstChildOfClass("WorldModel")
            if wm then modelName = wm.Name end
            if not modelName and child:FindFirstChild("UnitName") then
                modelName = child.UnitName.Text
            end
            if modelName and awakenable[modelName] and not seen[modelName] then
                seen[modelName] = true
                list[#list + 1] = {
                    id = child.Name,
                    name = modelName,
                    index = tonumber(child.Name),
                    level = nil,
                }
            end
        end
    end
    return list
end

local function getOwnedAwakenableUnits()
    refreshPlayerData()
    local data = getPlayerData()
    local list = {}
    local seen = {}

    if data and type(data.characters) == "table" then
        for id, ch in pairs(data.characters) do
            if type(ch) == "table" and type(ch.name) == "string" and ch.name ~= "" then
                local ok, folderName = isAwakenableUnitName(ch.name)
                if ok and folderName and not seen[folderName] then
                    seen[folderName] = true
                    list[#list + 1] = {
                        id = ch.id or id,
                        name = folderName,
                        index = ch.index,
                        level = ch.level,
                    }
                end
            end
        end
    end

    if #list == 0 then
        for _, u in ipairs(discoverUnitsFromCharactersGui(seen)) do
            list[#list + 1] = u
        end
    end

    table.sort(list, function(a, b) return tostring(a.name) < tostring(b.name) end)
    return list
end

local function findOwnedUnitByName(unitName)
    if type(unitName) ~= "string" or unitName == "" then return nil end
    refreshPlayerData()
    local data = getPlayerData()
    if data and type(data.characters) == "table" then
        for id, ch in pairs(data.characters) do
            if type(ch) == "table" and ch.name then
                local ok, folderName = isAwakenableUnitName(ch.name)
                if ok and folderName == unitName then
                    return {
                        id = ch.id or id,
                        name = folderName,
                        index = ch.index,
                        level = ch.level,
                    }
                end
            end
        end
    end
    for _, u in ipairs(getOwnedAwakenableUnits()) do
        if u.name == unitName then return u end
    end
    return nil
end

local function getMissingAwakeningReqs(unitName)
    local cost = getAwakeningCost(unitName)
    if not cost then return {} end
    local missing = {}
    for item, need in pairs(cost) do
        need = tonumber(need) or 0
        if need > 0 then
            local have = getItemCount(item)
            if have < need then
                missing[#missing + 1] = {
                    item = item,
                    need = need,
                    have = have,
                    deficit = need - have,
                }
            end
        end
    end
    table.sort(missing, function(a, b)
        if a.deficit ~= b.deficit then return a.deficit > b.deficit end
        return a.item < b.item
    end)
    return missing
end

local function parseItemDescriptionLocation(itemName)
    if ITEM_LOC_CACHE[itemName] then return ITEM_LOC_CACHE[itemName] end
    local folder = ReplicatedStorage.Items:FindFirstChild(itemName)
    if not folder then return nil end
    local ok, data = pcall(function() return require(folder.data) end)
    if not ok or type(data) ~= "table" then return nil end
    local desc = stripHtml(tostring(data.description or ""))
    local loc = desc:match("Obtainable in%s*→%s*(.+)$")
        or desc:match("Obtainable in%s+(.+)$")
    if not loc or loc == "" then return nil end
    loc = loc:gsub("%.$", "")

    if loc:find("Special Quest", 1, true) then
        local quest = loc:match("Special Quest%s+(.+)")
        local parsed = { type = "special", quest = quest and quest:gsub("%.$", "") or loc }
        ITEM_LOC_CACHE[itemName] = parsed
        return parsed
    end
    if loc:find("Crafting", 1, true) then
        local parsed = { type = "crafting" }
        ITEM_LOC_CACHE[itemName] = parsed
        return parsed
    end

    local world, mode, act1, act2, difficulty = loc:match("^(.-) Story Act (%d+)%s*,%s*(%d+)")
    if world then
        local parsed = {
            type = "map", world = world, mode = "Story",
            acts = { tonumber(act1), tonumber(act2) }, difficulty = "Normal",
        }
        ITEM_LOC_CACHE[itemName] = parsed
        return parsed
    end

    world, act1 = loc:match("^(.-) Squadron Act (%d+)")
    if world then
        local parsed = {
            type = "map", world = world, mode = "Squadron",
            acts = { tonumber(act1) }, difficulty = "Normal",
        }
        ITEM_LOC_CACHE[itemName] = parsed
        return parsed
    end

    world, act1 = loc:match("^(.-) Act (%d+) Squadron")
    if world then
        local parsed = {
            type = "map", world = world, mode = "Squadron",
            acts = { tonumber(act1) }, difficulty = "Normal",
        }
        ITEM_LOC_CACHE[itemName] = parsed
        return parsed
    end

    world, act1, difficulty = loc:match("^(.-) Squadron Act (%d+)%s+(Hard)")
    if world then
        local parsed = {
            type = "map", world = world, mode = "Squadron",
            acts = { tonumber(act1) }, difficulty = difficulty,
        }
        ITEM_LOC_CACHE[itemName] = parsed
        return parsed
    end

    world, act1 = loc:match("^(.-) Act (%d+) Raid")
    if world then
        local parsed = {
            type = "map", world = world, mode = "Raid",
            acts = { tonumber(act1) }, difficulty = "Normal",
        }
        ITEM_LOC_CACHE[itemName] = parsed
        return parsed
    end

    world = loc:match("^(.-) Invasion")
    if world then
        local parsed = {
            type = "map", world = world, mode = "Invasion",
            acts = { 1 }, difficulty = "Normal",
        }
        ITEM_LOC_CACHE[itemName] = parsed
        return parsed
    end

    return nil
end

local function discoverItemDropMaps(itemName)
    local found, seen = {}, {}
    local ok, Worlds = pcall(function() return require(LP.PlayerScripts.Client.Play.Worlds) end)
    if ok and type(Worlds) == "table" then
        for _, idx in ipairs(WORLD_INDICES) do
            local w = Worlds[idx]
            if type(w) == "table" and w.name and type(w.Rewards) == "table" then
                for mode, modeData in pairs(w.Rewards) do
                    if type(modeData) == "table" then
                        for diff, diffData in pairs(modeData) do
                            if type(diffData) == "table" then
                                for act, actRewards in ipairs(diffData) do
                                    if type(actRewards) == "table" and actRewards[itemName] then
                                        local key = mode .. "|" .. w.name .. "|" .. act .. "|" .. diff
                                        if not seen[key] then
                                            seen[key] = true
                                            found[#found + 1] = {
                                                world = w.name,
                                                mode = mode,
                                                act = act,
                                                difficulty = (diff == "Hard") and "Hard" or "Normal",
                                            }
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    table.sort(found, function(a, b)
        if a.mode ~= b.mode then return a.mode < b.mode end
        if a.world ~= b.world then return a.world < b.world end
        return a.act < b.act
    end)
    return found
end

local function buildFarmTargetsForItem(itemName)
    local targets = {}
    local seen = {}
    local function addTarget(t)
        if type(t) ~= "table" or not t.world or not t.mode or not t.act then return end
        local key = t.mode .. "|" .. t.world .. "|" .. t.act .. "|" .. (t.difficulty or "Normal")
        if seen[key] then return end
        seen[key] = true
        targets[#targets + 1] = t
    end

    for _, m in ipairs(discoverItemDropMaps(itemName)) do addTarget(m) end

    local parsed = parseItemDescriptionLocation(itemName)
    if parsed and parsed.type == "map" then
        for _, act in ipairs(parsed.acts or {}) do
            addTarget({
                world = parsed.world,
                mode = parsed.mode,
                act = act,
                difficulty = parsed.difficulty or CONFIG.awakeningDifficulty,
            })
        end
    elseif parsed and parsed.type == "special" then
        return { special = parsed.quest or SPECIAL_QUEST_ITEM[itemName] }
    elseif parsed and parsed.type == "crafting" then
        return { crafting = true }
    elseif SPECIAL_QUEST_ITEM[itemName] then
        return { special = SPECIAL_QUEST_ITEM[itemName] }
    end

    if #targets == 0 and parsed and parsed.type == "map" and parsed.world then
        addTarget({
            world = parsed.world,
            mode = parsed.mode or "Story",
            act = (parsed.acts and parsed.acts[1]) or 1,
            difficulty = parsed.difficulty or CONFIG.awakeningDifficulty,
        })
    end

    return targets
end

local function getSpecialQuestCatalog()
    local ok, data = invokeR("Quests", "get_specials")
    if ok and type(data) == "table" then
        AS.specialQuestCache = data
        return data
    end
    return AS.specialQuestCache or {}
end

local function claimReadySpecialTasks(questName)
    refreshPlayerData()
    local data = getPlayerData()
    local catalog = getSpecialQuestCatalog()
    local questDef = catalog[questName]
    local playerQuest = data and data.specials and data.specials[questName]
    if not questDef or not playerQuest then return false end
    local claimed = false
    for idx, taskDef in pairs(questDef.quests or {}) do
        if type(taskDef) == "table" then
            local prog = playerQuest.quests and playerQuest.quests[tostring(idx)]
            if prog and not prog.claimed and tonumber(prog.progress) >= tonumber(taskDef.required) then
                local ok, suc, newData = invokeR("Quests", "claim_special", questName, tostring(idx))
                if ok and suc then
                    claimed = true
                    if type(newData) == "table" then
                        AS.playerData = newData
                        pcall(function()
                            local util = require(LP.PlayerScripts.Client.Utility)
                            if util then util.data = newData end
                        end)
                    end
                end
            end
        end
    end
    refreshPlayerData()
    return claimed
end

local function parseTaskFarmTarget(taskDesc)
    if type(taskDesc) ~= "string" then return nil end
    local desc = stripHtml(taskDesc):lower()
    local solo = desc:find("solo", 1, true) ~= nil

    local world, mode, act
    if desc:find("invasion", 1, true) then
        mode = "Invasion"
        if desc:find("bralu", 1, true) or desc:find("lava", 1, true) then
            world = "The Lava Continent"
        elseif desc:find("ice", 1, true) then
            world = "The Ice Continent"
        end
        act = 1
    elseif desc:find("infinite", 1, true) then
        mode = "Infinite"
        world = "The Lava Continent"
        act = 1
    elseif desc:find("raid", 1, true) then
        mode = "Raid"
        world = desc:match("(%w[%w%s%(%)%-]+) raid") or world
        act = tonumber(desc:match("act (%d+)")) or 1
    elseif desc:find("squadron", 1, true) or desc:find("stage", 1, true) then
        mode = "Squadron"
        world = desc:match("(%w[%w%s%(%)%-]+) invasion")
            or desc:match("(%w[%w%s%(%)%-]+) squadron")
            or world
        act = tonumber(desc:match("act (%d+)")) or 1
    end

    if not world or not mode then return nil end
    return { world = world, mode = mode, act = act, difficulty = CONFIG.awakeningDifficulty, solo = solo }
end

local function pickSpecialQuestFarmTarget(questName, itemName)
    claimReadySpecialTasks(questName)
    if getItemCount(itemName) > 0 then return nil end

    local data = getPlayerData()
    local catalog = getSpecialQuestCatalog()
    local questDef = catalog[questName]
    local playerQuest = data and data.specials and data.specials[questName]
    if not questDef or not playerQuest then return nil end

    local best
    for idx, taskDef in pairs(questDef.quests or {}) do
        if type(taskDef) == "table" then
            local prog = playerQuest.quests and playerQuest.quests[tostring(idx)]
            local progress = prog and tonumber(prog.progress) or 0
            local required = tonumber(taskDef.required) or 0
            if not (prog and prog.claimed) and progress < required then
                local target = parseTaskFarmTarget(taskDef.desc or taskDef.name or "")
                if target then
                    target.quest = questName
                    target.taskIndex = tostring(idx)
                    target.taskName = taskDef.name or ("Task " .. tostring(idx))
                    target.progress = progress
                    target.required = required
                    if not best or (required - progress) > (best.required - best.progress) then
                        best = target
                    end
                end
            end
        end
    end
    return best
end

local function pickNextAwakeningFarmTarget(unitName, focusItem)
    local missing = getMissingAwakeningReqs(unitName)
    if #missing == 0 then return nil, "ready" end

    local itemEntry = missing[1]
    if focusItem then
        for _, m in ipairs(missing) do
            if m.item == focusItem then itemEntry = m break end
        end
    end

    local itemName = itemEntry.item
    local targets = buildFarmTargetsForItem(itemName)
    if type(targets) == "table" and targets.special then
        local sq = pickSpecialQuestFarmTarget(targets.special, itemName)
        if sq then return sq, itemName end
        return {
            type = "special_wait",
            quest = targets.special,
            item = itemName,
        }, itemName
    end
    if type(targets) == "table" and targets.crafting then
        return { type = "crafting", item = itemName }, itemName
    end

    local af = Session.awakeningFarm
    local startIdx = 1
    if af and af.item == itemName and af.targetIdx then
        startIdx = af.targetIdx
    end

    if type(targets) == "table" and #targets > 0 then
        for i = 0, #targets - 1 do
            local idx = ((startIdx - 1 + i) % #targets) + 1
            local t = targets[idx]
            return {
                world = t.world,
                mode = t.mode,
                act = t.act,
                difficulty = t.difficulty or CONFIG.awakeningDifficulty,
                item = itemName,
                targetIdx = idx,
                targetCount = #targets,
            }, itemName
        end
    end

    return { type = "unknown", item = itemName }, itemName
end

local function awakeningHasWork()
    if not CONFIG.autoAwakening then return false end
    return findOwnedUnitByName(CONFIG.awakeningUnit) ~= nil
end

local function awakeningTakesPriority()
    if Session.awakeningFarm then return true end
    return awakeningHasWork()
end

local function rememberAwakeningFarm(target, unitName)
    Session.awakeningFarm = Session.awakeningFarm or {}
    local af = Session.awakeningFarm
    af.unitName = unitName
    af.item = target.item or af.item
    af.world = target.world
    af.mode = target.mode
    af.act = target.act
    af.difficulty = target.difficulty
    af.quest = target.quest
    af.taskName = target.taskName
    af.targetIdx = target.targetIdx
    af.targetCount = target.targetCount
    af.runs = af.runs or 0
    af.stall = af.stall or 0
    af.lastCount = getItemCount(af.item or "")
    saveSession()
end

local function forgetAwakeningFarm()
    Session.awakeningFarm = nil
    saveSession()
end

local function tryAwakenUnit(unit)
    if not unit or not unit.id then return false, "no_unit" end
    setStatus("Awakening " .. tostring(unit.name) .. "...")
    local ok, suc, newName, newData = invokeR("Awakening", "awaken", unit.id)
    if ok and suc then
        if type(newData) == "table" then
            AS.playerData = newData
            pcall(function()
                local util = require(LP.PlayerScripts.Client.Utility)
                if util then util.data = newData end
            end)
        end
        forgetAwakeningFarm()
        notify("Awakening", (unit.name or "Unit") .. " awakened → " .. tostring(newName or "?"), "success")
        return true
    end
    return false, tostring(newName or suc or "awaken_failed")
end

local function waitForAwakeningRun(target)
    local t0 = tick()
    while alive() and CONFIG.enabled and inLobby() and (tick() - t0) < 12 do
        task.wait(0.5)
    end
    if not alive() or not CONFIG.enabled then return false end

    if inLobby() then
        setStatus("Awakening farm - waiting for stage to start...")
        local t1 = tick()
        while alive() and CONFIG.enabled and inLobby() and (tick() - t1) < CONFIG.farmTimeout do
            task.wait(2)
        end
        if inLobby() then return false end
    end

    local label = target.quest and ("Special: " .. target.quest) or "Awakening"
    setStatus(("%s - farming %s %s Act %d for %s..."):format(
        label, target.mode or "?", target.world or "?", target.act or 0, target.item or "?"))

    local t2 = tick()
    while alive() and CONFIG.enabled and (not inLobby() or inBattle()) and (tick() - t2) < CONFIG.farmTimeout do
        task.wait(1)
    end

    if inLobby() and not inBattle() then return true end
    waitForLobbyReturn(30)
    return true
end

local function awakeningStep()
    if not CONFIG.autoAwakening then return end

    local unit = findOwnedUnitByName(CONFIG.awakeningUnit)
    if not unit then
        setStatus("Awakening - select an owned awakenable unit.")
        return
    end

    if not inLobby() then
        local af = Session.awakeningFarm
        if af then
            setStatus(("Awakening - in %s %s Act %d for %s..."):format(
                af.mode or "?", af.world or "?", af.act or 0, af.item or unit.name))
        else
            setStatus("Awakening - in stage, waiting to return...")
        end
        return
    end

    refreshPlayerData()
    local af = Session.awakeningFarm
    if af and af.quest then pcall(claimReadySpecialTasks, af.quest) end
    claimReadySpecialTasks(SPECIAL_QUEST_ITEM[Session.awakeningFarm and Session.awakeningFarm.item or ""] or "")

    local missing = getMissingAwakeningReqs(unit.name)
    if #missing == 0 then
        local ok, err = tryAwakenUnit(unit)
        if ok then
            setStatus("Awakening complete for " .. unit.name)
            return "done"
        end
        setStatus("Awaken failed: " .. tostring(err))
        task.wait(2)
        return
    end

    local focusItem = Session.awakeningFarm and Session.awakeningFarm.item
    local target, itemName = pickNextAwakeningFarmTarget(unit.name, focusItem)

    if not target then
        setStatus("Awakening - no farm route for missing items.")
        return
    end

    if target.type == "ready" then
        tryAwakenUnit(unit)
        return
    end
    if target.type == "crafting" then
        setStatus("Need " .. target.item .. " from Crafting (manual).")
        notify("Awakening", target.item .. " requires Crafting — farm manually.", "error")
        task.wait(5)
        return
    end
    if target.type == "unknown" then
        setStatus("No farm location for " .. target.item)
        notify("Awakening", "Can't find farm map for " .. target.item, "error")
        task.wait(5)
        return
    end
    if target.type == "special_wait" then
        setStatus("Special quest " .. target.quest .. " — claim tasks / check progress.")
        claimReadySpecialTasks(target.quest)
        task.wait(3)
        return
    end

    local before = getItemCount(itemName)
    rememberAwakeningFarm(target, unit.name)
    local af = Session.awakeningFarm
    af.runs = (af.runs or 0) + 1

    local soloNote = (target.solo and CONFIG.soloOnly) and " solo" or ""
    local needAmt = before
    for _, m in ipairs(getMissingAwakeningReqs(unit.name)) do
        if m.item == itemName then needAmt = m.need break end
    end
    setStatus(("Awakening: need %s (%d/%d) — %s %s Act %d%s run #%d"):format(
        itemName, before, needAmt,
        target.mode, target.world, target.act, soloNote, af.runs))

    local prevSolo = CONFIG.soloOnly
    if target.solo then CONFIG.soloOnly = true end
    local ok, err = startMap(target.world, target.act, target.mode, target.difficulty or CONFIG.awakeningDifficulty)
    if target.solo then CONFIG.soloOnly = prevSolo end

    if not ok then
        setStatus("Awakening launch failed: " .. tostring(err))
        if af.targetIdx and af.targetCount and af.targetCount > 1 then
            af.targetIdx = (af.targetIdx % af.targetCount) + 1
            saveSession()
        end
        task.wait(2)
        return
    end

    waitForAwakeningRun(target)
    refreshPlayerData()
    if target.quest then claimReadySpecialTasks(target.quest) end

    local after = getItemCount(itemName)
    if after > before then
        af.stall = 0
        af.lastCount = after
        notify("Awakening", itemName .. " " .. after .. " (+" .. (after - before) .. ")", "success")
    else
        af.stall = (af.stall or 0) + 1
        if af.targetIdx and af.targetCount and af.stall >= CONFIG.awakeningStallRuns then
            af.targetIdx = (af.targetIdx % af.targetCount) + 1
            af.stall = 0
            setStatus(itemName .. " stalled — trying next map...")
        end
    end
    saveSession()
end

-- ============================================================
-- Core loop logic
-- ============================================================
-- one decision step for daily trait caps; returns "done" when all maps are maxed
local function dailyTraitStep()
    if not CONFIG.dailyTraitFarm then return end
    if challengesTakePriority() then
        local pending = countPendingChallenges()
        if pending > 0 then
            setStatus(("Challenges first — %d available this reset"):format(pending))
        end
        return
    end
    if awakeningTakesPriority() then
        setStatus("Awakening farm active — daily traits paused.")
        return
    end

    refreshPlayerData()

    if not inLobby() then
        local map = resolveDailyMap()
        if map then
            local curIdx = Session.dailyFarm and Session.dailyFarm.idx
            if leaveStageIfCapped(map, nil, curIdx) then
                waitForLobbyReturn(45)
                return
            end
            setStatus(("Daily traits - in %s %s Act %d  %d/%d"):format(
                map.mode, map.world, map.act, getTraitCapCount(map), map.cap))
        else
            setStatus("Daily traits - in stage, watching cap...")
        end
        return
    end

    local open = countOpenTraitMaps()
    if open == 0 then
        setStatus("All daily trait caps filled!")
        if CONFIG.dailyStopWhenDone then
            notify("Daily Traits", "Every map's daily Trait Shard cap is full.", "success")
            return "done"
        end
        task.wait(3)
        return
    end

    local startIdx = 1
    if Session.dailyFarm and Session.dailyFarm.idx then
        startIdx = Session.dailyFarm.idx
    end
    local map, idx = nextTraitMap(startIdx)
    if not map then
        setStatus("All daily trait caps filled!")
        return "done"
    end

    local beforeCap = getTraitCapCount(map)
    if isTraitCapMaxed(map) or shouldSkipMapAfterCapLeave(map) then
        advanceDailyMapIdx(idx, map)
        setStatus(map.world .. " capped — rotating to next map")
        return
    end

    rememberDailyMap(map, idx)
    local df = Session.dailyFarm
    df.runs = (df.runs or 0) + 1

    setStatus(("Daily traits: %s %s Act %d  %d/%d  (run #%d, %d maps left)")
        :format(map.mode, map.world, map.act, beforeCap, map.cap, df.runs, open))

    local ok, err = startMap(map.world, map.act, map.mode, CONFIG.dailyDifficulty)
    if not ok then
        setStatus("Daily launch failed: " .. tostring(err))
        advanceDailyMapIdx(idx, nil)
        df.stall = (df.stall or 0) + 1
        saveSession()
        local qn = #getDailyMapQueue()
        if qn > 0 and df.stall >= qn then
            notify("Daily Traits", "Couldn't enter any daily-trait map. Stopped.", "error")
            return "done"
        end
        task.wait(2)
        return
    end

    waitForDailyRun(map)

    refreshPlayerData()
    local afterCap = getTraitCapCount(map)
    if afterCap > beforeCap then
        df.stall = 0
        df.lastCap = afterCap
    else
        df.stall = (df.stall or 0) + 1
    end
    saveSession()

    if isTraitCapMaxed(map) or shouldSkipMapAfterCapLeave(map) then
        if not AS._dailyLeftCap then
            notify("Daily Traits", map.world .. " cap reached (" .. map.cap .. ") — next map.", "success")
        end
        AS._dailyLeftCap = nil
        advanceDailyMapIdx(idx, map)
        return
    end
    if df.stall >= CONFIG.dailyStallRuns then
        setStatus(map.world .. " cap stalled - moving to next map")
        notify("Daily Traits", map.world .. " cap not increasing - skipping.", "info")
        advanceDailyMapIdx(idx, map)
        df.stall = 0
        saveSession()
    end
end

local _looping = false
local _inSetEnabled = false
mainLoop = function()
    if _looping then return end
    _looping = true
    setStatus("Anime Squadron started.")
    while alive() and CONFIG.enabled do
        if CONFIG.autoDailyChallenge or CONFIG.autoRegularChallenge then
            local okC, errC = pcall(challengeStep)
            if not okC then
                setStatus("Challenge error: " .. tostring(errC))
            end
        end

        if CONFIG.autoAwakening and not challengesTakePriority() then
            local okA, resA = pcall(awakeningStep)
            if not okA then
                setStatus("Awakening error: " .. tostring(resA))
            elseif resA == "done" then
                setStatus("Awakening complete.")
            end
        end

        if CONFIG.dailyTraitFarm and not challengesTakePriority() and not awakeningTakesPriority() then
            local ok, res = pcall(dailyTraitStep)
            if not ok then
                setStatus("Daily error: " .. tostring(res))
            elseif res == "done" then
                if CONFIG.dailyStopWhenDone then
                    setStatus("All daily trait caps filled - stopped.")
                    notify("Anime Squadron", "Every daily trait cap is full. Done.", "success")
                    setEnabled(false)
                    break
                end
            end
        elseif not (CONFIG.autoDailyChallenge or CONFIG.autoRegularChallenge or CONFIG.autoAwakening) then
            setStatus("Enable Challenges, Awakening, and/or Daily Trait Farm to start.")
            task.wait(2)
        end
        task.wait(CONFIG.loopDelay)
    end
    _looping = false
    setStatus("Stopped.")
end

setEnabled = function(on)
    on = on and true or false
    if _inSetEnabled then return end
    if CONFIG.enabled == on then
        Session.running = on
        AS.enabled = on
        return
    end
    _inSetEnabled = true
    CONFIG.enabled = on
    AS.enabled = CONFIG.enabled
    Session.running = CONFIG.enabled
    pcall(persistMasterToggleImmediate)
    pcall(saveSettings)
    if canFile() then
        pcall(function() writefile(SESSION_FILE, HttpService:JSONEncode(Session)) end)
    end
    if CONFIG.enabled then addThread(mainLoop) end
    _inSetEnabled = false
end

