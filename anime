local function readInventoryItemCount(data, itemName)
    if type(data) ~= "table" or type(itemName) ~= "string" or itemName == "" then return nil end
    local bank = readItemsOnlyCount(data, itemName)
    if bank ~= nil then return bank end
    return readStatsOnlyCount(data, itemName)
end

local function lookupGameStyleCount(data, itemName, firstTbl, secondTbl)
    if type(data) ~= "table" or type(itemName) ~= "string" or itemName == "" then return nil end
    local items = type(data.items) == "table" and data.items or nil
    local stats = type(data.stats) == "table" and data.stats or nil
    local a = firstTbl == "items" and lookupExactInTable(items, itemName) or lookupExactInTable(stats, itemName)
    if a ~= nil then return a end
    local b = secondTbl == "items" and lookupExactInTable(items, itemName) or lookupExactInTable(stats, itemName)
    if b ~= nil then return b end

    local want = normalizeItemKey(itemName)
    local best = nil
    for _, tbl in ipairs({ items, stats }) do
        if type(tbl) == "table" then
            for k, v in pairs(tbl) do
                if type(k) == "string" and normalizeItemKey(k) == want and tbl[k] ~= nil then
                    local n = coerceItemValue(v)
                    n = n ~= nil and n or 0
                    if not best or n > best then best = n end
                end
            end
        end
    end
    return best
end

local function lookupItemCountInData(data, itemName)
    if type(data) ~= "table" or type(itemName) ~= "string" or itemName == "" then return nil end
    local bank = readItemsOnlyCount(data, itemName)
    if bank ~= nil then return bank end
    local best = nil
    local function consider(n)
        if n ~= nil and (not best or n > best) then best = n end
    end
    consider(readItemsBankCache(itemName))
    consider(readInventoryItemCount(data, itemName))
    if type(data.all_items) == "table" then
        consider(lookupExactInTable(data.all_items, itemName))
    end
    if best ~= nil then return best end
    return readStatsOnlyCount(data, itemName)
end

