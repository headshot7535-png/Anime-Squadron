local _lastLeaveAt = 0
local function leaveStage(force)
    local now = tick()
    if not force and now - _lastLeaveAt < 0.8 then return false end
    _lastLeaveAt = now

    if armReexec then pcall(armReexec) end

    setStatus("Leaving stage (Settings Teleport + client leave)...")

    local clicked = clickBackToLobby()
    clientForceLeave()

    if clicked or (not inBattle()) then return true end

    fireR("Play", "leave")
    fireR("Matchmaking", "leave")
    pcall(function() invokeR("Player", "physical_teleport", "play") end)

    pcall(function()
        local menus = getMenus()
        if not menus then return end
        local stage = menus:FindFirstChild("StageInfo")
        local leaveBtn = stage and stage:FindFirstChild("Buttons") and stage.Buttons:FindFirstChild("Leave")
        if leaveBtn and leaveBtn.Visible then invokeGui(leaveBtn) end
    end)

    return true
end

