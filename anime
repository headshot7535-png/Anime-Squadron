addThread(function()
    while alive() do
        if next(statusLabels) then
            local lobby = inLobby()
            pcall(function() statusLabels.place.Set("Place: " .. (lobby and "Lobby" or "Battle/Loading")) end)
            -- remembered target works in Story mode too (read from disk-backed Session)
            pcall(function()
                local sb = Session.bounty
                if sb then
                    statusLabels.memory.Set(("Target: %s Act %s | %s | %s/%s | runs %d")
                        :format(sb.world or "?", tostring(sb.act or CONFIG.act),
                            sb.enemy or "?",
                            tostring(sb.progress or 0), tostring(sb.required or 0),
                            sb.runs or 0))
                else
                    statusLabels.memory.Set("Target: none")
                end
            end)
            pcall(function()
                local sb = Session.bounty
                if sb then
                    local need = "?"
                    if sb.required then
                        need = math.max(0, sb.required - (sb.progress or 0) - (Session.runKills or 0))
                    end
                    statusLabels.kills.Set(("Live kills this run: %d  (need ~%s more)")
                        :format(Session.runKills or 0, tostring(need)))
                else
                    statusLabels.kills.Set("Live kills this run: -")
                end
            end)
            if lobby then
                local list = readBounties()
                local active, traitCount = nil, 0
                for _, b in ipairs(list) do
                    if b.active then active = b end
                    if b.trait then traitCount = traitCount + 1 end
                end
                pcall(function() statusLabels.tickets.Set("Tickets: " .. getTickets()) end)
                pcall(function()
                    if active then
                        statusLabels.active.Set(("Active: %s  %d/%d%s")
                            :format(active.world or "?", active.progress, active.required,
                                active.trait and " (trait)" or ""))
                    else
                        statusLabels.active.Set("Active bounty: none")
                    end
                end)
                pcall(function() statusLabels.trait.Set("Trait bounties available: " .. traitCount) end)
                pcall(function() statusLabels.board.Set("Board: " .. #list .. " bounties") end)
            end
            -- daily trait cap readout (lobby or battle)
            pcall(refreshDailyCapLabels)
            pcall(refreshDpsLabels)
        end
        task.wait(1)
    end
end)

