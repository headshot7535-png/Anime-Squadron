local _lastLeaveAt = 0
local function leaveStage(force)
    local now = tick()
    if not force and now - _lastLeaveAt < 0.8 then return inLobby() end
    _lastLeaveAt = now

    if inLobby() then return true end

    if armReexec then pcall(armReexec) end

    setStatus("Leaving stage (teleport + Play.leave)...")

    -- Primary leave path in-match: ReplicatedStorage.Remotes.Players.teleport (u8.on_teleport)
    fireR("Players", "teleport")
    task.wait(0.45)
    if inLobby() then return true end

    pcall(function()
        local menus = getMenus()
        local es = menus and menus:FindFirstChild("EndScreen")
        if es and es.Visible then
            local leaveBtn = es:FindFirstChild("Buttons") and es.Buttons:FindFirstChild("Leave")
            if leaveBtn then invokeGui(leaveBtn) end
        end
    end)
    task.wait(0.45)
    if inLobby() then return true end

    clientForceLeave()
    task.wait(0.8)
    if inLobby() then return true end

    clickBackToLobby()
    task.wait(0.8)
    if inLobby() then return true end

    fireR("Play", "leave")
    fireR("Matchmaking", "leave")
    pcall(function() invokeR("Player", "physical_teleport", "play") end)

    pcall(function()
        local menus = getMenus()
        if not menus then return end
        local stage = menus:FindFirstChild("StageInfo")
        local leaveBtn = stage and stage:FindFirstChild("Buttons") and stage.Buttons:FindFirstChild("Leave")
        if leaveBtn and leaveBtn.Visible then invokeGui(leaveBtn) end
    end)

    task.wait(0.6)
    return inLobby()
end

