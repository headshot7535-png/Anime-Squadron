        for ck in pairs(AS.challengeProbeCache) do
            if ck:sub(1, #key + 1) == (key .. "|") then
                AS.challengeProbeCache[ck] = true
            end
        end
    end
    pcall(saveSettings)
    if canFile() then
        pcall(function()
            local data = {}
            local path = SETTINGS_FILE
            if isfile(path) then
                local ok, raw = pcall(readfile, path)
                if ok and raw then
                    local ok2, d = pcall(function() return HttpService:JSONDecode(raw) end)
                    if ok2 and type(d) == "table" then data = d end
                end
            end
            data.challengeDone = CONFIG.challengeDone
            data.challengeDoneMeta = CONFIG.challengeDoneMeta
