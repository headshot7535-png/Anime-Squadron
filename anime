-- independent cap watcher — leaves mid-raid even if main loop is blocked
local function startDailyCapWatcher()
    addThread(function()
        local lastTry = 0
        while alive() do
            if CONFIG.enabled and CONFIG.dailyTraitFarm and inBattle() then
                refreshPlayerData()
                local map = resolveDailyMap()
                if map and (isTraitCapMaxed(map) or shouldSkipMapAfterCapLeave(map)) then
                    local now = tick()
                    if now - lastTry >= 2 then
                        lastTry = now
                        leaveStageIfCapped(map, ("Cap full %s %d/%d — leaving stage...")
                            :format(map.world, getTraitCapCount(map), map.cap),
                            Session.dailyFarm and Session.dailyFarm.idx)
                    end
                end
            end
            task.wait(0.5)
        end
    end)
end
startDailyCapWatcher()

