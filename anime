-- ============================================================
-- Live in-stage elimination tracker (Story/battle place)
-- The bounty board doesn't exist in Story mode, so we count the bounty enemy's
-- deaths directly: any Model named like the enemy with a Humanoid that Dies = 1
-- kill. This is a live readout; the server still credits the real bounty count
-- (reconciled in the lobby). Solo room => every kill is yours.
-- ============================================================
local function norm(s) return tostring(s):lower():gsub("%s+", "") end
-- This is exactly how the game itself registers a kill on the client: the enemy
-- is a Model in workspace.Characters tagged with attribute type=="Enemies", and
-- when it dies the server's "destroy" event makes the client Destroy that model
-- -> fires ChildRemoved. We listen to the SAME removal and count it for the
-- bounty enemy. Works whether the stage is in-place or a separate place, and we
-- never depend on lobby detection (which can stay true during in-place battles).
local function isTargetEnemy(m)
    local enemy = Session.bounty and Session.bounty.enemy
    if not enemy then return false end
    if not (m and m:IsA("Model")) then return false end
    local ok, t = pcall(function() return m:GetAttribute("type") end)
    if not ok or t ~= "Enemies" then return false end
    return norm(m.Name) == norm(enemy)
end
local function startKillTracker()
    local bound = setmetatable({}, { __mode = "k" })
    local function bind(container)
        if not container or bound[container] then return end
        bound[container] = true
        addConn(container.ChildRemoved:Connect(function(m)
            if CONFIG.liveKills and isTargetEnemy(m) then
                Session.runKills = (Session.runKills or 0) + 1
            end
        end))
    end
    local existing = workspace:FindFirstChild("Characters")
    if existing then bind(existing) end
    -- workspace.Characters may be (re)created per place/stage - rebind on add
    addConn(workspace.ChildAdded:Connect(function(c)
        if c.Name == "Characters" then bind(c) end
    end))

    addThread(function()
        local warned = false
        while alive() do
            -- leave the stage the moment the target is met, so we return to the
            -- lobby to claim + accept the next one. Fires once per run (AB._leftRun),
            -- and self-disables (AB._noEarlyLeave) if it turns out the server only
            -- banks progress on stage completion (see step()).
            if CONFIG.leaveWhenDone and not AB._noEarlyLeave and not AB._leftRun
                and Session.bounty and Session.bounty.required then
                local total = (Session.bounty.progress or 0) + (Session.runKills or 0)
                if (Session.runKills or 0) > 0 and total >= Session.bounty.required then
                    AB._leftRun = true
                    AB._earlyLeft = true
                    setStatus("Target reached in-stage - leaving to claim...")
                    leaveStage()
                end
            end
            -- diagnostic: bounty active, enemies present, but none match the name
            if not warned and Session.bounty and Session.bounty.enemy then
                local c = workspace:FindFirstChild("Characters")
                if c then
                    local target, names, seen, found, anyEnemy = norm(Session.bounty.enemy), {}, {}, false, false
                    for _, m in ipairs(c:GetChildren()) do
                        local ok, t = pcall(function() return m:GetAttribute("type") end)
                        if ok and t == "Enemies" and m:IsA("Model") then
                            anyEnemy = true
                            if norm(m.Name) == target then found = true end
                            if not seen[m.Name] then seen[m.Name] = true; names[#names + 1] = m.Name end
                        end
                    end
                    if anyEnemy and not found then
                        warned = true
                        warn("[Auto Bounty] Bounty enemy is '" .. tostring(Session.bounty.enemy) ..
                            "' but enemies present are: " .. table.concat(names, ", ") ..
                            ". Tell me the right one if the live count stays 0.")
                    end
                end
            end
            task.wait(1)
        end
    end)
end
startKillTracker()
