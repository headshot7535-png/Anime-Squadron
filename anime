        parts[#parts + 1] = ("#%d %s %d/%d%s"):format(i, m.world, cur, m.cap, mark)
    end
    if #parts == 0 then
        setLabel(statusLabels.dailyCaps, "Caps: no priority maps enabled")
    else
        setLabel(statusLabels.dailyCaps, "Priority caps: " .. table.concat(parts, " | "))
    end
end

local function refreshAwakeningLabels()
    local unitName = CONFIG.awakeningUnit
    if unitName == "" then
        setLabel(statusLabels.awakenUnit, "Unit: none selected")
        setLabel(statusLabels.awakenReqs, "Requirements: -")
        setLabel(statusLabels.awakenFarm, "Farm target: -")
        return
    end
    local unit = findOwnedUnitByName(unitName)
    if not unit then
        setLabel(statusLabels.awakenUnit, "Unit: " .. unitName .. " (not owned)")
        setLabel(statusLabels.awakenReqs, "Requirements: -")
        setLabel(statusLabels.awakenFarm, "Farm target: -")
        return
    end
    setLabel(statusLabels.awakenUnit, "Unit: " .. unit.name .. " (id " .. tostring(unit.id) .. ")")
    local missing = getMissingAwakeningReqs(unit.name)
    if #missing == 0 then
        setLabel(statusLabels.awakenReqs, "Requirements: ALL MET — ready to awaken")
    else
        local parts = {}
        for _, m in ipairs(missing) do
            parts[#parts + 1] = m.item .. " " .. m.have .. "/" .. m.need
        end
        setLabel(statusLabels.awakenReqs, "Missing: " .. table.concat(parts, " | "))
    end
    local af = Session.awakeningFarm
    if af and af.world and af.mode then
        setLabel(statusLabels.awakenFarm, ("Farming: %s %s Act %d for %s"):format(
            af.mode, af.world, af.act or 0, af.item or "?"))
    elseif af and af.quest then
        setLabel(statusLabels.awakenFarm, "Special quest: " .. tostring(af.quest))
    else
        setLabel(statusLabels.awakenFarm, "Farm target: idle in lobby")
    end
    local n = #getOwnedAwakenableUnits()
    if statusLabels.awakenCount then
        setLabel(statusLabels.awakenCount, ("Awakenable units found: %d"):format(n))
    end
end

local awakenUnitInput = nil
local function cycleAwakenUnit(dir)
    local units = getOwnedAwakenableUnits()
    if #units == 0 then return end
    local names = {}
    for _, u in ipairs(units) do names[#names + 1] = u.name end
    local cur = table.find(names, CONFIG.awakeningUnit) or 1
    cur = cur + (dir or 1)
    if cur < 1 then cur = #names end
    if cur > #names then cur = 1 end
    CONFIG.awakeningUnit = names[cur]
    saveSettings()
    if awakenUnitInput then pcall(function() awakenUnitInput.Set(CONFIG.awakeningUnit) end) end
    pcall(refreshAwakeningLabels)
end

local function refreshAwakenUnitDropdown()
    refreshPlayerData()
    local units = getOwnedAwakenableUnits()
    local names = {}
    for _, u in ipairs(units) do names[#names + 1] = u.name end

    if #names == 0 then
        setLabel(statusLabels.awakenList, "Available: none (open Characters menu, then Refresh)")
    else
        if CONFIG.awakeningUnit == "" or not table.find(names, CONFIG.awakeningUnit) then
            CONFIG.awakeningUnit = names[1]
            saveSettings()
        end
        setLabel(statusLabels.awakenList, "Available: " .. table.concat(names, ", "))
        if awakenUnitInput then
            pcall(function() awakenUnitInput.Set(CONFIG.awakeningUnit) end)
        end
    end
    pcall(refreshAwakeningLabels)
    return #units
end

local function refreshChallengeLabels()
    local dayT, halfT = getChallengeTimers()
    setLabel(statusLabels.chTimers, ("Reset timers: Daily %s | Regular %s")
        :format(fmtChallengeTimer(dayT), fmtChallengeTimer(halfT)))

    local chs = getRotatingChallenges()
    syncChallengeDoneFlags(chs)

    for _, key in ipairs(CHALLENGE_ORDER) do
        local lbl = (key == "1d") and statusLabels.chDaily or statusLabels.chRegular
        if lbl then
        local name = CHALLENGE_NAMES[key] or key
        local ch = chs[key]
        local enabled = isChallengeEnabled(key)
        if not enabled then
            setLabel(lbl, name .. ": disabled")
        elseif type(ch) == "table" and ch.world then
            local done = (AS.challengeDoneSession and AS.challengeDoneSession[key])
                or scanChallengeGuiCompleted(key)
            setLabel(lbl, name .. ": " .. ch.world .. " Act " .. tostring(ch.act)
                .. (done and " (already completed)" or " (ready)"))
        else
            setLabel(lbl, name .. ": done / on cooldown")
        end
        end
    end
end

