local function resolveAwakenItemCount(itemName, snapByItem)
    if type(itemName) ~= "string" or itemName == "" then return nil end
    local have = getItemCount(itemName)
    if have ~= nil then return have end
    have = readBestItemsBankCount(itemName)
    if have ~= nil then return have end
    have = tonumber(AS.awakenItemCache and AS.awakenItemCache[itemName])
        or tonumber(Session.awakenItemCache and Session.awakenItemCache[itemName])
    if have ~= nil then return have end
    local data = AS._lobbyPlayerData or AS.playerData or getPlayerData()
    if data then
        have = readItemsOnlyCount(data, itemName)
        if have ~= nil then return have end
        have = readInventoryItemCount(data, itemName)
        if have ~= nil then return have end
    end
    if inPlayArea() then
        local utilData = getLiveUtilityData()
        if utilData then
            have = readItemsOnlyCount(utilData, itemName)
            if have ~= nil then return have end
        end
        data = AS._matchPlayerData
        if data then
            have = readStatsOnlyCount(data, itemName)
            if have ~= nil then return have end
        end
    end
    return nil
end

local function getMissingAwakeningReqs(unitName)
    local cost = getAwakeningCost(unitName)
    if type(cost) ~= "table" or next(cost) == nil then return nil end

    if inLobby() then
        refreshPlayerData()
        updateAwakenItemCacheFromData(getPlayerData(), unitName)
    end

    local snapByItem = {}
    local af = Session.awakeningFarm
    if af and af.unitName == unitName then
        if type(af.reqSnapshotFull) == "table" then
            for _, m in ipairs(af.reqSnapshotFull) do snapByItem[m.item] = m end
        elseif type(af.reqSnapshot) == "table" then
            for _, m in ipairs(af.reqSnapshot) do snapByItem[m.item] = m end
        end
    end

    local missing = {}
    local full = {}
    for item, need in pairs(cost) do
        need = tonumber(need) or 0
        if need > 0 then
            local have = resolveAwakenItemCount(item, snapByItem)
            if have == nil then return nil end
            local entry = {
                item = item,
                need = need,
                have = have,
                deficit = math.max(0, need - have),
            }
            full[#full + 1] = entry
            if have < need then
                missing[#missing + 1] = entry
            end
        end
    end
    table.sort(missing, function(a, b)
        if a.deficit ~= b.deficit then return a.deficit > b.deficit end
        return a.item < b.item
    end)
    table.sort(full, function(a, b)
        if a.deficit ~= b.deficit then return a.deficit > b.deficit end
        return a.item < b.item
    end)

    if af and af.unitName == unitName then
        af.reqSnapshot = copyMissingSnapshot(missing)
        af.reqSnapshotFull = copyFullReqSnapshot(full)
    end
    return missing
end

local function parseItemDescriptionLocation(itemName)
    if ITEM_LOC_CACHE[itemName] then return ITEM_LOC_CACHE[itemName] end
    local folder = ReplicatedStorage.Items:FindFirstChild(itemName)
    if not folder then return nil end
    local ok, data = pcall(function() return require(folder.data) end)
    if not ok or type(data) ~= "table" then return nil end
    local desc = stripHtml(tostring(data.description or ""))
    local loc = desc:match("Obtainable in%s*→%s*(.+)$")
        or desc:match("Obtainable in%s+(.+)$")
    loc = loc and loc:gsub("%.$", ""):gsub("%s+", " ") or nil
    if not loc or loc == "" then return nil end

    if loc:find("Special Quest", 1, true) then
        local quest = loc:match("Special Quest%s+(.+)")
        local parsed = { type = "special", quest = quest and quest:gsub("%.$", "") or loc }
        ITEM_LOC_CACHE[itemName] = parsed
        return parsed
    end
    if loc:find("Crafting", 1, true) then
        local parsed = { type = "crafting" }
        ITEM_LOC_CACHE[itemName] = parsed
        return parsed
    end

    local world, act1, act2 = loc:match("^(.-) Story Act (%d+)%s*,%s*(%d+)")
    if world then
        local parsed = {
            type = "map", world = world:match("^%s*(.-)%s*$"), mode = "Story",
            acts = { tonumber(act1), tonumber(act2) }, difficulty = "Normal",
        }
        ITEM_LOC_CACHE[itemName] = parsed
        return parsed
    end

    world, act1 = loc:match("^(.-) Story Act (%d+)")
    if world then
        local parsed = {
            type = "map", world = world:match("^%s*(.-)%s*$"), mode = "Story",
            acts = { tonumber(act1) }, difficulty = "Normal",
        }
        ITEM_LOC_CACHE[itemName] = parsed
        return parsed
    end

    world, act1 = loc:match("^(.-) Act (%d+)%s+Squadron")
    if world then
        local parsed = {
            type = "map", world = world:match("^%s*(.-)%s*$"), mode = "Squadron",
            acts = { tonumber(act1) }, difficulty = "Normal",
        }
        ITEM_LOC_CACHE[itemName] = parsed
        return parsed
    end

    world, act1 = loc:match("^(.-) Squadron Act (%d+)")
    if world then
        local parsed = {
            type = "map", world = world, mode = "Squadron",
            acts = { tonumber(act1) }, difficulty = "Normal",
        }
        ITEM_LOC_CACHE[itemName] = parsed
        return parsed
    end

    world, act1 = loc:match("^(.-) Act (%d+) Squadron")
    if world then
        local parsed = {
            type = "map", world = world, mode = "Squadron",
            acts = { tonumber(act1) }, difficulty = "Normal",
        }
        ITEM_LOC_CACHE[itemName] = parsed
        return parsed
    end

    world, act1, difficulty = loc:match("^(.-) Squadron Act (%d+)%s*(Hard)")
    if world then
        local parsed = {
            type = "map", world = world:match("^%s*(.-)%s*$"), mode = "Squadron",
            acts = { tonumber(act1) }, difficulty = "Hard",
        }
        ITEM_LOC_CACHE[itemName] = parsed
        return parsed
    end

    world, act1 = loc:match("^(.-) Act (%d+) Raid")
    if world then
        local parsed = {
            type = "map", world = world:match("^%s*(.-)%s*$"), mode = "Raid",
            acts = { tonumber(act1) }, difficulty = "Normal",
        }
        ITEM_LOC_CACHE[itemName] = parsed
        return parsed
    end

    world = loc:match("^(.-) Invasion")
    if world then
        local parsed = {
            type = "map", world = world, mode = "Invasion",
            acts = { 1 }, difficulty = "Normal",
        }
        ITEM_LOC_CACHE[itemName] = parsed
        return parsed
    end

    return nil
end

local function discoverItemDropMaps(itemName)
    local found, seen = {}, {}
    local ok, Worlds = pcall(function() return require(LP.PlayerScripts.Client.Play.Worlds) end)
    if ok and type(Worlds) == "table" then
        for _, idx in ipairs(WORLD_INDICES) do
            local w = Worlds[idx]
            if type(w) == "table" and w.name and type(w.Rewards) == "table" then
                for mode, modeData in pairs(w.Rewards) do
                    if type(modeData) == "table" then
                        for diff, diffData in pairs(modeData) do
                            if type(diffData) == "table" then
                                for act, actRewards in ipairs(diffData) do
                                    if type(actRewards) == "table" and actRewards[itemName] then
                                        local key = mode .. "|" .. w.name .. "|" .. act .. "|" .. diff
                                        if not seen[key] then
                                            seen[key] = true
                                            found[#found + 1] = {
                                                world = w.name,
                                                mode = mode,
                                                act = act,
                                                difficulty = (diff == "Hard") and "Hard" or "Normal",
                                            }
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    table.sort(found, function(a, b)
        if a.mode ~= b.mode then return a.mode < b.mode end
        if a.world ~= b.world then return a.world < b.world end
        return a.act < b.act
    end)
    return found
end

local function normalizeAwakeningDifficulty(itemDifficulty)
    if itemDifficulty == "Hard" then return "Hard" end
    return (CONFIG.awakeningDifficulty == "Hard") and "Hard" or "Normal"
end

local function filterTargetsByDifficulty(targets)
    if type(targets) ~= "table" or #targets == 0 then return targets end
    local want = normalizeAwakeningDifficulty()
    local filtered = {}
    for _, t in ipairs(targets) do
        if normalizeAwakeningDifficulty(t.difficulty) == want then
            filtered[#filtered + 1] = t
        end
    end
    if #filtered > 0 then return filtered end
    if want == "Hard" then
        for _, t in ipairs(targets) do
            if normalizeAwakeningDifficulty(t.difficulty) == "Normal" then
                filtered[#filtered + 1] = t
            end
        end
    end
    return #filtered > 0 and filtered or targets
end

local function buildFarmTargetsForItem(itemName)
    local targets = {}
    local seen = {}
    local function addTarget(t)
        if type(t) ~= "table" or not t.world or not t.mode or not t.act then return end
        local key = t.mode .. "|" .. t.world .. "|" .. t.act .. "|" .. (t.difficulty or "Normal")
        if seen[key] then return end
        seen[key] = true
        targets[#targets + 1] = t
    end

    for _, m in ipairs(discoverItemDropMaps(itemName)) do addTarget(m) end

    local parsed = parseItemDescriptionLocation(itemName)
    if parsed and parsed.type == "map" then
        for _, act in ipairs(parsed.acts or {}) do
            addTarget({
                world = parsed.world,
                mode = parsed.mode,
                act = act,
                difficulty = parsed.difficulty or CONFIG.awakeningDifficulty,
            })
        end
    elseif parsed and parsed.type == "special" then
        return { special = parsed.quest or SPECIAL_QUEST_ITEM[itemName] }
    elseif parsed and parsed.type == "crafting" then
        return { crafting = true }
    elseif SPECIAL_QUEST_ITEM[itemName] then
        return { special = SPECIAL_QUEST_ITEM[itemName] }
    end

    if #targets == 0 and parsed and parsed.type == "map" and parsed.world then
        addTarget({
            world = parsed.world,
            mode = parsed.mode or "Story",
            act = (parsed.acts and parsed.acts[1]) or 1,
            difficulty = parsed.difficulty or CONFIG.awakeningDifficulty,
        })
    end

    if type(targets) == "table" and #targets > 0 then
        for _, t in ipairs(targets) do
            t.difficulty = normalizeAwakeningDifficulty(t.difficulty)
        end
        targets = filterTargetsByDifficulty(targets)
    end

    return targets
end

local function getSpecialQuestCatalog()
    local ok, data = invokeR("Quests", "get_specials")
    if ok and type(data) == "table" then
        AS.specialQuestCache = data
        return data
    end
    return AS.specialQuestCache or {}
end

local function claimReadySpecialTasks(questName)
    refreshPlayerData()
    local data = getPlayerData()
    local catalog = getSpecialQuestCatalog()
    local questDef = catalog[questName]
    local playerQuest = data and data.specials and data.specials[questName]
    if not questDef or not playerQuest then return false end
    local claimed = false
    for idx, taskDef in pairs(questDef.quests or {}) do
        if type(taskDef) == "table" then
            local prog = playerQuest.quests and playerQuest.quests[tostring(idx)]
            if prog and not prog.claimed and tonumber(prog.progress) >= tonumber(taskDef.required) then
                local ok, suc, newData = invokeR("Quests", "claim_special", questName, tostring(idx))
                if ok and suc then
                    claimed = true
                    if type(newData) == "table" then
                        AS.playerData = newData
                        pcall(function()
                            local util = require(LP.PlayerScripts.Client.Utility)
                            if util then util.data = newData end
                        end)
                    end
                end
            end
        end
    end
    refreshPlayerData()
    return claimed
end

local function parseTaskFarmTarget(taskDesc)
    if type(taskDesc) ~= "string" then return nil end
    local desc = stripHtml(taskDesc):lower()
    local solo = desc:find("solo", 1, true) ~= nil

    local world, mode, act
    if desc:find("invasion", 1, true) then
        mode = "Invasion"
        if desc:find("bralu", 1, true) or desc:find("lava", 1, true) then
            world = "The Lava Continent"
        elseif desc:find("ice", 1, true) then
            world = "The Ice Continent"
        end
        act = 1
    elseif desc:find("infinite", 1, true) then
        mode = "Infinite"
        world = "The Lava Continent"
        act = 1
    elseif desc:find("raid", 1, true) then
        mode = "Raid"
        world = desc:match("(%w[%w%s%(%)%-]+) raid") or world
        act = tonumber(desc:match("act (%d+)")) or 1
    elseif desc:find("squadron", 1, true) or desc:find("stage", 1, true) then
        mode = "Squadron"
        world = desc:match("(%w[%w%s%(%)%-]+) invasion")
            or desc:match("(%w[%w%s%(%)%-]+) squadron")
            or world
        act = tonumber(desc:match("act (%d+)")) or 1
    end

    if not world or not mode then return nil end
    return { world = world, mode = mode, act = act, difficulty = CONFIG.awakeningDifficulty, solo = solo }
end

local function pickSpecialQuestFarmTarget(questName, itemName)
    claimReadySpecialTasks(questName)
    if getItemCount(itemName) > 0 then return nil end

    local data = getPlayerData()
    local catalog = getSpecialQuestCatalog()
    local questDef = catalog[questName]
    local playerQuest = data and data.specials and data.specials[questName]
    if not questDef or not playerQuest then return nil end

    local best
    for idx, taskDef in pairs(questDef.quests or {}) do
        if type(taskDef) == "table" then
            local prog = playerQuest.quests and playerQuest.quests[tostring(idx)]
            local progress = prog and tonumber(prog.progress) or 0
            local required = tonumber(taskDef.required) or 0
            if not (prog and prog.claimed) and progress < required then
                local target = parseTaskFarmTarget(taskDef.desc or taskDef.name or "")
                if target then
                    target.quest = questName
                    target.taskIndex = tostring(idx)
                    target.taskName = taskDef.name or ("Task " .. tostring(idx))
                    target.progress = progress
                    target.required = required
                    if not best or (required - progress) > (best.required - best.progress) then
                        best = target
                    end
                end
            end
        end
    end
    return best
end

local function pickNextAwakeningFarmTarget(unitName, focusItem)
    local missing = getMissingAwakeningReqs(unitName)
    if type(missing) ~= "table" then return nil, "unknown" end
    if #missing == 0 then return nil, "ready" end

    local tryOrder = {}
    if focusItem then
        for _, m in ipairs(missing) do
            if m.item == focusItem then tryOrder[#tryOrder + 1] = m end
        end
    end
    for _, m in ipairs(missing) do
        if m.item ~= focusItem then tryOrder[#tryOrder + 1] = m end
    end

    local lastUnknown, lastCrafting, lastSpecial
    for _, itemEntry in ipairs(tryOrder) do
        local itemName = itemEntry.item
        local targets = buildFarmTargetsForItem(itemName)
        if type(targets) == "table" and targets.special then
            local sq = pickSpecialQuestFarmTarget(targets.special, itemName)
            if sq then return sq, itemName end
            lastSpecial = {
                type = "special_wait",
                quest = targets.special,
                item = itemName,
            }
        elseif type(targets) == "table" and targets.crafting then
            lastCrafting = { type = "crafting", item = itemName }
        elseif type(targets) == "table" and #targets > 0 then
            local af = Session.awakeningFarm
            local startIdx = 1
            if af and af.item == itemName and af.targetIdx then
                startIdx = af.targetIdx
            end
            for i = 0, #targets - 1 do
                local idx = ((startIdx - 1 + i) % #targets) + 1
                local t = targets[idx]
                return {
                    world = t.world,
                    mode = t.mode,
                    act = t.act,
                    difficulty = t.difficulty or CONFIG.awakeningDifficulty,
                    item = itemName,
                    targetIdx = idx,
                    targetCount = #targets,
                }, itemName
            end
        else
            lastUnknown = { type = "unknown", item = itemName }
        end
    end

    if lastSpecial then return lastSpecial, lastSpecial.item end
    if lastCrafting then return lastCrafting, lastCrafting.item end
    if lastUnknown then return lastUnknown, lastUnknown.item end
    return nil, "ready"
end

local function awakeningHasWork()
    if not CONFIG.autoAwakening then return false end
    local unit = findOwnedUnitByName(CONFIG.awakeningUnit)
    if not unit then return false end
    if Session.awakeningFarm then return true end
    local missing = getMissingAwakeningReqs(unit.name)
    return type(missing) == "table" and #missing > 0
end

local function getAwakeningFarmPreview(unitName)
    local target = pickNextAwakeningFarmTarget(unitName, Session.awakeningFarm and Session.awakeningFarm.item)
    if not target then return "ready to awaken" end
    if target.type == "crafting" then
        return "need " .. target.item .. " (Crafting — manual)"
    end
    if target.type == "unknown" then
        return "no route for " .. target.item
    end
    if target.type == "special_wait" then
        return "special quest: " .. tostring(target.quest)
    end
    if target.world and target.mode then
        return ("next: %s %s Act %d (%s) for %s"):format(
            target.mode, target.world, target.act or 0, target.difficulty or CONFIG.awakeningDifficulty, target.item or "?")
    end
    return "planning route..."
end

local function awakeningTakesPriority()
    if Session.awakeningFarm then return true end
    return awakeningHasWork()
end

local function rememberAwakeningFarm(target, unitName)
    Session.awakeningFarm = Session.awakeningFarm or {}
    local af = Session.awakeningFarm
    af.unitName = unitName
    af.item = target.item or af.item
    af.world = target.world
    af.mode = target.mode
    af.act = target.act
    af.difficulty = target.difficulty
    af.quest = target.quest
    af.taskName = target.taskName
    af.targetIdx = target.targetIdx
    af.targetCount = target.targetCount
    af.runs = af.runs or 0
    af.stall = af.stall or 0
    af.lastCount = getItemCount(af.item or "") or 0
    af.unitName = unitName
    if unitName and inLobby() then
        invalidateMatchCountCaches()
        updateAwakenItemCacheFromData(getPlayerData(), unitName)
        local snap = getMissingAwakeningReqs(unitName)
        if type(snap) == "table" then
            af.reqSnapshot = copyMissingSnapshot(snap)
            if type(af.reqSnapshotFull) ~= "table" then
                local cost = getAwakeningCost(unitName)
                if type(cost) == "table" then
                    local full = {}
                    for item, need in pairs(cost) do
                        need = tonumber(need) or 0
                        if need > 0 then
                            local have = resolveAwakenItemCount(item)
                            if have ~= nil then
                                full[#full + 1] = {
                                    item = item, need = need, have = have,
                                    deficit = math.max(0, need - have),
                                }
                            end
                        end
                    end
                    if #full > 0 then
                        af.reqSnapshotFull = copyFullReqSnapshot(full)
                    end
                end
            end
        end
        if flushSession then pcall(flushSession) end
    end
    saveSession()
end

local function forgetAwakeningFarm()
    Session.awakeningFarm = nil
    saveSession()
end

local function tryAwakenUnit(unit)
    if not unit or not unit.id then return false, "no_unit" end
    setStatus("Awakening " .. tostring(unit.name) .. "...")
    local ok, suc, newName, newData = invokeR("Awakening", "awaken", unit.id)
    if ok and suc then
        if type(newData) == "table" then
            AS.playerData = newData
            pcall(function()
                local util = require(LP.PlayerScripts.Client.Utility)
                if util then util.data = newData end
            end)
        end
        forgetAwakeningFarm()
        notify("Awakening", (unit.name or "Unit") .. " awakened → " .. tostring(newName or "?"), "success")
        return true
    end
    return false, tostring(newName or suc or "awaken_failed")
end

local function waitForAwakeningRun(target)
    local t0 = tick()
    while alive() and CONFIG.enabled and inLobby() and (tick() - t0) < 12 do
        task.wait(0.5)
    end
    if not alive() or not CONFIG.enabled then return false end

    if inLobby() then
        setStatus("Awakening farm - waiting for stage to start...")
        local t1 = tick()
        while alive() and CONFIG.enabled and inLobby() and (tick() - t1) < CONFIG.farmTimeout do
            task.wait(2)
        end
        if inLobby() then return false end
    end

    local label = target.quest and ("Special: " .. target.quest) or "Awakening"
    setStatus(("%s - farming %s %s Act %d for %s..."):format(
        label, target.mode or "?", target.world or "?", target.act or 0, target.item or "?"))

    local af = Session.awakeningFarm
    local farmItem = af and af.item
    local runTargetAct = tonumber(target.act) or tonumber(af and af.act)
    local runTargetWorld = target.world or (af and af.world)
    local lastSeenAct = nil
    local actTransitions = 0
    local settleUntil = tick() + 15

    local t2 = tick()
    local idleSince = nil
    while alive() and CONFIG.enabled and not inLobby() and (tick() - t2) < CONFIG.farmTimeout do
        local unitName = af and af.unitName
        if unitName and unitName ~= "" then
            local costTbl = getAwakeningCost(unitName)
            if type(costTbl) == "table" then
                for item in pairs(costTbl) do
                    if (tonumber(costTbl[item]) or 0) > 0 then
                        getItemCount(item)
                    end
                end
            end
        end
        if farmItem then
            local farmNeed = getFarmItemNeed(farmItem)
            local have = getItemCount(farmItem)
            if farmNeed and have and have >= farmNeed then
                setStatus(("Enough %s (%d/%d) — leaving stage..."):format(farmItem, have, farmNeed))
                break
            end
            if unitName and unitName ~= "" then
                local missing = getMissingAwakeningReqs(unitName)
                if type(missing) == "table" and #missing == 0 then
                    setStatus("All awakening materials met — leaving stage...")
                    break
                end
            end
        end

        local curWorld, curAct = getHotbarStageInfo()
        if curAct then
            if lastSeenAct and curAct ~= lastSeenAct then
                actTransitions = actTransitions + 1
                if af then
                    af.actTransitions = actTransitions
                    af.lastSeenAct = curAct
                end
            end
            lastSeenAct = curAct

            if runTargetAct and tick() > settleUntil and curAct ~= runTargetAct then
                setStatus(("Act drifted to %d (target Act %d) — leaving stage..."):format(
                    curAct, runTargetAct))
                break
            end
            if runTargetWorld and curWorld and tick() > settleUntil then
                local tw = runTargetWorld:lower()
                local cw = curWorld:lower()
                if cw:find(tw, 1, true) == nil and tw:find(cw, 1, true) == nil then
                    setStatus(("World drifted to %s (target %s) — leaving..."):format(curWorld, runTargetWorld))
                    break
                end
            end
            if actTransitions >= 2 then
                setStatus("Multiple act advances in one run — leaving stage...")
                break
            end
        end

        if isEndScreenVisible() then
            setStatus("Stage clear (EndScreen) — leaving...")
            break
        end
        if inBattle() then
            idleSince = nil
        elseif isStageCompleteScreenVisible() then
            break
        else
            idleSince = idleSince or tick()
            if tick() - idleSince >= 2 then
                break
            end
        end
        task.wait(0.25)
    end

    leaveStage(true)
    waitForLobbyReturn(45)
    if inLobby() then
        refreshPlayerData()
        local af2 = Session.awakeningFarm
        if af2 and af2.unitName then
            updateAwakenItemCacheFromData(getPlayerData(), af2.unitName)
        end
    end
    return true
end

local function awakeningStep()
    if not CONFIG.autoAwakening then return end

    local unit = findOwnedUnitByName(CONFIG.awakeningUnit)
    if not unit then
        setStatus("Awakening - select an owned awakenable unit.")
        return
    end

    if not inLobby() then
        local af = Session.awakeningFarm
        if af then
            local farmItem = af.item
            if farmItem then
                local farmNeed = getFarmItemNeed(farmItem)
                local have = getItemCount(farmItem)
                if farmNeed and have and have >= farmNeed then
                    setStatus(("Enough %s (%d/%d) — leaving stage..."):format(farmItem, have, farmNeed))
                    leaveStage(true)
                    waitForLobbyReturn(45)
                    return
                end
            end
            local _, curAct = getHotbarStageInfo()
            local targetAct = tonumber(af.farmTargetAct) or tonumber(af.act)
            if curAct and targetAct and curAct ~= targetAct then
                AS._awakenActDriftAt = AS._awakenActDriftAt or tick()
                if tick() - AS._awakenActDriftAt >= 3
                    or (tonumber(af.actTransitions) or 0) >= 2 then
                    setStatus(("Awakening - act %d ≠ target %d, leaving..."):format(curAct, targetAct))
                    leaveStage(true)
                    waitForLobbyReturn(45)
                    AS._awakenActDriftAt = nil
                    return
                end
            else
                AS._awakenActDriftAt = nil
            end
            setStatus(("Awakening - in %s %s Act %d for %s..."):format(
                af.mode or "?", af.world or "?", af.act or 0, af.item or unit.name))
        else
            setStatus("Awakening - in stage, waiting to return...")
            if not inBattle() and isStageCompleteScreenVisible() then
                leaveStage(true)
                waitForLobbyReturn(45)
            end
        end
        return
    end
    AS._awakenActDriftAt = nil

    refreshPlayerData()
    updateAwakenItemCacheFromData(getPlayerData(), unit.name)
    local af = Session.awakeningFarm
    if af and af.quest then pcall(claimReadySpecialTasks, af.quest) end
    claimReadySpecialTasks(SPECIAL_QUEST_ITEM[Session.awakeningFarm and Session.awakeningFarm.item or ""] or "")

    local missing = getMissingAwakeningReqs(unit.name)
    if missing == nil then
        refreshPlayerData()
        updateAwakenItemCacheFromData(getPlayerData(), unit.name)
        missing = getMissingAwakeningReqs(unit.name)
    end
    if missing == nil then
        setStatus("Awakening - refresh material counts in lobby.")
        task.wait(2)
        return
    end
    if #missing == 0 then
        local ok, err = tryAwakenUnit(unit)
        if ok then
            setStatus("Awakening complete for " .. unit.name)
            return "done"
        end
        setStatus("Awaken failed: " .. tostring(err))
        task.wait(2)
        return
    end

    local focusItem = Session.awakeningFarm and Session.awakeningFarm.item
    local target, itemName = pickNextAwakeningFarmTarget(unit.name, focusItem)

    if not target then
        setStatus("Awakening - no farm route for missing items.")
        return
    end

    if target.type == "ready" then
        tryAwakenUnit(unit)
        return
    end
    if target.type == "crafting" then
        setStatus("Need " .. target.item .. " from Crafting (manual).")
        notify("Awakening", target.item .. " requires Crafting — farm manually.", "error")
        task.wait(5)
        return
    end
    if target.type == "unknown" then
        setStatus("No farm location for " .. target.item)
        notify("Awakening", "Can't find farm map for " .. target.item, "error")
        task.wait(5)
        return
    end
    if target.type == "special_wait" then
        setStatus("Special quest " .. target.quest .. " — claim tasks / check progress.")
        claimReadySpecialTasks(target.quest)
        task.wait(3)
        return
    end

    local before = getItemCount(itemName) or 0
    refreshPlayerData()
    updateAwakenItemCacheFromData(getPlayerData(), unit.name)
    rememberAwakeningFarm(target, unit.name)
    local af = Session.awakeningFarm
    af.runs = (af.runs or 0) + 1
    af.actTransitions = 0
    af.farmTargetAct = target.act
    af.lastSeenAct = nil
    local snap = getMissingAwakeningReqs(unit.name)
    if type(snap) == "table" then
        af.reqSnapshot = copyMissingSnapshot(snap)
        af.unitName = unit.name
    else
        setStatus("Awakening - material counts unknown, not launching stage.")
        notify("Awakening", "Refresh in lobby before farming — counts unknown.", "error")
        forgetAwakeningFarm()
        task.wait(3)
        return
    end
    if flushSession then pcall(flushSession) end

    local soloNote = (target.solo and CONFIG.soloOnly) and " solo" or ""
    local needAmt = before
    local costTbl = getAwakeningCost(unit.name)
    if costTbl and costTbl[itemName] then
        needAmt = tonumber(costTbl[itemName]) or needAmt
    end
    for _, m in ipairs(snap or {}) do
        if m.item == itemName then needAmt = m.need break end
    end
    setStatus(("Awakening: need %s (%d/%d) — %s %s Act %d%s run #%d"):format(
        itemName, before, needAmt,
        target.mode, target.world, target.act, soloNote, af.runs))

    local prevSolo = CONFIG.soloOnly
    if target.solo then CONFIG.soloOnly = true end
    local ok, err = startMap(target.world, target.act, target.mode, target.difficulty or CONFIG.awakeningDifficulty)
    if target.solo then CONFIG.soloOnly = prevSolo end

    if not ok then
        setStatus("Awakening launch failed: " .. tostring(err))
        if af.targetIdx and af.targetCount and af.targetCount > 1 then
            af.targetIdx = (af.targetIdx % af.targetCount) + 1
            saveSession()
        end
        task.wait(2)
        return
    end

    waitForAwakeningRun(target)
    if inLobby() then
        refreshPlayerData()
        updateAwakenItemCacheFromData(getPlayerData(), unit.name)
        local snap = getMissingAwakeningReqs(unit.name)
        if type(snap) == "table" then
            af.reqSnapshot = copyMissingSnapshot(snap)
            af.unitName = unit.name
        end
    end
    if target.quest then claimReadySpecialTasks(target.quest) end

    local after = getItemCount(itemName) or before
    if after > before then
        af.stall = 0
        af.lastCount = after
        notify("Awakening", itemName .. " " .. after .. " (+" .. (after - before) .. ")", "success")
    else
        af.stall = (af.stall or 0) + 1
        if af.targetIdx and af.targetCount and af.stall >= CONFIG.awakeningStallRuns then
            af.targetIdx = (af.targetIdx % af.targetCount) + 1
            af.stall = 0
            setStatus(itemName .. " stalled — trying next map...")
        end
    end
    saveSession()
end

