-- ============================================================
-- Boot lock (prevents double GUI on teleport) — claim BEFORE bumping GEN
-- so a rejected duplicate boot does not kill the live instance's status thread.
-- ============================================================
local BOOT_LOCK_FILE = "AutoBounty_boot_lock.json"
local function canFileEarly()
    return (writefile and readfile and isfile) and true or false
end
local function claimScriptBoot()
    local now = tick()
    if _G.AB_BootAt and (now - _G.AB_BootAt) < 4 then return false end
    _G.AB_BootAt = now
    if not canFileEarly() then return true end
    local job = game.JobId
    if isfile(BOOT_LOCK_FILE) then
        local ok, raw = pcall(readfile, BOOT_LOCK_FILE)
        if ok and raw and raw ~= "" then
            local ok2, d = pcall(function()
                return game:GetService("HttpService"):JSONDecode(raw)
            end)
            if ok2 and type(d) == "table" and d.job == job and (now - (d.at or 0)) < 4 then
                return false
            end
        end
    end
    pcall(function()
        writefile(BOOT_LOCK_FILE, game:GetService("HttpService"):JSONEncode({
            job = job, at = now,
        }))
    end)
    return true
end
if not claimScriptBoot() then return end

