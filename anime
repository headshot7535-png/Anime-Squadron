-- ============================================================
-- Remote caching + safe calling
-- ============================================================
local _remotes = {}
local function getRemote(folder, name)
    local key = folder .. "/" .. name
    local cached = _remotes[key]
    if cached and cached.Parent then return cached end
    local f = ReplicatedStorage:FindFirstChild("Remotes")
    f = f and f:FindFirstChild(folder)
    local r = f and f:FindFirstChild(name)
    if r then _remotes[key] = r end
    return r
end

local _lastCall = 0
local function throttle()
    local dt = tick() - _lastCall
    if dt < CONFIG.actionCooldown then task.wait(CONFIG.actionCooldown - dt) end
    _lastCall = tick()
end

-- InvokeServer wrapper that preserves multi-returns: ok, serverSuccess, a, b
local function invokeR(folder, name, ...)
    local r = getRemote(folder, name)
    if not r then return false, "remote_missing" end
    throttle()
    local res = table.pack(pcall(function(...) return r:InvokeServer(...) end, ...))
    if not res[1] then return false, res[2] end
    return true, res[2], res[3], res[4]
end
local function fireR(folder, name, ...)
    local r = getRemote(folder, name)
    if not r then return false end
    throttle()
    return pcall(function(...) r:FireServer(...) end, ...)
end

-- ============================================================
-- Authoritative bounty data (server-pushed, exact rewards table)
-- ------------------------------------------------------------
-- The game's server sends the full bounty list to the client via the
-- Bounties.setup RemoteEvent, and accept/decline/claim/use_ticket all RETURN
-- the updated list. Each bounty carries: world, enemy, difficulty, progress,
-- required, active, rewards = { ["Trait Shards"] = qty, ... }. Reading this is
-- 100% reliable - no fragile GUI/icon parsing. We cache it on AB so it survives
-- re-execution within the same place; setup fires again on each lobby (re)join.
-- ============================================================
local function setBountyCache(bounties, tickets)
    if type(bounties) == "table" then AB.bountyData = bounties end
    if type(tickets) == "number" then AB.bountyTickets = tickets end
end
do
    local setupR = getRemote("Bounties", "setup")
    if setupR and setupR.OnClientEvent then
        addConn(setupR.OnClientEvent:Connect(function(bounties, tickets)
            setBountyCache(bounties, tickets)
        end))
    end
end

-- does a rewards table (or a list of reward names) contain a trait/reroll reward?
local function rewardsAreTrait(rewards)
    if type(rewards) ~= "table" then return false end
    for itemName in pairs(rewards) do
        local lc = tostring(itemName):lower()
        for _, kw in ipairs(CONFIG.traitKeywords) do
            if lc:find(kw, 1, true) then return true end
        end
    end
    return false
end

