    if not canFile() then return end
    if _sessionSaveQueued then return end
    _sessionSaveQueued = true
    addThread(function()
        task.wait(0.3)
        _sessionSaveQueued = false
        pcall(function() writefile(SESSION_FILE, HttpService:JSONEncode(Session)) end)
    end)
end
