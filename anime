-- Anti-AFK (Roblox idle kick + block game's AFK Chamber popup)
-- ============================================================
local function blockGameAFK()
    local hooked = {}

    local function neuterYes(btn)
        if not btn or not btn:IsA("GuiButton") then return end
        pcall(function()
            btn.Active = false
            btn.AutoButtonColor = false
        end)
        if hooked[btn] then return end
        hooked[btn] = true
        addConn(btn.Activated:Connect(function() end))
        addConn(btn.MouseButton1Click:Connect(function() end))
    end

    local function hideAfkGui(gui)
        if not gui then return end
        pcall(function() gui.Visible = false end)
        if not hooked[gui] then
            hooked[gui] = true
            if gui:IsA("GuiObject") then
                addConn(gui:GetPropertyChangedSignal("Visible"):Connect(function()
                    if CONFIG.antiAfk and gui.Visible then
                        pcall(function() gui.Visible = false end)
                    end
                end))
            end
        end
        for _, d in ipairs(gui:GetDescendants()) do
            if d.Name == "Yes" and d:IsA("GuiButton") then neuterYes(d) end
        end
    end

    local function scanMenus(menus)
        if not menus then return end
        hideAfkGui(menus:FindFirstChild("AFK Chamber"))
        local prompts = menus:FindFirstChild("Prompts")
        if prompts then
            hideAfkGui(prompts:FindFirstChild("AFK Chamber"))
            if not hooked[prompts] then
                hooked[prompts] = true
                addConn(prompts.ChildAdded:Connect(function(c)
                    if CONFIG.antiAfk and c.Name == "AFK Chamber" then hideAfkGui(c) end
                end))
            end
        end
    end

    scanMenus(getMenus())
    addConn(LP.ChildAdded:Connect(function(c)
        if c.Name == "PlayerGui" then
            task.defer(function() scanMenus(c:FindFirstChild("Menus")) end)
        end
    end))

    -- stop the game's own teleport_afk_chamber handler from firing
    pcall(function()
        local pm = require(LP.PlayerScripts.Client.Players)
        if type(pm) == "table" then
            pm.teleport_afk_chamber = function() end
        end
    end)
end

local function startAntiAFK()
    local VirtualUser = game:GetService("VirtualUser")
    local VIM = nil
    pcall(function() VIM = game:GetService("VirtualInputManager") end)

    blockGameAFK()

    -- 1) definitive backstop: reset idle the instant Roblox fires Idled
    addConn(LP.Idled:Connect(function()
        if not CONFIG.antiAfk then return end
        pcall(function()
            VirtualUser:CaptureController()
            VirtualUser:Button2Down(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
            task.wait(0.2)
            VirtualUser:Button2Up(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
        end)
    end))

    -- disable any built-in AFK / idle LocalScript (and watch for re-injection)
    local function disableAfkScripts(root)
        if not root then return end
        for _, d in ipairs(root:GetDescendants()) do
            if d:IsA("LocalScript") then
                local n = d.Name:lower()
                if n:find("afk") or n:find("idle") or n:find("kick") then
                    pcall(function() d.Disabled = true end)
                end
            end
        end
    end
    local ps = LP:FindFirstChild("PlayerScripts")
    if ps then
        addConn(ps.ChildAdded:Connect(function(c)
            if CONFIG.antiAfk and c:IsA("LocalScript") then
                local n = c.Name:lower()
                if n:find("afk") or n:find("idle") or n:find("kick") then
                    pcall(function() c.Disabled = true end)
                end
            end
        end))
    end

    -- 2) proactive keep-alive + re-block game AFK UI if it reappears
    addThread(function()
        while alive() do
            if CONFIG.antiAfk then
                blockGameAFK()
                disableAfkScripts(LP:FindFirstChild("PlayerScripts"))
                disableAfkScripts(LP:FindFirstChildOfClass("PlayerGui"))
                if VIM then
                    pcall(function()
                        local cam = workspace.CurrentCamera
                        local vp = cam and cam.ViewportSize or Vector2.new(200, 200)
                        local x, y = math.floor(vp.X * 0.5), math.floor(vp.Y * 0.5)
                        VIM:SendMouseMoveEvent(x, y, game)
                    end)
                end
            end
            task.wait(CONFIG.antiAfkInterval)
        end
    end)
end
