-- ============================================================
local QUEUE_ARM_FILE = "AutoBounty_queue_arm.json"
local LOCAL_SCRIPT   = "AutoBounty.lua"

local function getQueueFn()
    return (syn and syn.queue_on_teleport)
        or (fluxus and fluxus.queue_on_teleport)
        or queue_on_teleport
        or queueonteleport
        or (getgenv and (getgenv().queue_on_teleport or getgenv().queueonteleport))
        or (potassium and potassium.queue_on_teleport)
end

local function shouldInstallReconnect()
    return CONFIG.autoExecute or CONFIG.autoexecInstall
end

local function markQueueArmed()
    if not canFile() then return end
    pcall(function()
        writefile(QUEUE_ARM_FILE, HttpService:JSONEncode({
            ts    = os.time(),
            job   = game.JobId,
            place = game.PlaceId,
        }))
    end)
end

-- compact loader injected into queue_on_teleport (runs after teleport)
local function buildQueuePayload(url)
    return ([[
-- Auto Bounty teleport loader
if _G.AB_TP_BOOT and (tick() - _G.AB_TP_BOOT) < 8 then return end
_G.AB_TP_BOOT = tick()
local _u = %q
local function abGet(u)
    local ok, s = pcall(function() return game:HttpGet(u) end)
    if ok and s and #s > 500 then return s end
    local req = (syn and syn.request) or request or http_request or (http and http.request)
    if req then
        local ok2, r = pcall(function() return req({Url=u, Method="GET"}).Body end)
        if ok2 and r and #r > 500 then return r end
    end
end
task.defer(function()
    if not game:IsLoaded() then pcall(function() game.Loaded:Wait() end) end
    task.wait(0.6)
    local src
    if readfile and isfile and isfile("AutoBounty.lua") then
        local ok, loc = pcall(readfile, "AutoBounty.lua")
        if ok and loc and #loc > 1000 then src = loc end
    end
    if not src then src = abGet(_u) end
    if src then pcall(function() loadstring(src)() end) end
end)
]]):format(url)
end

local function buildReconnectLoader(url)
    local gid = tostring(game.GameId)
    return ([[
-- Auto Bounty reconnect loader (auto-generated)
if tostring(game.GameId) ~= %q then return end
if _G.AB_TP_BOOT and (tick() - _G.AB_TP_BOOT) < 8 then return end
local _u = %q
local function abGet(u)
    local ok, s = pcall(function() return game:HttpGet(u) end)
    if ok and s and #s > 500 then return s end
    local req = (syn and syn.request) or request or http_request or (http and http.request)
    if req then
        local ok2, r = pcall(function() return req({Url=u, Method="GET"}).Body end)
        if ok2 and r and #r > 500 then return r end
    end
end
task.defer(function()
    if not game:IsLoaded() then pcall(function() game.Loaded:Wait() end) end
    task.wait(0.8)
    if _G.AB_TP_BOOT and (tick() - _G.AB_TP_BOOT) < 8 then return end
    if _G.AB_BootAt and (tick() - _G.AB_BootAt) < 5 then return end
    local HS = game:GetService("HttpService")
    local arm = "AutoBounty_queue_arm.json"
    if readfile and isfile and isfile(arm) then
        local ok, r = pcall(readfile, arm)
