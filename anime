local function buildQueuePayload(url)
    return ([[
-- Anime Squadron teleport loader
if _G.AS_TP_BOOT and (tick() - _G.AS_TP_BOOT) < 8 then return end
_G.AS_TP_BOOT = tick()
local _u = %q
local function asGet(u)
    local ok, s = pcall(function() return game:HttpGet(u) end)
    if ok and s and #s > 500 then return s end
    local req = (syn and syn.request) or request or http_request or (http and http.request)
    if req then
        local ok2, r = pcall(function() return req({Url=u, Method="GET"}).Body end)
        if ok2 and r and #r > 500 then return r end
    end
end
%s
task.defer(function()
    if not game:IsLoaded() then pcall(function() game.Loaded:Wait() end) end
    task.wait(0.6)
    local src = loadLocalScript()
    if not src then src = asGet(_u) end
    if src then pcall(function() loadstring(src)() end) end
end)
]]):format(url, LOCAL_LOAD_SNIPPET)
end

local function buildReconnectLoader(url)
    local gid = tostring(game.GameId)
    return ([[
-- Anime Squadron reconnect loader (auto-generated)
if tostring(game.GameId) ~= %q then return end
if _G.AS_TP_BOOT and (tick() - _G.AS_TP_BOOT) < 8 then return end
local _u = %q
local function asGet(u)
    local ok, s = pcall(function() return game:HttpGet(u) end)
    if ok and s and #s > 500 then return s end
    local req = (syn and syn.request) or request or http_request or (http and http.request)
    if req then
        local ok2, r = pcall(function() return req({Url=u, Method="GET"}).Body end)
        if ok2 and r and #r > 500 then return r end
    end
end
%s
task.defer(function()
    if not game:IsLoaded() then pcall(function() game.Loaded:Wait() end) end
    task.wait(0.8)
    if _G.AS_TP_BOOT and (tick() - _G.AS_TP_BOOT) < 8 then return end
    if _G.AS_BootAt and (tick() - _G.AS_BootAt) < 5 then return end
    local HS = game:GetService("HttpService")
    for _, arm in ipairs({ "AnimeSquadron_queue_arm.json", "AutoBounty_queue_arm.json" }) do
        if readfile and isfile and isfile(arm) then
            local ok, r = pcall(readfile, arm)
            if ok and r and r ~= "" then
                local ok2, d = pcall(function() return HS:JSONDecode(r) end)
                if ok2 and d and d.job == game.JobId and os.time() - (tonumber(d.ts) or 0) < 20 then
                    return
                end
            end
        end
    end
    _G.AS_TP_BOOT = tick()
    local src = loadLocalScript()
    if not src then src = asGet(_u) end
    if src then pcall(function() loadstring(src)() end) end
end)
]]):format(gid, url, LOCAL_LOAD_SNIPPET)
end

local function installReconnectLoader()
    if not shouldInstallReconnect() then return false end
    local url = CONFIG.scriptUrl
    if type(url) ~= "string" or url == "" then return false end
    if type(writefile) ~= "function" then return false end
    local loader = buildReconnectLoader(url)
    local targets = {
        "autoexec/AnimeSquadron.lua",
        "autoexec/animesquadron.lua",
        "../autoexec/AnimeSquadron.lua",
        "../autoexec/animesquadron.lua",
        "auto_exec/AnimeSquadron.lua",
        "Autoexec/AnimeSquadron.lua",
        "autoexec/AutoBounty.lua",
        "../autoexec/AutoBounty.lua",
    }
    local wrote = false
    for _, path in ipairs(targets) do
        local ok = pcall(function()
            if type(makefolder) == "function" then
                local dir = path:match("^(.*)/")
                if dir and type(isfolder) == "function" and not isfolder(dir) then
                    pcall(makefolder, dir)
                end
            end
            writefile(path, loader)
        end)
        if ok then wrote = true end
    end
    AS._autoexecPaths = targets
    return wrote
end

local function uninstallReconnectLoader()
    if type(delfile) ~= "function" then return false end
    local any = false
    for _, path in ipairs(AS._autoexecPaths or {
        "autoexec/AnimeSquadron.lua", "autoexec/animesquadron.lua",
        "../autoexec/AnimeSquadron.lua", "../autoexec/animesquadron.lua",
        "auto_exec/AnimeSquadron.lua", "Autoexec/AnimeSquadron.lua",
        "autoexec/AutoBounty.lua", "../autoexec/AutoBounty.lua",
    }) do
        pcall(function()
            if type(isfile) == "function" and isfile(path) then
                delfile(path)
                any = true
            end
        end)
    end
    return any
end

armReexec = function()
    if not CONFIG.autoExecute then return false end
    local url = CONFIG.scriptUrl
    if type(url) ~= "string" or url == "" then return false end
    local q = getQueueFn()
    if not q then
        if not AS._queueWarned then
            AS._queueWarned = true
            warn("[Anime Squadron] queue_on_teleport missing — enable reconnect loader or use Misc > Re-arm")
        end
        return false
    end
    local now = tick()
    if AS._lastQueue and (now - AS._lastQueue) < 1.5 then return true end
    AS._lastQueue = now
    markQueueArmed()
    pcall(q, buildQueuePayload(url))
    return true
end

