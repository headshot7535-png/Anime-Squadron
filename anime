-- Hotbar.Info.World.TextLabel → "Eclipse (Before) - Act. <font ...>3</font>"
local function getHotbarStageInfo()
    local pg = LP:FindFirstChildOfClass("PlayerGui")
    local hotbar = pg and pg:FindFirstChild("Hotbar")
    local lbl = hotbar and hotbar:FindFirstChild("Info")
        and hotbar.Info:FindFirstChild("World")
        and hotbar.Info.World:FindFirstChild("TextLabel")
    if not lbl then return nil, nil end
    local text = lbl.Text or ""
    local actStr = text:match("Act%.%s*<[^>]+>(%d+)")
        or text:match("Act%.%s*(%d+)")
        or text:match("Act%s*(%d+)")
    local world = text:match("^(.-)%s*%-%s*Act")
    if world then world = world:gsub("^%s+", ""):gsub("%s+$", "") end
    return world, tonumber(actStr)
end

