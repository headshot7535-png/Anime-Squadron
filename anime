local function stripHtml(s)
    if type(s) ~= "string" then return "" end
    s = s:gsub("<[^>]+>", ""):gsub("&nbsp;", " "):gsub("%s+", " ")
    return (s:match("^%s*(.-)%s*$") or s)
end

local function coerceItemValue(raw)
    if raw == nil then return nil end
    local n = tonumber(raw)
    if n then return n end
    if type(raw) == "table" then
        n = tonumber(raw.amount or raw.count or raw.qty or raw.quantity or raw.n)
        if n then return n end
    end
    return nil
end

local function normalizeItemKey(name)
    if type(name) ~= "string" then return "" end
    return name:lower():gsub("%s+", "")
end

local function lookupExactInTable(tbl, key)
    if type(tbl) ~= "table" or type(key) ~= "string" then return nil end
    local keys = { key, string.lower(key) }
    for _, k in ipairs(keys) do
        if tbl[k] ~= nil then
            local n = coerceItemValue(tbl[k])
            return n ~= nil and n or 0
        end
    end
    return nil
end

local function parseCompactNumber(text)
    if type(text) ~= "string" or text == "" then return nil end
    local s = stripHtml(text):gsub(",", ""):gsub("%s+", "")
    local n = tonumber(s)
    if n then return math.floor(n) end
    local num, suffix = s:match("^([%d%.]+)([kKmMbB])$")
    num = tonumber(num)
    if not num then return nil end
    suffix = suffix:lower()
    if suffix == "k" then num = num * 1e3
    elseif suffix == "m" then num = num * 1e6
    elseif suffix == "b" then num = num * 1e9 end
    return math.floor(num)
end

-- Game hover/tooltip: items first, then stats (total owned vs session stat)
local function readItemsOnlyCount(data, itemName)
    if type(data) ~= "table" or type(itemName) ~= "string" or itemName == "" then return nil end
    local items = type(data.items) == "table" and data.items or nil
    if not items then return nil end
    local n = lookupExactInTable(items, itemName)
    if n ~= nil then return n end
    local want = normalizeItemKey(itemName)
    for k, v in pairs(items) do
        if type(k) == "string" and normalizeItemKey(k) == want then
            local num = coerceItemValue(v)
            return num ~= nil and num or 0
        end
    end
    return nil
end

local function readStatsOnlyCount(data, itemName)
    if type(data) ~= "table" or type(itemName) ~= "string" or itemName == "" then return nil end
    local stats = type(data.stats) == "table" and data.stats or nil
    if not stats then return nil end
    local n = lookupExactInTable(stats, itemName)
    if n ~= nil then return n end
    local want = normalizeItemKey(itemName)
    for k, v in pairs(stats) do
        if type(k) == "string" and normalizeItemKey(k) == want then
