-- Stage leave (Settings > Gameplay > Back To Lobby > Teleport during raids)
local function guiText(node)
    if not node then return "" end
    if node:IsA("TextLabel") or node:IsA("TextButton") then return node.Text or "" end
    return ""
end

local function guiTextDeep(node)
    if not node then return "" end
    local direct = guiText(node)
    if direct ~= "" then return direct end
    for _, d in ipairs(node:GetDescendants()) do
        if d:IsA("TextLabel") or d:IsA("TextButton") then
            local t = d.Text
            if t and t ~= "" then return t end
        end
    end
    return ""
end

local function invokeGui(btn)
    if not btn or not btn.Parent then return false end
    local targets = { btn }
    local rb = btn:FindFirstChild("RealButton")
    if rb then targets[#targets + 1] = rb end
    local fired = false
    if getconnections then
        for _, t in ipairs(targets) do
            for _, sig in ipairs({ "Activated", "MouseButton1Click" }) do
                local ev = t[sig]
                if ev then
                    for _, conn in ipairs(getconnections(ev)) do
                        if conn.Function then
                            fired = pcall(conn.Function) or fired
                        end
                    end
                end
            end
        end
    end
    if not fired and firesignal then
        for _, t in ipairs(targets) do
            fired = pcall(firesignal, t.Activated) or fired
            fired = pcall(firesignal, t.MouseButton1Click) or fired
        end
    end
    return fired
end

local function clickGui(btn)
    return invokeGui(btn)
end

