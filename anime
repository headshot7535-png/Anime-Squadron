                        end
                    end
                end
            end
        end
        return nil
    end)
    if okHover then take(hoverNow) end

    -- 2. Items bank (util.data + lobby snapshot + bank cache) — never session stats
    local utilData = getLiveUtilityData()
    if utilData then
        take(readItemsOnlyCount(utilData, itemName))
        mergeItemsBankCache(utilData.items)
    end
    take(readBestItemsBankCount(itemName))
    if AS.awakenItemCache and AS.awakenItemCache[itemName] ~= nil then
        take(AS.awakenItemCache[itemName])
    end
    if Session.awakenItemCache and Session.awakenItemCache[itemName] ~= nil then
        take(Session.awakenItemCache[itemName])
    end

    -- 3. Stats fallback only when no bank/hover count found (session drops)
    if best == nil then
        local matchData = AS._matchPlayerData
        if matchData then take(readStatsOnlyCount(matchData, itemName)) end
        if utilData then take(readStatsOnlyCount(utilData, itemName)) end
        local fresh = refreshMatchPlayerData(false)
        if fresh then take(readStatsOnlyCount(fresh, itemName)) end
    end

    return best
end

