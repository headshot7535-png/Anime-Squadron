local function updateAwakenItemCacheFromData(data, unitName)
    if type(data) ~= "table" then return end
    mergeItemsBankCache(data.items)
    local cost = unitName and getAwakeningCost(unitName)
    if not cost then return end
    AS.awakenItemCache = AS.awakenItemCache or {}
    Session.awakenItemCache = Session.awakenItemCache or {}
    for item in pairs(cost) do
        local n = readItemsOnlyCount(data, item)
        if n == nil then n = readBestItemsBankCount(item) end
        if n == nil then n = readInventoryItemCount(data, item) end
        if n == nil then n = readLiveItemCount(item, data) end
        AS.awakenItemCache[item] = n
        Session.awakenItemCache[item] = n
    end
    saveSession()
end

local function bumpAwakenItemCache(itemName, amount)
    if type(itemName) ~= "string" or itemName == "" then return end
    amount = tonumber(amount) or 0
    restoreAwakenItemCache()
    AS.awakenItemCache = AS.awakenItemCache or {}
    Session.awakenItemCache = Session.awakenItemCache or {}
    local prev = tonumber(AS.awakenItemCache[itemName]) or 0
    if amount > prev then
        AS.awakenItemCache[itemName] = amount
        Session.awakenItemCache[itemName] = amount
        saveSession()
    end
end

local function getFarmItemNeed(itemName)
    if type(itemName) ~= "string" or itemName == "" then return nil end
    local af = Session.awakeningFarm
    if af and type(af.reqSnapshotFull) == "table" then
        for _, m in ipairs(af.reqSnapshotFull) do
            if m.item == itemName then
                local need = tonumber(m.need)
                if need and need > 0 then return need end
            end
        end
    end
    if af and type(af.reqSnapshot) == "table" then
        for _, m in ipairs(af.reqSnapshot) do
            if m.item == itemName then
                local need = tonumber(m.need)
                if need and need > 0 then return need end
            end
        end
    end
    local unitName = (af and af.unitName) or CONFIG.awakeningUnit
    local cost = unitName and getAwakeningCost(unitName)
    if type(cost) == "table" then
        local need = tonumber(cost[itemName])
        if need and need > 0 then return need end
    end
    return nil
end

local function syncReqSnapshotHave(itemName, have)
    local af = Session.awakeningFarm
    if not af then return end
    have = tonumber(have) or 0
    for _, list in ipairs({ af.reqSnapshot, af.reqSnapshotFull }) do
        if type(list) == "table" then
            for _, m in ipairs(list) do
                if m.item == itemName then
                    m.have = have
                    m.deficit = math.max(0, (tonumber(m.need) or 0) - have)
                end
            end
        end
    end
end

local function syncAwakenItemCount(itemName, live)
    live = tonumber(live)
    if live == nil then return nil end
    restoreAwakenItemCache()
    local hover = readCachedHoverCount(itemName)
    if hover and hover > live then live = hover end
    local bank = readBestItemsBankCount(itemName)
    if bank and bank > live then live = bank end
    local utilData = getLiveUtilityData()
    if utilData then
        local utilBank = readItemsOnlyCount(utilData, itemName)
        if utilBank and utilBank > live then live = utilBank end
    end
    local prev = tonumber(AS.awakenItemCache and AS.awakenItemCache[itemName])
        or tonumber(Session.awakenItemCache and Session.awakenItemCache[itemName])
    if prev and prev > live then live = prev end
    if not prev or live ~= prev then
        bumpAwakenItemCache(itemName, live)
    end
    syncReqSnapshotHave(itemName, live)
    return live
end

local function getItemCount(itemName)
    restoreAwakenItemCache()
    if inPlayArea() then
        local live = readMatchItemCount(itemName)
        if live ~= nil then
            return syncAwakenItemCount(itemName, live)
        end
        local hover = readCachedHoverCount(itemName)
        if hover ~= nil then
            return syncAwakenItemCount(itemName, hover)
        end
        local bank = readBestItemsBankCount(itemName)
        if bank ~= nil then
            return syncAwakenItemCount(itemName, bank)
        end
        local utilData = getLiveUtilityData()
        if utilData then
            live = readItemsOnlyCount(utilData, itemName)
            if live ~= nil then
                return syncAwakenItemCount(itemName, live)
            end
        end
        if AS.awakenItemCache and AS.awakenItemCache[itemName] ~= nil then
            return syncAwakenItemCount(itemName, AS.awakenItemCache[itemName])
        end
        if Session.awakenItemCache and Session.awakenItemCache[itemName] ~= nil then
            return syncAwakenItemCount(itemName, Session.awakenItemCache[itemName])
        end
        local matchData = AS._matchPlayerData
        if matchData then
            live = readStatsOnlyCount(matchData, itemName)
            if live ~= nil then
                return syncAwakenItemCount(itemName, live)
            end
        end
        return nil
    end
    local live = readLiveItemCount(itemName)
    if inLobby() then
        AS.awakenItemCache = AS.awakenItemCache or {}
        Session.awakenItemCache = Session.awakenItemCache or {}
        AS.awakenItemCache[itemName] = live
        Session.awakenItemCache[itemName] = live
        saveSession()
    end
    return live
end

local function scanAwakenableCharacterNames()
    if AWAKENABLE_NAMES then return AWAKENABLE_NAMES end
