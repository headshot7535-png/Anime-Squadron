local _conns, _threads = {}, {}
local function addConn(c) if c then table.insert(_conns, c) end end
local function addThread(fn) local t = task.spawn(fn); table.insert(_threads, t); return t end
local function cleanup()
    for _, c in ipairs(_conns) do pcall(function() c:Disconnect() end) end
    for _, t in ipairs(_threads) do pcall(function() task.cancel(t) end) end
    _conns, _threads = {}, {}
end
if _G.CombatProbeCleanup then pcall(_G.CombatProbeCleanup) end
_G.CombatProbeCleanup = function() cleanup() end

-- ============================================================
-- Logging
-- ============================================================
local lineCount = 0
local logBuf = {}
local lastFlush = 0

local function canFile()
    return writefile and readfile and isfile and appendfile
end

local function flushLog(force)
    if not canFile() or #logBuf == 0 then return end
    if not force and (tick() - lastFlush) < 2 then return end
    local chunk = table.concat(logBuf, "\n") .. "\n"
    logBuf = {}
    lastFlush = tick()
    pcall(function()
        if isfile(LOG_FILE) then appendfile(LOG_FILE, chunk)
        else writefile(LOG_FILE, chunk) end
    end)
end

local function log(tag, msg)
    if lineCount >= MAX_LINES then return end
    lineCount = lineCount + 1
    local line = ("[%s] [%s] %s"):format(os.date("%H:%M:%S"), tag, tostring(msg))
    if VERBOSE then print(line) end
    logBuf[#logBuf + 1] = line
    if #logBuf >= 25 then flushLog(true) end
end

pcall(function()
    if canFile() then
        writefile(LOG_FILE, ("=== Combat Probe v%s started %s ===\n"):format(VERSION, os.date()))
    end
end)

-- ============================================================
-- Safe serialization (for remote payloads / tables)
-- ============================================================
local seen = {}
local function keyLess(a, b)
    local ta, tb = typeof(a), typeof(b)
    if ta == "number" and tb == "number" then return a < b end
    return tostring(a) < tostring(b)
end

local function ser(v, depth)
    depth = tonumber(depth) or 0
    if depth > 10 then return "\"<maxdepth>\"" end
    local tv = typeof(v)
    if tv == "nil" then return "null"
    elseif tv == "boolean" or tv == "number" then return tostring(v)
    elseif tv == "string" then
        if #v > 300 then return "\"" .. v:sub(1, 300) .. "…\"" end
        return "\"" .. v:gsub("[\r\n\"]", " ") .. "\""
    elseif tv == "Instance" then
        return "\"@" .. v:GetFullName() .. "\""
    elseif tv == "Vector3" then
        return string.format("{\"x\":%.2f,\"y\":%.2f,\"z\":%.2f}", v.X, v.Y, v.Z)
    elseif tv == "CFrame" then
        local p = v.Position
        return string.format("{\"cf\":%.1f,%.1f,%.1f}", p.X, p.Y, p.Z)
    elseif tv == "EnumItem" then return "\"" .. tostring(v) .. "\""
    elseif tv == "table" then
        if seen[v] then return "\"<cycle>\"" end
        seen[v] = true
        local keys = {}
        local n = 0
        for k in pairs(v) do
            n = n + 1
            keys[n] = k
            if n > 40 then break end
        end
        table.sort(keys, keyLess)
        local parts = {}
        local arr = true
        for i = 1, n do if keys[i] ~= i then arr = false break end end
        if arr then
            for i = 1, math.min(n, 30) do
                parts[i] = ser(v[i], depth + 1)
            end
            seen[v] = nil
            return "[" .. table.concat(parts, ",") .. "]"
        end
        for _, k in ipairs(keys) do
            parts[#parts + 1] = ser(k, depth + 1) .. ":" .. ser(v[k], depth + 1)
        end
        seen[v] = nil
        return "{" .. table.concat(parts, ",") .. "}"
    end
    return "\"" .. tv .. "\""
end

local function serArgs(...)
    seen = {}
    local n = select("#", ...)
    local parts = {}
    for i = 1, n do
        local ok, s = pcall(ser, select(i, ...), 0)
        parts[i] = ok and s or "\"<ser err>\""
    end
    return table.concat(parts, " | ")
end

local COMBAT_KEYS = {
    "damage", "dmg", "dps", "health", "hp", "owner", "attacker", "source",
    "target", "killer", "deal", "dealt", "hit", "attack", "combat", "unit",
    "ally", "allies", "enemy", "enemies", "id", "name", "type", "progress",
}

local function scorePayload(s)
    local lower = string.lower(s)
    local score = 0
    for _, k in ipairs(COMBAT_KEYS) do
        if lower:find(k, 1, true) then score = score + 1 end
    end
    return score
end

local function summarizeTable(t, label)
    if type(t) ~= "table" then return end
    local hits = {}
    local function walk(tbl, path, d)
        if d > 4 or type(tbl) ~= "table" then return end
        for k, v in pairs(tbl) do
            local kn = string.lower(tostring(k))
            for _, ck in ipairs(COMBAT_KEYS) do
                if kn:find(ck, 1, true) then
                    hits[#hits + 1] = path .. tostring(k) .. "=" .. ser(v, 2)
                    break
                end
            end
            if type(v) == "table" then walk(v, path .. tostring(k) .. ".", d + 1) end
        end
    end
    walk(t, "", 0)
    if #hits > 0 then
        log("PAYLOAD", label .. " combat fields: " .. table.concat(hits, " ; "))
    end
end

-- ============================================================
-- 1) Remote sniffer — hook every RemoteEvent under ReplicatedStorage.Remotes
-- ============================================================
local hookedRemotes = {}
local remoteHits = {}

local function hookRemote(r, path)
    if hookedRemotes[r] then return end
    hookedRemotes[r] = path
    if not r:IsA("RemoteEvent") then return end
    addConn(r.OnClientEvent:Connect(function(...)
        pcall(function()
            local payload = serArgs(...)
            local score = scorePayload(payload)
            remoteHits[path] = (remoteHits[path] or 0) + 1
            local deep = path:find("fight_hit", 1, true) or path:find("Characters/update", 1, true)
            local limit = deep and 4000 or 1200
            local maxLog = deep and 25 or 5
            if score >= 2 or remoteHits[path] <= maxLog then
                log("REMOTE", path .. " #" .. remoteHits[path] .. " score=" .. score .. " :: " .. payload:sub(1, limit))
            end
            for i = 1, select("#", ...) do
                local a = select(i, ...)
                if type(a) == "table" then summarizeTable(a, path) end
            end
        end)
    end))
end

local function scanRemotes(root, prefix)
    prefix = prefix or ""
    for _, ch in ipairs(root:GetChildren()) do
        local p = prefix .. ch.Name
        if ch:IsA("RemoteEvent") or ch:IsA("RemoteFunction") then
            hookRemote(ch, p)
        end
        scanRemotes(ch, p .. "/")
    end
end

local remotesFolder = RS:FindFirstChild("Remotes")
if remotesFolder then
    scanRemotes(remotesFolder)
    log("INIT", "Hooked RemoteEvents under ReplicatedStorage.Remotes")
    addConn(remotesFolder.DescendantAdded:Connect(function(d)
        if d:IsA("RemoteEvent") then
            local path = d:GetFullName():gsub("ReplicatedStorage%.Remotes%.", ""):gsub("%.", "/")
            hookRemote(d, path)
            log("INIT", "New remote: " .. path)
        end
    end))
else
    log("WARN", "ReplicatedStorage.Remotes not found")
end

