            af.mode, af.world, af.act or 0, af.difficulty or CONFIG.awakeningDifficulty, af.item or "?", leaveHint))
    elseif af and af.quest then
        setLabel(statusLabels.awakenFarm, "Special quest: " .. tostring(af.quest))
    elseif not CONFIG.autoAwakening then
        setLabel(statusLabels.awakenFarm, "Farm target: auto awakening OFF")
    elseif challengesTakePriority() and countPendingChallenges() > 0 then
        setLabel(statusLabels.awakenFarm, ("Waiting: %d challenge(s) first"):format(countPendingChallenges()))
    elseif challengesTakePriority() and Session.challengeFarm then
        setLabel(statusLabels.awakenFarm, "Waiting: stale challenge session clearing...")
    elseif type(missing) == "table" and #missing > 0 then
        setLabel(statusLabels.awakenFarm, getAwakeningFarmPreview(unit.name))
    else
        setLabel(statusLabels.awakenFarm, "Farm target: ready to awaken")
    end
    local n = #getOwnedAwakenableUnits()
    if statusLabels.awakenCount then
        setLabel(statusLabels.awakenCount, ("Awakenable units found: %d%s"):format(
            n, (not inLobby() and n > 0) and " (cached)" or ""))
    end
end

local function cycleAwakenUnit(dir)
    local units = getOwnedAwakenableUnits()
    if #units == 0 then return end
    local names = {}
    for _, u in ipairs(units) do names[#names + 1] = u.name end
    local cur = table.find(names, CONFIG.awakeningUnit) or 1
    cur = cur + (dir or 1)
    if cur < 1 then cur = #names end
    if cur > #names then cur = 1 end
    CONFIG.awakeningUnit = names[cur]
    saveSettings()
    if awakenUnitInput then pcall(function() awakenUnitInput.Set(CONFIG.awakeningUnit) end) end
    pcall(refreshAwakeningLabels)
end

local function refreshAwakenUnitDropdown()
    local units = getOwnedAwakenableUnits()
    local names = {}
    for _, u in ipairs(units) do names[#names + 1] = u.name end

    if #names == 0 then
        setLabel(statusLabels.awakenList, "Available: none (open Characters menu in lobby, then Refresh)")
    else
        if CONFIG.awakeningUnit == "" then
            CONFIG.awakeningUnit = names[1]
            saveSettings()
        end
        local selectedOk = table.find(names, CONFIG.awakeningUnit) ~= nil
            or (AS.awakenUnitByName and AS.awakenUnitByName[CONFIG.awakeningUnit] ~= nil)
        local listText = "Available: " .. table.concat(names, ", ")
        if not selectedOk and CONFIG.awakeningUnit ~= "" then
            listText = listText .. " | Selected: " .. CONFIG.awakeningUnit .. " (cached)"
        end
        setLabel(statusLabels.awakenList, listText)
        if awakenUnitInput then
            pcall(function() awakenUnitInput.Set(CONFIG.awakeningUnit) end)
        end
    end
    pcall(refreshAwakeningLabels)
    return #units
end

local function refreshChallengeLabels()
    local dayT, halfT = getChallengeTimers()
    setLabel(statusLabels.chTimers, ("Reset timers: Daily %s | Regular %s")
        :format(fmtChallengeTimer(dayT), fmtChallengeTimer(halfT)))

    local chs = getRotatingChallenges()
    syncChallengeDoneFlags(chs)

    for _, key in ipairs(CHALLENGE_ORDER) do
        local lbl = (key == "1d") and statusLabels.chDaily or statusLabels.chRegular
        if lbl then
        local name = CHALLENGE_NAMES[key] or key
        local ch = chs[key]
        local enabled = isChallengeEnabled(key)
        if not enabled then
            setLabel(lbl, name .. ": disabled")
        elseif type(ch) == "table" and ch.world then
            local done = isChallengeMarkedDone(key) or scanChallengeGuiCompleted(key)
            setLabel(lbl, name .. ": " .. ch.world .. " Act " .. tostring(ch.act)
                .. (done and " (already completed)" or " (ready)"))
        else
            setLabel(lbl, name .. ": done / on cooldown")
        end
        end
    end
end

