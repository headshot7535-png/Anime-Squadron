-- ============================================================
-- Teleport persistence (re-exec after returning to lobby)
-- ============================================================
local function getQueueFn()
    return (syn and syn.queue_on_teleport)
        or (fluxus and fluxus.queue_on_teleport)
        or queue_on_teleport
        or queueonteleport
        or (getgenv and getgenv().queue_on_teleport)
end
armReexec = function()
    if not CONFIG.autoExecute then return end
    local url = CONFIG.scriptUrl
    if type(url) ~= "string" or url == "" then return end
    local q = getQueueFn()
    if not q then return false end
    -- guard against double-queue within the same place
    local now = tick()
    if AB._lastQueue and (now - AB._lastQueue) < 3 then return true end
    AB._lastQueue = now
    pcall(q, ([[loadstring(game:HttpGet("%s"))()]]):format(url))
    return true
end
-- OnTeleport: compare by NAME string so a missing Enum member can't crash us
addConn(LP.OnTeleport:Connect(function(state)
    local name = (typeof(state) == "EnumItem") and state.Name or tostring(state)
    if name == "Started" or name == "RequestedByServer" or name == "InProgress" then
        pcall(armReexec)
    end
end))
armReexec()

-- ============================================================
-- Anti-AFK (prevents the 20-minute idle kick)
-- ============================================================
local function startAntiAFK()
    local VirtualUser = game:GetService("VirtualUser")
    local VIM = nil
    pcall(function() VIM = game:GetService("VirtualInputManager") end)

    -- 1) definitive backstop: reset idle the instant Roblox fires Idled
    addConn(LP.Idled:Connect(function()
        if not CONFIG.antiAfk then return end
        pcall(function()
            VirtualUser:CaptureController()
            VirtualUser:Button2Down(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
            task.wait(0.2)
            VirtualUser:Button2Up(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
        end)
    end))

    -- disable any built-in AFK / idle LocalScript (and watch for re-injection)
    local function disableAfkScripts(root)
        if not root then return end
        for _, d in ipairs(root:GetDescendants()) do
            if d:IsA("LocalScript") then
                local n = d.Name:lower()
                if n:find("afk") or n:find("idle") then
                    pcall(function() d.Disabled = true end)
                end
            end
        end
    end
    local ps = LP:FindFirstChild("PlayerScripts")
    if ps then
        addConn(ps.ChildAdded:Connect(function(c)
            if CONFIG.antiAfk and c:IsA("LocalScript") then
                local n = c.Name:lower()
                if n:find("afk") or n:find("idle") then
                    pcall(function() c.Disabled = true end)
                end
            end
        end))
    end

    -- 2) proactive keep-alive: send a harmless input (VirtualInputManager
    --    preferred per its broader detection coverage) + re-disable afk scripts
    addThread(function()
        while alive() do
            if CONFIG.antiAfk then
                disableAfkScripts(LP:FindFirstChild("PlayerScripts"))
                disableAfkScripts(LP:FindFirstChildOfClass("PlayerGui"))
                if VIM then
                    pcall(function()
                        local cam = workspace.CurrentCamera
                        local vp = cam and cam.ViewportSize or Vector2.new(200, 200)
                        local x, y = math.floor(vp.X * 0.5), math.floor(vp.Y * 0.5)
                        VIM:SendMouseMoveEvent(x, y, game)
                    end)
                end
            end
            task.wait(CONFIG.antiAfkInterval)
        end
    end)
end
startAntiAFK()

-- ============================================================
-- Live in-stage elimination tracker (Story/battle place)
-- The bounty board doesn't exist in Story mode, so we count the bounty enemy's
-- deaths directly: any Model named like the enemy with a Humanoid that Dies = 1
-- kill. This is a live readout; the server still credits the real bounty count
-- (reconciled in the lobby). Solo room => every kill is yours.
-- ============================================================
local function startKillTracker()
    addThread(function()
        local tracking = false
        local conns = {}
        local function stop()
            for _, c in ipairs(conns) do pcall(function() c:Disconnect() end) end
            conns = {}
            tracking = false
        end
        local function norm(s) return tostring(s):lower():gsub("%s+", "") end
        -- in this game enemies are Models cloned into workspace.Characters, tagged
        -- with attribute type=="Enemies" (allies are "Allies"); a kill Destroys the
        -- model -> fires ChildRemoved. We count those, filtered to the bounty enemy.
        while alive() do
            local battle = not inLobby()
            local enemy = Session.bounty and Session.bounty.enemy
            if CONFIG.liveKills and battle and enemy and CONFIG.enabled then
                if not tracking then
                    tracking = true
                    Session.runKills = 0
                    local target = norm(enemy)
                    local chars = workspace:FindFirstChild("Characters")
                    local function isTargetEnemy(m)
                        if not (m and m:IsA("Model")) then return false end
                        local ok, t = pcall(function() return m:GetAttribute("type") end)
                        if not ok or t ~= "Enemies" then return false end
                        return norm(m.Name) == target
                    end
                    local function bind(container)
                        if not container then return end
                        conns[#conns + 1] = container.ChildRemoved:Connect(function(m)
                            if isTargetEnemy(m) then
                                Session.runKills = (Session.runKills or 0) + 1
                            end
                        end)
                    end
                    bind(chars)
                    -- if Characters folder isn't there yet, wait for it then bind
                    if not chars then
                        conns[#conns + 1] = workspace.ChildAdded:Connect(function(c)
                            if c.Name == "Characters" then bind(c) end
                        end)
                    end

                    -- diagnostic: after a few seconds, if we found no enemy of the
                    -- target name, print what enemies ARE present so we can verify
                    task.delay(6, function()
                        if not alive() or inLobby() then return end
                        local c = workspace:FindFirstChild("Characters")
                        if not c then
                            warn("[Auto Bounty] workspace.Characters not found in battle.")
                            return
                        end
                        local seen, names, found = {}, {}, false
                        for _, m in ipairs(c:GetChildren()) do
                            local ok, t = pcall(function() return m:GetAttribute("type") end)
                            if ok and t == "Enemies" and m:IsA("Model") then
                                if norm(m.Name) == target then found = true end
                                if not seen[m.Name] then
                                    seen[m.Name] = true
                                    names[#names + 1] = m.Name
                                end
                            end
                        end
                        if not found then
                            warn("[Auto Bounty] No enemy named '" .. tostring(enemy) ..
                                "'. Enemies currently present: " ..
                                (#names > 0 and table.concat(names, ", ") or "(none yet)"))
                        end
                    end)
                end
                -- optional: bail out of the stage as soon as the target is met
                if CONFIG.leaveWhenDone and Session.bounty and Session.bounty.required then
                    local total = (Session.bounty.progress or 0) + (Session.runKills or 0)
                    if total >= Session.bounty.required then
                        setStatus("Target reached in-stage - leaving to claim...")
                        pcall(function() fireR("Play", "leave") end)
                    end
                end
            elseif tracking and (inLobby() or not enemy) then
                stop()
            end
            task.wait(1)
        end
    end)
end
startKillTracker()

