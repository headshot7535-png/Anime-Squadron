    if data.enabled ~= nil then CONFIG.enabled = data.enabled == true end
    CONFIG.act              = math.clamp(tonumber(data.act) or CONFIG.act, 1, 7)
    if data.difficulty == "Normal" or data.difficulty == "Hard" then CONFIG.difficulty = data.difficulty end
    CONFIG.soloOnly         = data.soloOnly == true
    CONFIG.declineNonTrait  = data.declineNonTrait == true
    CONFIG.useRefreshTicket = data.useRefreshTicket == true
    CONFIG.stopWhenDone     = data.stopWhenDone == true
    -- default these to true when missing from an older settings file
    if data.autoExecute ~= nil then CONFIG.autoExecute = data.autoExecute == true end
    if data.autoexecInstall ~= nil then CONFIG.autoexecInstall = data.autoexecInstall == true end
    if data.antiAfk ~= nil then CONFIG.antiAfk = data.antiAfk == true end
    if data.liveKills ~= nil then CONFIG.liveKills = data.liveKills == true end
    if data.leaveWhenDone ~= nil then CONFIG.leaveWhenDone = data.leaveWhenDone == true end
    if data.dailyTraitFarm ~= nil then CONFIG.dailyTraitFarm = data.dailyTraitFarm == true end
    if data.bountyFarm ~= nil then CONFIG.bountyFarm = data.bountyFarm == true end
    if data.dailyDifficulty == "Normal" or data.dailyDifficulty == "Hard" then
        CONFIG.dailyDifficulty = data.dailyDifficulty
    end
    if data.dailyStopWhenDone ~= nil then CONFIG.dailyStopWhenDone = data.dailyStopWhenDone == true end
    if type(data.dailyPriorityOrder) == "table" then CONFIG.dailyPriorityOrder = data.dailyPriorityOrder end
    if type(data.dailyPriorityEnabled) == "table" then
        for k, v in pairs(data.dailyPriorityEnabled) do
            CONFIG.dailyPriorityEnabled[k] = v == true
        end
    end
    if data.dpsMeter ~= nil then CONFIG.dpsMeter = data.dpsMeter == true end
    if type(data.scriptUrl) == "string" and data.scriptUrl ~= "" then CONFIG.scriptUrl = data.scriptUrl end
end
