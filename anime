-- ============================================================
-- Remote caching + safe calling
-- ============================================================
local _remotes = {}
local function getRemote(folder, name)
    local key = folder .. "/" .. name
    local cached = _remotes[key]
    if cached and cached.Parent then return cached end
    local f = ReplicatedStorage:FindFirstChild("Remotes")
    f = f and f:FindFirstChild(folder)
    local r = f and f:FindFirstChild(name)
    if r then _remotes[key] = r end
    return r
end

local _lastCall = 0
local function throttle()
    local dt = tick() - _lastCall
    if dt < CONFIG.actionCooldown then task.wait(CONFIG.actionCooldown - dt) end
    _lastCall = tick()
end

-- InvokeServer wrapper that preserves multi-returns: ok, serverSuccess, a, b
local function invokeR(folder, name, ...)
    local r = getRemote(folder, name)
    if not r then return false, "remote_missing" end
    throttle()
    local res = table.pack(pcall(function(...) return r:InvokeServer(...) end, ...))
    if not res[1] then return false, res[2] end
    return true, res[2], res[3], res[4]
end
local function fireR(folder, name, ...)
    local r = getRemote(folder, name)
    if not r then return false end
    throttle()
    return pcall(function(...) r:FireServer(...) end, ...)
end

-- ============================================================
-- Authoritative bounty data (server-pushed, exact rewards table)
-- ------------------------------------------------------------
-- The game's server sends the full bounty list to the client via the
-- Bounties.setup RemoteEvent, and accept/decline/claim/use_ticket all RETURN
-- the updated list. Each bounty carries: world, enemy, difficulty, progress,
-- required, active, rewards = { ["Trait Shards"] = qty, ... }. Reading this is
-- 100% reliable - no fragile GUI/icon parsing. We cache it on AB so it survives
-- re-execution within the same place; setup fires again on each lobby (re)join.
-- ============================================================
local function setBountyCache(bounties, tickets)
    if type(bounties) == "table" then AB.bountyData = bounties end
    if type(tickets) == "number" then AB.bountyTickets = tickets end
end
do
    local setupR = getRemote("Bounties", "setup")
    if setupR and setupR.OnClientEvent then
        addConn(setupR.OnClientEvent:Connect(function(bounties, tickets)
            setBountyCache(bounties, tickets)
        end))
    end
end

-- does a rewards table (or a list of reward names) contain a trait/reroll reward?
local function rewardsAreTrait(rewards)
    if type(rewards) ~= "table" then return false end
    for itemName in pairs(rewards) do
        local lc = tostring(itemName):lower()
        for _, kw in ipairs(CONFIG.traitKeywords) do
            if lc:find(kw, 1, true) then return true end
        end
    end
    return false
end

-- ============================================================
-- GUI helpers / place detection
-- ============================================================
local function getMenus()
    local pg = LP:FindFirstChildOfClass("PlayerGui")
    return pg and pg:FindFirstChild("Menus")
end
local function getBountyGui()
    local m = getMenus()
    return m and m:FindFirstChild("Bounty")
end
-- We're "in the lobby" if the Bounty menu exists (battle place won't have it)
local function inLobby()
    return getBountyGui() ~= nil
end

-- the game's own bounty client module (calls remotes AND refreshes the GUI)
local _bModule
local function ensureModule()
    if _bModule then return _bModule end
    local ok, m = pcall(function()
        return require(LP.PlayerScripts.Client.Bounties)
    end)
    if ok and type(m) == "table" then _bModule = m end
    return _bModule
end
-- best-effort refresh of the game's own bounty GUI after a direct remote call
local function refreshGUI(bounties, tickets)
    if not bounties then return end
    local m = ensureModule()
    if m and m.setup then pcall(m.setup, bounties, tickets) end
end

-- ============================================================
-- Bounty reading (parse the live GUI)
-- ============================================================
local function parseProgress(text)
    if type(text) ~= "string" then return 0, 0 end
    local p, r = text:match(">%s*(%d+)%s*</font>%s*/%s*(%d+)")
    if not p then
        local clean = text:gsub("<[^>]->", "")
        p, r = clean:match("(%d+)%s*/%s*(%d+)")
    end
    return tonumber(p) or 0, tonumber(r) or 0
end

-- returns a list: { {id, world, progress, required, active, complete, trait}, ... }
local _diagBounties = false

-- Build the bounty list straight from the authoritative server data when we have
-- it (exact rewards). Returns nil if we have no cached data yet.
local function readBountiesFromData()
    local data = AB.bountyData
    if type(data) ~= "table" then return nil end
    local out = {}
    for k, b in pairs(data) do
        if type(b) == "table" then
            local entry = {
                id       = tonumber(k) or k,
                world    = b.world,
                enemy    = b.enemy,
                progress = tonumber(b.progress) or 0,
                required = tonumber(b.required) or 0,
                active   = b.active == true,
                rewards  = b.rewards,
                rewardNames = {},
            }
            for itemName in pairs(b.rewards or {}) do
                entry.rewardNames[#entry.rewardNames + 1] = tostring(itemName)
            end
            entry.trait = rewardsAreTrait(b.rewards)
            entry.complete = (entry.required > 0) and (entry.progress >= entry.required)
            out[#out + 1] = entry
        end
    end
    if #out == 0 then return nil end

    -- one-time diagnostic if the (exact) server rewards still show no trait bounty
    if not _diagBounties then
        _diagBounties = true
        local anyTrait = false
        for _, e in ipairs(out) do if e.trait then anyTrait = true end end
        if not anyTrait then
            for _, e in ipairs(out) do
                warn(("[Auto Bounty] (server) Bounty %s (%s) rewards: %s"):format(
                    tostring(e.id), tostring(e.world or "?"),
                    #e.rewardNames > 0 and table.concat(e.rewardNames, ", ") or "(none)"))
            end
            warn("[Auto Bounty] None match trait keywords " ..
                table.concat(CONFIG.traitKeywords, "/") ..
                ". Tell me which reward above is the trait/reroll one.")
        end
    end
    return out
end

local function readBounties()
    -- 1) authoritative server data (preferred - exact rewards)
    local fromData = readBountiesFromData()
    if fromData then return fromData end

    -- 2) fallback: parse the live GUI (cold start before setup has fired)
    local out = {}
    local gui = getBountyGui()
    if not gui then return out end
    local sf = gui:FindFirstChild("ScrollingFrame")
    if not sf then return out end
    for _, f in ipairs(sf:GetChildren()) do
        local id = tonumber(f.Name)
        if id and f:IsA("GuiObject") then
            local entry = { id = id, progress = 0, required = 0, active = false, trait = false }

            local worldL = f:FindFirstChild("World")
            entry.world = worldL and worldL.Text or nil

            -- enemy name lives in the Description: "-> <font...>Scout Ninja</font> is seeking..."
            local descL = f:FindFirstChild("Description")
            if descL then
                entry.enemy = descL.Text:match(">([^<]+)</font>")
                if entry.enemy then entry.enemy = entry.enemy:match("^%s*(.-)%s*$") end
            end

            local progL = f:FindFirstChild("Progress")
            if progL then entry.progress, entry.required = parseProgress(progL.Text) end

            local isAct = f:FindFirstChild("Is_Active")
            if isAct and isAct.Visible then entry.active = true end
            local accept = f:FindFirstChild("Accept")
            local acceptLbl = accept and accept:FindFirstChild("TextLabel")
            if acceptLbl then
                local t = acceptLbl.Text
                if t == "Pending" or t == "Claim" then entry.active = true end
            end

            -- Reward detection (GUI fallback). Reward icons are clones of
            -- Templates.item, parented under a "Rewards" frame, named by the item
            -- and carrying an "ItemName" TextLabel = item name. We scan the whole
            -- entry for any "trait"/"reroll" reward (covers it even if the Rewards
            -- frame is structured differently than expected).
            entry.rewardNames = {}
            local function consider(str)
                if type(str) ~= "string" or str == "" then return end
                local lc = str:lower()
                for _, kw in ipairs(CONFIG.traitKeywords) do
                    if lc:find(kw, 1, true) then entry.trait = true end
                end
            end
            local rew = f:FindFirstChild("Rewards")
            local scanRoot = rew or f
            for _, r in ipairs(scanRoot:GetDescendants()) do
                -- record an ItemName text (or named icon) for diagnostics
                if r.Name == "ItemName" and (r:IsA("TextLabel") or r:IsA("TextButton")) then
                    entry.rewardNames[#entry.rewardNames + 1] = r.Text
                end
                consider(r.Name)
                if r:IsA("TextLabel") or r:IsA("TextButton") then consider(r.Text) end
            end

            entry.complete = (entry.required > 0) and (entry.progress >= entry.required)
            out[#out + 1] = entry
        end
    end

    -- one-time diagnostic: show what each bounty's rewards are actually called so
    -- we can confirm trait detection (only when we found bounties but no traits)
    if not _diagBounties and #out > 0 then
        _diagBounties = true
        local anyTrait = false
        for _, e in ipairs(out) do if e.trait then anyTrait = true end end
        if not anyTrait then
            for _, e in ipairs(out) do
                warn(("[Auto Bounty] Bounty %s (%s) rewards: %s"):format(
                    tostring(e.id), tostring(e.world or "?"),
                    #e.rewardNames > 0 and table.concat(e.rewardNames, ", ") or "(none read)"))
            end
            warn("[Auto Bounty] No trait bounty detected above. If one of these IS " ..
                "a trait/reroll reward, tell me its exact name so I can match it.")
        end
    end
    return out
end

local function getTickets()
    local gui = getBountyGui()
    local tl = gui and gui:FindFirstChild("Tickets Left")
    local amt = tl and tl:FindFirstChild("Amount")
    if amt then
        local n = tostring(amt.Text):gsub("%D", "")
        return tonumber(n) or 0
    end
    return 0
end

-- ============================================================
-- Bounty actions (direct remotes + GUI refresh)
-- ============================================================
-- Prefer the game's module fn (it InvokeServers + rebuilds the GUI in one go),
-- fall back to a direct remote call + manual GUI refresh.
local function doAction(method, remoteName, id)
    -- Direct remote first: it RETURNS (success, bounties, tickets) so we can keep
    -- our authoritative cache fresh AND refresh the game's GUI ourselves.
    local ok, suc, bounties, tickets = invokeR("Bounties", remoteName, id)
    if ok and suc then
        setBountyCache(bounties, tickets)
        refreshGUI(bounties, tickets)
        return true
    end
    -- fallback to the game's own module fn (it InvokeServers + rebuilds the GUI)
    local m = ensureModule()
    if m and m[method] then
        throttle()
        local ok2 = pcall(m[method], id)
        if ok2 then return true end
    end
    return false, suc
end
local function bAccept(id)    return doAction("accept",      "accept",      id) end
local function bDecline(id)   return doAction("decline",     "decline",     id) end
local function bClaim(id)     return doAction("claim",       "claim",       id) end
local function bUseTicket()   return doAction("use_ticket",  "use_ticket",  nil) end

-- ============================================================
-- Matchmaking (start the bounty's world)
-- ============================================================
local function startMap(world, act)
    local current = {
        world        = world,
        act          = act or CONFIG.act,
        mode         = "Story",
        difficulty   = CONFIG.difficulty,
        only_friends = CONFIG.soloOnly and true or false,
    }
    local okC, sucC, room = invokeR("Play", "create_room", current)
    if not (okC and sucC) then
        return false, tostring(room or "create_room failed")
    end
    task.wait(0.3)
    -- prime the re-exec queue RIGHT before we teleport, so the script comes
    -- back automatically in the battle place (and again on the way to lobby)
    if armReexec then pcall(armReexec) end
    local okS, sucS = invokeR("Play", "start")
    if okS and sucS then return true end
    -- couldn't start; clean up the room so we don't get stuck
    pcall(function() fireR("Play", "leave") end)
    return false, "start failed"
end

-- ============================================================
-- UI handle (set later) + status helper
-- ============================================================
local Win
local function setStatus(msg)
    if Win then pcall(function() Win:Status(msg) end) end
end
local function notify(title, msg, typ)
    if Win then pcall(function() Win:Notify(title, msg, 4, typ or "info") end) end
